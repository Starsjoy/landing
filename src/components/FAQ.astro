---
const faqs = [
  {
    q: "To'lov qanday amalga oshiriladi?",
    a: "To'lovni Click yoki kartaga o'tkazish orqali amalga oshirishingiz mumkin. Bot sizga qulay to'lov usulini tanlash imkonini beradi.",
  },
  {
    q: 'Stars qancha vaqtda yetkaziladi?',
    a: "To'lov tasdiqlangandan so'ng 1-5 daqiqa ichida Stars hisobingizga tushadi. Agar 5 daqiqadan ko'proq vaqt ketsa, 10 Stars cashback beriladi.",
  },
  {
    q: 'Premium obuna qancha muddatga beriladi?',
    a: "Telegram Premium 1 oy, 3 oy, 6 oy yoki 1 yillik muddatlarda sotib olish mumkin. Uzoqroq muddat tanlasangiz, narx arzonroq bo'ladi.",
  },
  {
    q: 'Pul qaytarish mumkinmi?',
    a: "Ha, agar xizmat yetkazilmasa yoki texnik muammo yuzaga kelsa, to'langan summa 100% qaytariladi. Buning uchun bot orqali qo'llab-quvvatlash xizmatiga murojaat qiling.",
  },
  {
    q: 'Referral dastur qanday ishlaydi?',
    a: "Botdan shaxsiy referral havolangizni oling va do'stlaringiz bilan ulashing. Har safar do'stingiz xarid qilganda, xarid summasining 5% ini bonus sifatida olasiz.",
  },
];
---

<section id="faq">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-label">FAQ</span>
      <h2 class="section-title">Ko'p beriladigan savollar</h2>
      <p class="section-subtitle">Eng ko'p so'raladigan savollarga javoblar</p>
    </div>
    <div class="faq-list">
      {faqs.map((faq) => (
        <div class="faq-item fade-in">
          <button class="faq-question">
            <span>{faq.q}</span>
            <span class="faq-toggle">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">{faq.a}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement!;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const isActive = item.classList.contains('active');

      // Close all
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('active');
        (i.querySelector('.faq-answer') as HTMLElement).style.maxHeight = '';
      });

      // Open clicked if it was closed
      if (!isActive) {
        item.classList.add('active');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });
</script>

<style>
  .faq-list {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: #FFFFFF;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
    box-shadow: var(--shadow-sm);
  }
  .faq-item.active {
    border-color: rgba(124, 58, 237, 0.3);
    box-shadow: 0 4px 16px rgba(124, 58, 237, 0.08);
  }

  .faq-question {
    width: 100%;
    padding: 20px 24px;
    background: none;
    border: none;
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-family: inherit;
  }
  .faq-question:hover { color: var(--primary); }

  .faq-toggle {
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: 8px;
    background: rgba(124, 58, 237, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--primary);
    transition: transform 0.3s;
  }
  .faq-item.active .faq-toggle { transform: rotate(45deg); }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-answer-inner {
    padding: 0 24px 20px;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }
</style>
