---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const uzPath = currentPath.replace(/^\/ru/, '') || '/';
---

<nav id="navbar">
  <div class="nav-inner">
    <a href="/ru" class="logo">
      <img src="/logo.png" alt="StarsJoy" class="logo-img" />
      <span>StarsJoy</span>
    </a>
    <ul class="nav-links">
      <li><a href="/ru">Главная</a></li>
      <li><a href="/ru/stars">Stars</a></li>
      <li><a href="/ru/premium">Premium</a></li>
      <li><a href="/ru/gifts">Gifts</a></li>
      <li><a href="/ru#guarantees">Гарантии</a></li>
      <li><a href="/ru/blog">Блог</a></li>
      <li class="mobile-menu-cta"><a href="https://t.me/starsjoybot" class="nav-cta" target="_blank">Перейти в бот</a></li>
    </ul>
    <div class="nav-right">
      <a href={uzPath} class="lang-switch desktop-lang">🇺🇿</a>
      <a href="https://t.me/starsjoybot" class="nav-cta" target="_blank">Перейти в бот</a>
    </div>
    <div class="mobile-actions">
      <a href={uzPath} class="lang-switch mobile-lang">🇺🇿</a>
      <button class="mobile-toggle" aria-label="Menu">
        <span class="hamburger"></span>
      </button>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 50);
    navLinks?.classList.remove('show');
    toggle?.classList.remove('active');
  });

  const toggle = document.querySelector('.mobile-toggle');
  const navLinks = document.querySelector('.nav-links');
  toggle?.addEventListener('click', () => {
    navLinks?.classList.toggle('show');
    toggle.classList.toggle('active');
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.nav-links') && !target.closest('.mobile-toggle')) {
      navLinks?.classList.remove('show');
      toggle?.classList.remove('active');
    }
  });
</script>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 16px 0;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
  }
  nav.scrolled {
    padding: 10px 0;
    border-bottom-color: var(--border);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
  }

  .nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.4rem;
    font-weight: 800;
    text-decoration: none;
    color: var(--text);
  }
  .logo-img {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    object-fit: cover;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--primary); }

  .lang-switch {
    padding: 0;
    background: none;
    font-size: 1.2rem !important;
    line-height: 1;
    text-decoration: none !important;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-cta {
    padding: 10px 24px;
    background: var(--gradient);
    border: none;
    border-radius: 50px;
    color: #fff;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(124, 58, 237, 0.3);
  }

  .mobile-actions {
    display: none;
    align-items: center;
    gap: 12px;
  }

  .mobile-lang {
    display: none;
  }
  .mobile-menu-cta {
    display: none;
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    width: 32px;
    height: 32px;
    position: relative;
  }
  .hamburger,
  .hamburger::before,
  .hamburger::after {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.3s;
    position: absolute;
    left: 5px;
  }
  .hamburger { top: 15px; }
  .hamburger::before { content: ''; top: -7px; }
  .hamburger::after { content: ''; top: 7px; }

  .mobile-toggle.active .hamburger { background: transparent; }
  .mobile-toggle.active .hamburger::before { top: 0; transform: rotate(45deg); }
  .mobile-toggle.active .hamburger::after { top: 0; transform: rotate(-45deg); }

  @media (max-width: 768px) {
    .nav-links {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      padding: 0 24px;
      gap: 0;
      border-bottom: 1px solid transparent;
      box-shadow: none;
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: max-height 0.35s ease, opacity 0.25s ease, padding 0.35s ease, gap 0.35s ease;
    }
    .nav-links.show {
      max-height: 500px;
      opacity: 1;
      padding: 24px;
      gap: 20px;
      border-bottom-color: var(--border);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    }
    .nav-right { display: none; }
    .mobile-actions { display: flex; }
    .mobile-lang { display: inline-block; }
    .mobile-menu-cta { display: list-item; list-style: none; }
    .mobile-menu-cta .nav-cta { display: inline-flex; text-align: center; justify-content: center; width: 100%; color: #fff; }
    .mobile-toggle { display: block; }
  }
</style>
