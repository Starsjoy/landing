<section class="hero" id="hero">
  <div class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">
        Telegram Stars<br>
        Premium va Gifts<br>
        <span class="hero-highlight">5 daqiqada!</span>
      </h1>
      <p class="hero-desc">
        StarsJoy orqali Telegram Stars xarid qiling, Premium obuna bo'ling yoki do'stlaringizga sovg'a yuboring.
      </p>
      <div class="hero-buttons">
        <a href="https://t.me/starsjoybot" class="btn-primary" target="_blank">
          &#9889; Botga o'tish
        </a>
        <a href="#services" class="btn-secondary">
          Xizmatlarni ko'rish &#8595;
        </a>
      </div>
    </div>

    <div class="hero-visual">
      <!-- Logo -->
      <div class="logo-float" id="logoFloat">
        <img src="/logo.png" alt="StarsJoy" class="float-logo" />
      </div>

      <!-- 3D Cube (4 sides) -->
      <div class="cube-stage">
        <div class="cube" id="cube3d">
          <!-- Front: Stars -->
          <div class="cube-face face-front">
            <div class="face-icon face-icon-star">
              <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
                <defs>
                  <linearGradient id="csG1" x1="6" y1="6" x2="46" y2="46">
                    <stop offset="0%" stop-color="#FFD60A"/>
                    <stop offset="50%" stop-color="#FFAE00"/>
                    <stop offset="100%" stop-color="#FF9500"/>
                  </linearGradient>
                </defs>
                <path d="M26 4l6.2 12.5L45 18.8l-9.5 9.3 2.2 13.1L26 34.8l-11.7 6.4 2.2-13.1L7 18.8l12.8-2.3L26 4z" fill="url(#csG1)"/>
                <path d="M26 4l6.2 12.5L45 18.8l-9.5 9.3 2.2 13.1L26 34.8V4z" fill="#FFE066" opacity="0.35"/>
              </svg>
            </div>
            <span class="face-title">Stars</span>
            <span class="face-sub">Yulduzlar xarid qiling</span>
          </div>

          <!-- Right: Premium -->
          <div class="cube-face face-right">
            <div class="face-icon face-icon-prem">
              <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
                <defs>
                  <linearGradient id="csG2" x1="8" y1="6" x2="44" y2="46">
                    <stop offset="0%" stop-color="#6B93FF"/>
                    <stop offset="50%" stop-color="#976FFF"/>
                    <stop offset="100%" stop-color="#E46ACE"/>
                  </linearGradient>
                </defs>
                <path d="M26 5L9 21l17 26 17-26L26 5z" fill="url(#csG2)"/>
                <path d="M26 5l17 16L26 47V5z" fill="#A78BFA" opacity="0.3"/>
                <path d="M9 21L26 5v42L9 21z" fill="#fff" opacity="0.12"/>
                <path d="M15 21l11-11 11 11" stroke="#fff" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
              </svg>
            </div>
            <span class="face-title">Premium</span>
            <span class="face-sub">Obuna bo'ling</span>
          </div>

          <!-- Back: Gifts -->
          <div class="cube-face face-back">
            <div class="face-icon face-icon-gift">
              <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
                <defs>
                  <linearGradient id="csG3" x1="6" y1="10" x2="46" y2="48">
                    <stop offset="0%" stop-color="#FF6B9D"/>
                    <stop offset="50%" stop-color="#C850C0"/>
                    <stop offset="100%" stop-color="#8B5CF6"/>
                  </linearGradient>
                </defs>
                <rect x="8" y="22" width="36" height="24" rx="4" fill="url(#csG3)"/>
                <rect x="11" y="14" width="30" height="10" rx="4" fill="url(#csG3)" opacity="0.85"/>
                <rect x="23" y="14" width="6" height="32" rx="1.5" fill="#fff" opacity="0.3"/>
                <rect x="8" y="26" width="36" height="4" rx="1" fill="#fff" opacity="0.15"/>
                <path d="M26 14c-3-7-12-7-12 0s12 8 12 8 12-1 12-8-9-7-12 0z" fill="#fff" opacity="0.3"/>
              </svg>
            </div>
            <span class="face-title">Gifts</span>
            <span class="face-sub">Sovg'a yuboring</span>
          </div>

          <!-- Left: 10% Cashback -->
          <div class="cube-face face-left">
            <div class="face-icon face-icon-cash">
              <svg width="52" height="52" viewBox="0 0 52 52" fill="none">
                <defs>
                  <linearGradient id="csG4" x1="6" y1="6" x2="46" y2="46">
                    <stop offset="0%" stop-color="#34D399"/>
                    <stop offset="50%" stop-color="#10B981"/>
                    <stop offset="100%" stop-color="#059669"/>
                  </linearGradient>
                </defs>
                <circle cx="26" cy="26" r="20" fill="url(#csG4)"/>
                <path d="M26 14v24M32 20c0-3.3-2.7-6-6-6s-6 2.7-6 6c0 3.3 2.7 6 6 6s6 2.7 6 6c0 3.3-2.7 6-6 6s-6-2.7-6-6" stroke="#fff" stroke-width="2.5" stroke-linecap="round" fill="none"/>
              </svg>
            </div>
            <span class="face-title">Cashback</span>
            <span class="face-sub">Referral bonus</span>
          </div>
        </div>
      </div>

      <!-- Shadow -->
      <div class="cube-shadow" id="cubeShadow"></div>

      <!-- Dots -->
      <div class="dot d1" id="dot1"></div>
      <div class="dot d2" id="dot2"></div>
      <div class="dot d3" id="dot3"></div>
      <div class="dot d4" id="dot4"></div>
      <div class="dot d5" id="dot5"></div>
      <div class="dot d6" id="dot6"></div>
    </div>
  </div>
</section>

<!-- Animations via JavaScript — 100% ishlaydi -->
<script>
  // 3D Cube rotation (4 sides)
  const cube = document.getElementById('cube3d');
  if (cube) {
    let angle = 0;

    function rotateCube() {
      angle += 0.3;
      const tiltX = Math.sin(angle * 0.01) * 6;
      cube!.style.transform = `rotateY(${angle}deg) rotateX(${tiltX}deg)`;
      requestAnimationFrame(rotateCube);
    }
    rotateCube();
  }

  // Logo float
  const logoEl = document.getElementById('logoFloat');
  if (logoEl) {
    let t = 0;
    function floatLogo() {
      t += 0.025;
      const y = Math.sin(t) * 8;
      logoEl!.style.transform = `translateY(${y}px)`;
      requestAnimationFrame(floatLogo);
    }
    floatLogo();
  }

  // Shadow pulse
  const shadow = document.getElementById('cubeShadow');
  if (shadow) {
    let st = 0;
    function pulseShadow() {
      st += 0.02;
      const s = 0.85 + Math.sin(st) * 0.15;
      const o = 0.4 + Math.sin(st) * 0.2;
      shadow!.style.transform = `scaleX(${s})`;
      shadow!.style.opacity = `${o}`;
      requestAnimationFrame(pulseShadow);
    }
    pulseShadow();
  }

  // Sparkle dots
  document.querySelectorAll('.dot').forEach((dot, i) => {
    const el = dot as HTMLElement;
    let dt = i * 1.2;
    function animDot() {
      dt += 0.025;
      const val = (Math.sin(dt) + 1) / 2; // 0..1
      const opacity = val * 0.9;
      const scale = 0.5 + val * 0.8;
      const moveY = val * -10;
      el.style.opacity = `${opacity}`;
      el.style.transform = `scale(${scale}) translateY(${moveY}px)`;
      requestAnimationFrame(animDot);
    }
    animDot();
  });
</script>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding: 100px 24px 80px;
    overflow: hidden;
    background: linear-gradient(180deg, #F8F6FF 0%, #FFFFFF 100%);
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -200px; right: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.08), transparent 70%);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute;
    bottom: -100px; left: -200px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.06), transparent 70%);
    pointer-events: none;
  }

  .hero-container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 60px;
    width: 100%;
  }

  .hero-content { flex: 1; position: relative; z-index: 1; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    background: rgba(217, 119, 6, 0.08);
    border: 1px solid rgba(217, 119, 6, 0.2);
    border-radius: 50px;
    color: var(--accent);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
  }
  .hero-title {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 20px;
    color: var(--text);
  }
  .hero-highlight {
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: 36px;
    max-width: 520px;
    line-height: 1.7;
  }
  .hero-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-muted);
  }
  .trust-icon { font-size: 1rem; }
  .trust-divider { width: 1px; height: 20px; background: var(--border); }

  /* ===== RIGHT VISUAL ===== */
  .hero-visual {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    min-height: 450px;
  }

  /* Logo float — 3D look, behind the cube */
  .logo-float {
    margin-bottom: 15px;
    position: relative;
    z-index: 1;
    will-change: transform;
    perspective: 500px;
  }
  .float-logo {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    object-fit: cover;
    transform: rotateY(-14deg) rotateX(-8deg);
    box-shadow:
      -2px 2px 0 rgba(124, 58, 237, 0.18),
      -4px 4px 0 rgba(124, 58, 237, 0.13),
      -6px 6px 0 rgba(124, 58, 237, 0.08),
      -8px 8px 0 rgba(124, 58, 237, 0.04),
      0 16px 48px rgba(124, 58, 237, 0.3);
  }

  /* 4-sided Cube */
  .cube-stage {
    width: 260px;
    height: 260px;
    perspective: 800px;
    cursor: grab;
    position: relative;
    z-index: 2;
  }
  .cube {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .cube-face {
    position: absolute;
    width: 260px;
    height: 260px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(232, 228, 240, 0.6);
    border-radius: 24px;
    backface-visibility: visible;
    box-shadow: 0 8px 32px rgba(124, 58, 237, 0.06);
  }
  .face-front  { transform: translateZ(130px); }
  .face-right  { transform: rotateY(90deg) translateZ(130px); }
  .face-back   { transform: rotateY(180deg) translateZ(130px); }
  .face-left   { transform: rotateY(-90deg) translateZ(130px); }

  .face-icon {
    width: 104px;
    height: 104px;
    border-radius: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .face-icon-star { background: linear-gradient(135deg, #FFF8E1, #FFE082); box-shadow: 0 8px 24px rgba(255, 174, 0, 0.15); }
  .face-icon-prem { background: linear-gradient(135deg, #EDE7F6, #D1C4E9); box-shadow: 0 8px 24px rgba(151, 111, 255, 0.15); }
  .face-icon-gift { background: linear-gradient(135deg, #FCE4EC, #F8BBD0); box-shadow: 0 8px 24px rgba(200, 80, 192, 0.15); }
  .face-icon-cash { background: linear-gradient(135deg, #D1FAE5, #A7F3D0); box-shadow: 0 8px 24px rgba(16, 185, 129, 0.15); }

  .face-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text);
    text-align: center;
  }
  .face-sub {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-align: center;
  }

  /* Shadow */
  .cube-shadow {
    width: 208px;
    height: 39px;
    margin-top: 20px;
    background: radial-gradient(ellipse, rgba(124, 58, 237, 0.12), transparent 70%);
    border-radius: 50%;
    will-change: transform, opacity;
  }

  /* Sparkle dots */
  .dot {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform, opacity;
    opacity: 0;
  }
  .d1 { width: 8px; height: 8px; background: #FFD60A; top: 10%; left: 10%; }
  .d2 { width: 6px; height: 6px; background: #976FFF; top: 15%; right: 5%; }
  .d3 { width: 5px; height: 5px; background: #FF6B9D; top: 50%; right: 0; }
  .d4 { width: 7px; height: 7px; background: #6B93FF; bottom: 15%; left: 8%; }
  .d5 { width: 5px; height: 5px; background: #C850C0; bottom: 25%; right: 10%; }
  .d6 { width: 6px; height: 6px; background: #FFAE00; top: 40%; left: 2%; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .hero { min-height: auto; }
    .hero-container { flex-direction: column; text-align: center; gap: 36px; }
    .hero-title { font-size: 2.6rem; }
    .hero-desc { margin: 0 auto 36px; }
    .hero-buttons { justify-content: center; }
    .hero-trust { justify-content: center; }
    .cube-stage { width: 234px; height: 234px; }
    .cube-face { width: 234px; height: 234px; }
    .face-front  { transform: translateZ(117px); }
    .face-right  { transform: rotateY(90deg) translateZ(117px); }
    .face-back   { transform: rotateY(180deg) translateZ(117px); }
    .face-left   { transform: rotateY(-90deg) translateZ(117px); }
    .face-icon { width: 88px; height: 88px; border-radius: 24px; }
    .float-logo { width: 60px; height: 60px; }
    .logo-float { margin-bottom: -4px; }
  }

  @media (max-width: 640px) {
    .hero { padding: 140px 16px 67px; }
    .hero-container { gap: 24px; }
    .hero-title { font-size: 2rem; }
    .hero-desc { font-size: 1.05rem; margin-bottom: 28px; }
    .hero-buttons { flex-direction: column; align-items: center; margin-bottom: 24px; }
    .hero-buttons :global(.btn-primary),
    .hero-buttons :global(.btn-secondary) { width: 70%; justify-content: center; padding: 10px 22px; font-size: 0.81rem; gap: 6px; }
    .hero-trust { flex-direction: column; gap: 8px; }
    .trust-divider { display: none; }
    .hero-visual { min-height: 300px; }
    .cube-stage { width: 195px; height: 195px; }
    .cube-face { width: 195px; height: 195px; border-radius: 24px; }
    .face-front  { transform: translateZ(98px); }
    .face-right  { transform: rotateY(90deg) translateZ(98px); }
    .face-back   { transform: rotateY(180deg) translateZ(98px); }
    .face-left   { transform: rotateY(-90deg) translateZ(98px); }
    .face-icon { width: 73px; height: 73px; border-radius: 20px; }
    .face-title { font-size: 0.88rem; }
    .face-sub { font-size: 0.7rem; }
    .float-logo { width: 52px; height: 52px; border-radius: 14px; }
    .logo-float { margin-bottom: -3px; }
    .cube-shadow { width: 160px; height: 30px; margin-top: 14px; }
  }
</style>
