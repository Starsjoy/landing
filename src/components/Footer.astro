<style>
  footer {
    padding: 60px 24px 32px;
    border-top: 1px solid var(--border);
    background: #F9F8FC;
  }

  .footer-inner {
    max-width: 1140px;
    margin: 0 auto 48px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.4rem;
    font-weight: 800;
    text-decoration: none;
    color: var(--text);
  }
  .footer-logo-img {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    object-fit: cover;
  }

  .footer-desc {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-top: 12px;
    max-width: 280px;
    line-height: 1.6;
  }

  .footer-heading {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 16px;
    color: var(--text);
  }
  .footer-col a {
    display: block;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.92rem;
    margin-bottom: 10px;
    transition: color 0.2s;
  }
  .footer-col a:hover { color: var(--primary); }
  .footer-link-icon {
    display: flex !important;
    align-items: center;
    gap: 8px;
  }
  .footer-link-icon svg { flex-shrink: 0; }

  .footer-bottom {
    max-width: 1140px;
    margin: 0 auto;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-socials {
    display: flex;
    gap: 12px;
  }
  .footer-socials a {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #FFFFFF;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 1.1rem;
    transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
  }
  .footer-socials a:hover {
    border-color: rgba(124, 58, 237, 0.3);
    color: var(--primary);
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 1024px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
  }
</style>
