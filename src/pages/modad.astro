      function renderRecent() {
        const allRows = statsData.recent;
        if (!allRows.length) {
          document.getElementById('recentTable').innerHTML = '<div class="empty">Tashriflar hali yo\'q</div>';
          return;
        }
        const rows = rowLimit > 0 ? allRows.slice(0, rowLimit) : allRows;
        var countText = rowLimit > 0 ? rows.length + ' / ' + allRows.length : allRows.length + ' ta';
        document.getElementById('recentTable').innerHTML = `<div style="padding:8px 20px 0;font-size:0.72rem;color:var(--text-3)">${countText} tashrif</div><table>
          <thead><tr><th>Turi</th><th>Sahifa</th><th>Mamlakat</th><th>Vaqt</th><th>Davomiylik</th><th>User-Agent</th></tr></thead>
          <tbody>${rows.map(v => {
            var type = v.isBot
              ? '<span class="' + botPillClass(v.botName) + '">' + v.botName + '</span>'
              : '<span class="pill pill-human">Odam</span>';
            var path = '<span class="path-chip">' + fmtPath(v.path) + '</span>';
            var country = (v.country && v.country !== 'Local' && v.country !== '—')
              ? '<span class="country-cell"><span class="flag">' + countryFlag(v.country) + '</span><span class="name">' + v.country + '</span></span>'
              : '';
            var time = '<span style="color:var(--text-3)">' + timeAgo(v.timestamp) + '</span>';
