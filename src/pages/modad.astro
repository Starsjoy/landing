      /* ── Sales filter ── */
      .sales-filter { flex-direction: column; align-items: stretch; gap: 10px; }
      .sf-tabs { overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
      .sf-tabs::-webkit-scrollbar { display: none; }
      .sf-tab { flex-shrink: 0; padding: 8px 14px; }
      .sf-date { width: 100%; }
      .sf-date input[type="date"] { flex: 1; min-width: 0; }
      .sales-cards { grid-template-columns: 1fr 1fr !important; }

      /* ── Login ── */
      .login-box { padding: 36px 24px; border-radius: 16px; }
      .login-box h1 { font-size: 1.15rem; }
      .login-box input { padding: 14px 16px; font-size: 0.92rem; }
      .login-box button { padding: 14px; font-size: 0.92rem; }
    }

    /* Extra small — phones under 380px */
    @media (max-width: 380px) {
      .content { padding: 10px; }
      .topbar { padding: 10px 12px; }
      .stat-cards { grid-template-columns: 1fr; gap: 8px; }
      .stat-cards .stat-card:last-child { grid-column: auto; }
      .stat-card .sc-value { font-size: 1.4rem; }
      .tb-filters button { padding: 7px 12px; font-size: 0.72rem; }
    }
  </style>

  {authenticated && (
    <script is:inline>
      let currentSection = 'overview';
      let currentPeriod = 'today';
      let statsData = null;
      let rowLimit = 10;

      function setRowLimit(n) {
        rowLimit = n;
        document.querySelectorAll('.rf-btn').forEach(b => {
          b.classList.toggle('active', (n === 0 && b.textContent === 'Barchasi') || (n > 0 && b.textContent === String(n)));
        });
        renderRecent();
      }

      function showSection(name) {
        currentSection = name;
        document.querySelectorAll('.section-content').forEach(el => el.hidden = true);
        const sec = document.getElementById('section-' + name);
        if (sec) sec.hidden = false;
        document.querySelectorAll('#sidebar-nav a').forEach(a => {
          a.classList.toggle('active', a.dataset.section === name);
        });
        closeSidebar();
      }

      function setPeriod(p) {
        currentPeriod = p;
        document.querySelectorAll('#filters button').forEach(b => {
          b.classList.toggle('active', b.dataset.period === p);
        });
        fetchStats();
      }

      function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('open');
        document.getElementById('overlay').classList.toggle('open');
      }
      function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('overlay').classList.remove('open');
      }

      function logout() {
        document.cookie = 'moda_token=;path=/;max-age=0';
        location.reload();
      }

      function timeAgo(ts) {
        const diff = Date.now() - new Date(ts).getTime();
        const m = Math.floor(diff / 60000);
        if (m < 1) return 'hozirgina';
        if (m < 60) return m + ' daq oldin';
        const h = Math.floor(m / 60);
        if (h < 24) return h + ' soat oldin';
        const d = Math.floor(h / 24);
        return d + ' kun oldin';
      }

      function fmtDur(sec) {
        if (!sec || sec <= 0) return '';
        if (sec < 60) return sec + ' son';
        var m = Math.floor(sec / 60);
        var s = sec % 60;
        if (s === 0) return m + ' daq';
        return m + ' daq ' + s + ' son';
      }

      function countryFlag(code) {
        if (!code || code.length !== 2) return '';
        return String.fromCodePoint(...[...code.toUpperCase()].map(c => 0x1F1E6 + c.charCodeAt(0) - 65));
      }

      function fmtPath(p) {
        if (!p || p === '/') return 'Asosiy sahifa';
        return p;
      }

      var botColors = {};
      var colorPool = ['orange','blue','purple','cyan','red','pink','teal','lime'];
      var colorIdx = 0;
      function botPillClass(name) {
        if (!botColors[name]) { botColors[name] = colorPool[colorIdx % colorPool.length]; colorIdx++; }
        return 'pill pill-bot pill-bot-' + botColors[name];
      }

      async function fetchStats() {
        var dot = document.querySelector('.live-dot');
        var txt = document.querySelector('.live-text');
        if (dot) { dot.style.background = 'var(--orange)'; dot.style.boxShadow = '0 0 8px rgba(245,158,11,0.5)'; }
        if (txt) txt.style.color = 'var(--orange)';
        try {
          const res = await fetch('/api/stats?period=' + currentPeriod);
          if (res.status === 401) { location.reload(); return; }
          statsData = await res.json();
          renderAll();
          if (dot) { dot.style.background = 'var(--green)'; dot.style.boxShadow = '0 0 8px rgba(16,185,129,0.5)'; }
          if (txt) txt.style.color = 'var(--green)';
        } catch (e) {
          if (dot) { dot.style.background = 'var(--red)'; dot.style.boxShadow = '0 0 8px rgba(239,68,68,0.5)'; }
          if (txt) txt.style.color = 'var(--red)';
        }
        var loader = document.getElementById('loading');
        if (loader) loader.style.display = 'none';
      }

      var salesPeriod = 'today';
      var salesFrom = '';
      var salesTo = '';

      function setSalesPeriod(p) {
        salesPeriod = p;
        salesFrom = '';
        salesTo = '';
        document.getElementById('salesDateFrom').value = '';
        document.getElementById('salesDateTo').value = '';
        document.querySelectorAll('.sf-tab').forEach(b => b.classList.toggle('active', b.dataset.speriod === p));
        fetchSales();
      }

      function setSalesCustomDate() {
        salesFrom = document.getElementById('salesDateFrom').value;
        salesTo = document.getElementById('salesDateTo').value;
        if (salesFrom) {
          salesPeriod = '';
          document.querySelectorAll('.sf-tab').forEach(b => b.classList.remove('active'));
          fetchSales();
        }
      }

      async function fetchSales() {
        var params = salesFrom
          ? 'salesFrom=' + salesFrom + (salesTo ? '&salesTo=' + salesTo : '')
          : 'period=' + (salesPeriod === 'all' ? '12months' : salesPeriod);
        try {
          var res = await fetch('/api/stats?' + params + '&period=' + currentPeriod);
          if (res.status === 401) { location.reload(); return; }
          var data = await res.json();
          statsData.orders = data.orders;
          renderSalesAll();
        } catch (e) { console.error('Sales fetch error:', e); }
      }

      function renderSalesAll() {
        renderSales();
        renderDailyRevenue();
        renderTopBuyers();
        renderDailyStars();
      }

      function renderAll() {
        if (!statsData) return;
        renderStatCards();
        renderRecent();
        renderBots();
        renderUsers();
        renderCountries();
        renderPages();
        renderSalesAll();
        renderProfit(statsData.orders);
        renderCharts();
      }

      var periodLabels = {
        today: 'Bugun', week: 'Hafta', month: 'Oy',
        '3months': '3 oy', '6months': '6 oy', '12months': '1 yil'
      };

      function renderStatCards() {
        var o = statsData.overview;
        var label = periodLabels[currentPeriod] || currentPeriod;
        document.getElementById('statCards').innerHTML = `
          <div class="stat-card highlighted">
            <div class="sc-label">${label} — jami</div>
            <div class="sc-value">${o.sessions}</div>
            <div class="sc-sub">
              <span>${o.views} ko'rish</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="sc-label">Odamlar</div>
            <div class="sc-value">${o.humanSessions}</div>
            <div class="sc-sub">
              <span class="sc-green">${o.humanViews} ko'rish</span>
            </div>
          </div>
          <div class="stat-card">
            <div class="sc-label">Botlar</div>
            <div class="sc-value">${o.botSessions}</div>
            <div class="sc-sub">
              <span class="sc-orange">${o.botViews} ko'rish</span>
            </div>
          </div>
        `;
      }

      function renderRecent() {
        const allRows = statsData.recent;
        if (!allRows.length) {
          document.getElementById('recentTable').innerHTML = '<div class="empty">Tashriflar hali yo\'q</div>';
          return;
        }
        const rows = rowLimit > 0 ? allRows.slice(0, rowLimit) : allRows;
        var countText = rowLimit > 0 ? rows.length + ' / ' + allRows.length : allRows.length + ' ta';
        document.getElementById('recentTable').innerHTML = `<div style="padding:8px 20px 0;font-size:0.72rem;color:var(--text-3)">${countText} tashrif</div><table>
          <thead><tr><th>Turi</th><th>Sahifa</th><th>Mamlakat</th><th>Vaqt</th><th>Davomiylik</th><th>User-Agent</th></tr></thead>
          <tbody>${rows.map(v => {
            var type = v.isBot
              ? '<span class="' + botPillClass(v.botName) + '">' + v.botName + '</span>'
              : '<span class="pill pill-human">Odam</span>';
            var path = '<span class="path-chip">' + fmtPath(v.path) + '</span>';
            var country = (v.country && v.country !== 'Local' && v.country !== '—')
              ? '<span class="country-cell"><span class="flag">' + countryFlag(v.country) + '</span><span class="name">' + v.country + '</span></span>'
              : '';
            var time = '<span style="color:var(--text-3)">' + timeAgo(v.timestamp) + '</span>';
            var dur = fmtDur(v.duration) ? '<span class="dur">' + fmtDur(v.duration) + '</span>' : '';
            var ua = v.userAgent ? '<span class="ua-chip" title="' + v.userAgent.replace(/"/g, '&quot;') + '">' + v.userAgent.slice(0, 40) + (v.userAgent.length > 40 ? '...' : '') + '</span>' : '';
            return '<tr><td>' + type + '</td><td>' + path + '</td><td>' + country + '</td><td>' + time + '</td><td>' + dur + '</td><td>' + ua + '</td></tr>';
          }).join('')}</tbody>
        </table>`;
