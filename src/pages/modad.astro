            var ua = v.userAgent ? '<span class="ua-chip" title="' + v.userAgent.replace(/"/g, '&quot;') + '">' + v.userAgent.slice(0, 40) + (v.userAgent.length > 40 ? '...' : '') + '</span>' : '';
