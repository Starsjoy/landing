---
export const prerender = false;

import { verifyToken, verifyPassword, generateToken, initDB } from '../lib/analytics';

const token = Astro.cookies.get('moda_token')?.value || '';
let authenticated = await verifyToken(token);
let loginError = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = form.get('password')?.toString() || '';
  if (await verifyPassword(password)) {
    const newToken = generateToken(password);
    Astro.cookies.set('moda_token', newToken, { path: '/', httpOnly: true, secure: true, sameSite: 'lax', maxAge: 60 * 60 * 24 * 7 });
    authenticated = true;
  } else {
    loginError = "Parol noto'g'ri";
  }
}

if (authenticated) {
  try { await initDB(); } catch (e) { console.error('DB init error:', e); }
}
---

<!doctype html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Analytics — StarsJoy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  {!authenticated ? (
    <div class="login-wrap">
      <form class="login-box" method="POST">
        <div class="login-brand">
          <div class="login-logo">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="white"/></svg>
