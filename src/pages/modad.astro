      // ───── SALARY (MAOSH) ─────
      var salaryState = null;

      function formatSalAmount(input) {
        var raw = (input.value || '').replace(/\D/g, '');
        if (!raw) { input.value = ''; return; }
        input.value = parseInt(raw, 10).toLocaleString('en-US');
      }

      function todayTashkentISO() {
        var d = new Date();
        var tz = new Date(d.getTime() + 5 * 60 * 60 * 1000);
        return tz.getUTCFullYear() + '-' + String(tz.getUTCMonth() + 1).padStart(2, '0') + '-' + String(tz.getUTCDate()).padStart(2, '0');
      }

      function fmtMonthName(yyyymm) {
        if (!yyyymm) return '';
        var parts = yyyymm.split('-');
        var months = ['Yanvar','Fevral','Mart','Aprel','May','Iyun','Iyul','Avgust','Sentabr','Oktabr','Noyabr','Dekabr'];
        return months[parseInt(parts[1], 10) - 1] + ' ' + parts[0];
      }

      async function fetchSalary() {
        try {
          var res = await fetch('/api/salary');
          if (!res.ok) {
            document.getElementById('salaryStatus').textContent = "Xato: " + res.status;
            return;
          }
          var data = await res.json();
          salaryState = data;
          renderSalary();
        } catch (e) {
          console.error('Salary fetch error:', e);
        }
      }

      function renderSalary() {
        if (!salaryState) return;
        var s = salaryState;
        var statusEl = document.getElementById('salaryStatus');
        var phaseTxt = '';
        if (s.showClosing) phaseTxt = "Yopilish davri (1–5) — " + fmtMonthName(s.closing.month) + " uchun qolgan maosh";
        else if (s.current.phase === 'first_half') phaseTxt = fmtMonthName(s.current.month) + " 1-yarmi (1–15): rollover + 30% yangi foyda";
        // 2-yarmi (16–oxiri) uchun matn ko'rsatilmaydi
        if (phaseTxt) {
          statusEl.style.display = '';
          statusEl.innerHTML = '<span class="ss-dot"></span><span>' + phaseTxt + '</span>';
          statusEl.classList.toggle('warn', s.current.over > 0);
        } else {
          statusEl.style.display = 'none';
        }

        // Closing context (faqat 1-5 da)
        var closingWrap = document.getElementById('salaryClosing');
        if (s.closing) {
          closingWrap.hidden = false;
          document.getElementById('salaryClosingTitle').textContent = fmtMonthName(s.closing.month) + " (yopilish)";
          document.getElementById('salClosingRollover').textContent = fmtMoney(s.closing.rollover);
          document.getElementById('salClosingWithdrawn').textContent = fmtMoney(s.closing.withdrawn);
          var availEl = document.getElementById('salClosingAvailable');
          var availCard = availEl.closest('.salary-card');
          if (s.closing.over > 0) {
            availEl.textContent = '−' + fmtMoney(s.closing.over);
            document.getElementById('salClosingAvailSub').textContent = "limit oshildi";
            availCard.classList.add('sc-over');
            availCard.classList.remove('sc-primary');
          } else {
            availEl.textContent = fmtMoney(s.closing.available);
            document.getElementById('salClosingAvailSub').textContent = "so'm";
            availCard.classList.remove('sc-over');
            availCard.classList.add('sc-primary');
          }
        } else {
          closingWrap.hidden = true;
        }

        // Current month context
        document.getElementById('salaryCurrentTitle').textContent = fmtMonthName(s.current.month) + " (joriy)";
        document.getElementById('salCurRollover').textContent = fmtMoney(s.current.rollover);
        document.getElementById('salCurWithdrawn').textContent = fmtMoney(s.current.withdrawn);
        document.getElementById('salCurLimit').textContent = s.current.limit > 0 ? fmtMoney(s.current.limit) : '—';
        var limitSubEl = document.getElementById('salCurLimitSub');
        if (s.current.phase === 'new_starting') {
          limitSubEl.textContent = "yangi siklda hali yo'q";
        } else {
          limitSubEl.textContent = "rollover " + fmtMoney(s.current.rollover) + " + 30% × " + fmtMoney(s.current.profit);
        }
        var curAvailEl = document.getElementById('salCurAvailable');
        var curAvailCard = curAvailEl.closest('.salary-card');
        var curAvailLabel = document.getElementById('salCurAvailLabel');
        if (s.current.phase === 'new_starting') {
          curAvailEl.textContent = '—';
          curAvailLabel.textContent = "Yangi sikl boshlanmoqda";
          document.getElementById('salCurAvailSub').textContent = '6-kundan limit hisoblanadi';
          curAvailCard.classList.remove('sc-over');
          curAvailCard.classList.remove('sc-primary');
        } else if (s.current.over > 0) {
