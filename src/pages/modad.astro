---
export const prerender = false;

import { verifyToken, verifyPassword, generateToken, getStats, initDB } from '../lib/analytics';

// Auth check
const token = Astro.cookies.get('moda_token')?.value || '';
let authenticated = verifyToken(token);
let loginError = '';

// Handle login POST
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = form.get('password')?.toString() || '';
  if (verifyPassword(password)) {
    const newToken = generateToken(password);
    Astro.cookies.set('moda_token', newToken, { path: '/', httpOnly: true, secure: true, sameSite: 'lax', maxAge: 60 * 60 * 24 * 7 });
    authenticated = true;
  } else {
    loginError = 'Parol noto\'g\'ri';
  }
}

let stats = null;
if (authenticated) {
  try {
    await initDB();
    stats = await getStats();
  } catch (e) {
    console.error('Stats error:', e);
  }
}

function timeAgo(ts: string) {
  const diff = Date.now() - new Date(ts).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'hozirgina';
  if (mins < 60) return `${mins} daq oldin`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours} soat oldin`;
  const days = Math.floor(hours / 24);
  return `${days} kun oldin`;
}
---

<!doctype html>
<html lang="uz">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Analytics — StarsJoy</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0f0f1a; color: #e0e0f0; min-height: 100vh; }

    /* Login */
    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 24px; }
    .login-box { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 16px; padding: 40px; width: 100%; max-width: 380px; }
    .login-box h1 { font-size: 1.4rem; font-weight: 700; margin-bottom: 8px; color: #fff; }
    .login-box p { font-size: 0.85rem; color: #8888aa; margin-bottom: 24px; }
    .login-box input { width: 100%; padding: 12px 16px; background: #12121f; border: 1px solid #2a2a4a; border-radius: 8px; color: #e0e0f0; font-size: 0.95rem; outline: none; margin-bottom: 16px; }
    .login-box input:focus { border-color: #7C3AED; }
    .login-box button { width: 100%; padding: 12px; background: #7C3AED; color: #fff; border: none; border-radius: 8px; font-size: 0.95rem; font-weight: 600; cursor: pointer; }
    .login-box button:hover { background: #6d28d9; }
    .login-error { color: #ef4444; font-size: 0.85rem; margin-bottom: 12px; }

    /* Dashboard */
    .dash { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }
    .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
    .dash-header h1 { font-size: 1.5rem; font-weight: 800; color: #fff; }
    .dash-header .logout { color: #8888aa; font-size: 0.85rem; text-decoration: none; border: 1px solid #2a2a4a; padding: 6px 14px; border-radius: 6px; }
    .dash-header .logout:hover { border-color: #7C3AED; color: #c4b5fd; }

    /* Stat cards */
    .stat-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 32px; }
    .stat-card { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 12px; padding: 24px; }
    .stat-card .label { font-size: 0.8rem; color: #8888aa; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
    .stat-card .value { font-size: 2rem; font-weight: 800; color: #fff; }
    .stat-card .breakdown { font-size: 0.8rem; color: #8888aa; margin-top: 6px; }
    .stat-card .breakdown span { margin-right: 12px; }
    .stat-card .breakdown .humans { color: #34d399; }
    .stat-card .breakdown .bots { color: #f97316; }

    /* Sections */
    .section { margin-bottom: 32px; }
    .section h2 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 16px; }

    /* Tables */
    .table-wrap { overflow-x: auto; border: 1px solid #2a2a4a; border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    th { background: #1a1a2e; color: #8888aa; font-weight: 600; text-align: left; padding: 12px 16px; border-bottom: 1px solid #2a2a4a; white-space: nowrap; }
    td { padding: 10px 16px; border-bottom: 1px solid rgba(42, 42, 74, 0.5); color: #c8c8e0; white-space: nowrap; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(124, 58, 237, 0.04); }

    /* Badges */
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.75rem; font-weight: 600; }
    .badge-bot { background: rgba(249, 115, 22, 0.15); color: #f97316; }
    .badge-human { background: rgba(52, 211, 153, 0.15); color: #34d399; }
    .badge-country { background: rgba(124, 58, 237, 0.15); color: #c4b5fd; }

    /* Top pages */
    .top-page { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid rgba(42, 42, 74, 0.5); }
    .top-page:last-child { border-bottom: none; }
    .top-page .rank { width: 28px; height: 28px; background: #1a1a2e; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: #7C3AED; flex-shrink: 0; }
    .top-page .page-path { flex: 1; font-size: 0.9rem; color: #c8c8e0; overflow: hidden; text-overflow: ellipsis; }
    .top-page .page-count { font-size: 0.85rem; font-weight: 600; color: #fff; }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .two-col .section { margin-bottom: 0; }

    .empty { color: #555; font-size: 0.9rem; padding: 24px; text-align: center; }

    .pages-list { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 12px; padding: 16px 20px; }

    @media (max-width: 768px) {
      .stat-cards { grid-template-columns: 1fr; }
      .two-col { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  {!authenticated ? (
    <div class="login-wrap">
      <form class="login-box" method="POST">
        <h1>StarsJoy Analytics</h1>
        <p>Kirish uchun parolni kiriting</p>
        {loginError && <div class="login-error">{loginError}</div>}
        <input type="password" name="password" placeholder="Parol" autofocus required />
        <button type="submit">Kirish</button>
      </form>
    </div>
  ) : (
    <div class="dash">
      <div class="dash-header">
        <h1>StarsJoy Analytics</h1>
        <a href="/modad" class="logout" onclick="document.cookie='moda_token=;path=/;max-age=0';return true;">Chiqish</a>
      </div>

      {stats ? (
        <>
          <div class="stat-cards">
            <div class="stat-card">
              <div class="label">Bugun</div>
              <div class="value">{stats.today.total}</div>
              <div class="breakdown">
                <span class="humans">{stats.today.humans} odam</span>
                <span class="bots">{stats.today.bots} bot</span>
              </div>
            </div>
            <div class="stat-card">
              <div class="label">Hafta (7 kun)</div>
              <div class="value">{stats.week.total}</div>
              <div class="breakdown">
                <span class="humans">{stats.week.humans} odam</span>
                <span class="bots">{stats.week.bots} bot</span>
              </div>
            </div>
            <div class="stat-card">
              <div class="label">Oy (30 kun)</div>
              <div class="value">{stats.month.total}</div>
              <div class="breakdown">
                <span class="humans">{stats.month.humans} odam</span>
                <span class="bots">{stats.month.bots} bot</span>
              </div>
            </div>
          </div>

          <div class="section">
            <h2>Bot trafik</h2>
            {stats.botTraffic.length > 0 ? (
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Bot nomi</th>
                      <th>Tashriflar</th>
                      <th>Oxirgi tashrif</th>
                      <th>Sahifalar</th>
                    </tr>
                  </thead>
                  <tbody>
                    {stats.botTraffic.map((bot: any) => (
                      <tr>
                        <td><span class="badge badge-bot">{bot.name}</span></td>
                        <td>{bot.count}</td>
                        <td>{timeAgo(bot.lastSeen)}</td>
                        <td>{bot.pages.slice(0, 3).join(', ')}{bot.pages.length > 3 ? ` +${bot.pages.length - 3}` : ''}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="table-wrap"><div class="empty">Bot trafik hali yo'q</div></div>
            )}
          </div>

          <div class="section">
            <h2>So'nggi 10 ta tashrif</h2>
            {stats.recent.length > 0 ? (
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Turi</th>
                      <th>Sahifa</th>
                      <th>Mamlakat</th>
                      <th>Vaqt</th>
                      <th>Davomiylik</th>
                    </tr>
                  </thead>
                  <tbody>
                    {stats.recent.map((v: any) => (
                      <tr>
                        <td>
                          {v.isBot
                            ? <span class="badge badge-bot">{v.botName}</span>
                            : <span class="badge badge-human">Odam</span>
                          }
                        </td>
                        <td>{v.path}</td>
                        <td>{v.country ? <span class="badge badge-country">{v.country}</span> : '—'}</td>
                        <td>{timeAgo(v.timestamp)}</td>
                        <td>{v.duration > 0 ? `${v.duration}s` : '—'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <div class="table-wrap"><div class="empty">Tashriflar hali yo'q</div></div>
            )}
          </div>

          <div class="two-col">
            <div class="section">
              <h2>Top 5 sahifa</h2>
              {stats.topPages.length > 0 ? (
                <div class="pages-list">
                  {stats.topPages.map((p: any, i: number) => (
                    <div class="top-page">
                      <div class="rank">{i + 1}</div>
                      <div class="page-path">{p.path}</div>
                      <div class="page-count">{p.count}</div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="pages-list"><div class="empty">Ma'lumot yo'q</div></div>
              )}
            </div>
          </div>
        </>
      ) : (
        <div class="table-wrap"><div class="empty">Database ga ulanib bo'lmadi. DATABASE_URL tekshiring.</div></div>
      )}
    </div>
  )}
</body>
</html>
