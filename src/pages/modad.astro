        }
        document.getElementById('topBuyers').innerHTML = `<table>
          <thead><tr><th>#</th><th>Foydalanuvchi</th><th>Buyurtmalar</th><th>Jami</th></tr></thead>
          <tbody>${o.topBuyers.map((b, i) => {
            var details = [];
            if (b.starsOrders) details.push('⭐' + b.starsOrders);
            if (b.giftOrders) details.push('🎁' + b.giftOrders);
            if (b.premiumOrders) details.push('👑' + b.premiumOrders);
            return '<tr>' +
              '<td><span class="pill pill-rank">' + (i + 1) + '</span></td>' +
              '<td>@' + b.username + '</td>' +
              '<td class="td-num">' + b.orders + ' <span style="color:var(--text-4);font-size:0.7rem">' + details.join(' ') + '</span></td>' +
              '<td class="td-num sc-revenue">' + fmtMoney(b.totalSpent) + '</td>' +
            '</tr>';
          }).join('')}</tbody>
        </table>`;
      }

      function renderDailyStars() {
        var o = statsData.orders;
        if (!o || !o.dailyStars || !o.dailyStars.length) {
          document.getElementById('dailyStars').innerHTML = '<div class="empty">Ma\'lumot yo\'q</div>';
          return;
        }
        var max = Math.max(...o.dailyStars.map(d => d.totalStars));
        document.getElementById('dailyStars').innerHTML = o.dailyStars.map(d => {
          var pct = max > 0 ? Math.max((d.totalStars / max) * 100, 4) : 4;
          var dateStr = new Date(d.date).toLocaleDateString('uz', { day: '2-digit', month: '2-digit' });
          return '<div class="dr-row">' +
            '<div class="dr-date">' + dateStr + '</div>' +
            '<div class="dr-bar-bg"><div class="dr-bar" style="width:' + pct + '%;background:linear-gradient(90deg,#facc15,#f59e0b)"></div></div>' +
            '<div class="dr-info"><span class="dr-amount">⭐ ' + fmtMoney(d.totalStars) + '</span><span class="dr-orders"> (' + d.orders + ')</span></div>' +
          '</div>';
        }).join('');
      }

      function renderDailyRevenue() {
        var o = statsData.orders;
        if (!o || !o.daily.length) {
          document.getElementById('dailyRevenue').innerHTML = '<div class="empty">Ma\'lumot yo\'q</div>';
          return;
        }
        var max = Math.max(...o.daily.map(d => d.revenue));
        document.getElementById('dailyRevenue').innerHTML = o.daily.map(d => {
          var pct = max > 0 ? Math.max((d.revenue / max) * 100, 4) : 4;
          var dateStr = new Date(d.date).toLocaleDateString('uz', { day: '2-digit', month: '2-digit' });
          return '<div class="dr-row">' +
            '<div class="dr-date">' + dateStr + '</div>' +
            '<div class="dr-bar-bg"><div class="dr-bar" style="width:' + pct + '%"></div></div>' +
            '<div class="dr-info"><span class="dr-amount">' + fmtMoney(d.revenue) + '</span><span class="dr-orders"> (' + d.orders + ')</span></div>' +
          '</div>';
        }).join('');
      }

      // ───── PROFIT ─────
      var profitPeriod = 'month';

      function setProfitPeriod(p) {
        profitPeriod = p;
        document.querySelectorAll('.pf-btn').forEach(b => b.classList.toggle('active', b.dataset.pp === p));
        fetchProfit();
      }

      async function fetchProfit() {
        try {
          var res = await fetch('/api/stats?period=' + profitPeriod + '&ap=' + chartPeriod);
          if (res.status === 401) { location.reload(); return; }
          var data = await res.json();
          renderProfit(data.orders);
        } catch (e) { console.error('Profit fetch error:', e); }
      }

      function renderProfit(orders) {
        if (!orders) return;
        var ov = orders.overview;
        var revenue = ov.totalRevenue;
        var starsProfit = Math.round(ov.starsRevenue * 0.10);
        var giftProfit = Math.round(ov.giftRevenue * 0.10);
        var premiumProfit = Math.round(ov.premiumRevenue * 0.05);
        var profit = starsProfit + giftProfit + premiumProfit;

        document.getElementById('profitValue').textContent = fmtMoney(profit);
        document.getElementById('profitRevenue').textContent = fmtMoney(revenue);
        document.getElementById('profitOrders').textContent = ov.totalOrders;

        document.getElementById('profitStars').textContent = fmtMoney(ov.starsRevenue) + " so'm";
        document.getElementById('profitStarsP').textContent = fmtMoney(starsProfit) + " so'm (10%)";
        document.getElementById('profitGift').textContent = fmtMoney(ov.giftRevenue) + " so'm";
        document.getElementById('profitGiftP').textContent = fmtMoney(giftProfit) + " so'm (10%)";
        document.getElementById('profitPremium').textContent = fmtMoney(ov.premiumRevenue) + " so'm";
        document.getElementById('profitPremiumP').textContent = fmtMoney(premiumProfit) + " so'm (5%)";
      }

      // ───── ANALYTICS CHARTS ─────
      var chartPeriod = 'week';
      var activeChart = 'sales';

      function setActiveChart(name) {
        activeChart = name;
        document.querySelectorAll('.an-tab').forEach(b => b.classList.toggle('active', b.dataset.chart === name));
        document.querySelectorAll('[id^="chart-"]').forEach(el => {
          el.hidden = el.id !== 'chart-' + name;
        });
        renderCharts();
      }

      function setChartPeriod(p) {
        chartPeriod = p;
        document.querySelectorAll('.cf-btn').forEach(b => b.classList.toggle('active', b.dataset.cp === p));
        fetchAnalytics();
      }

      async function fetchAnalytics() {
        try {
          var res = await fetch('/api/stats?period=' + currentPeriod + '&ap=' + chartPeriod);
          if (res.status === 401) { location.reload(); return; }
          var data = await res.json();
          statsData.analytics = data.analytics;
          renderCharts();
        } catch (e) { console.error('Analytics fetch error:', e); }
      }

      function renderCharts() {
        var a = statsData.analytics;
        if (!a) return;
        renderSalesChart(a.salesByPeriod);
        renderVisitsChart(a.visitsByPeriod);
        renderConversionChart(a.combined);
      }

      function fmtDate(d) {
        // Labels already formatted from server, just return
        if (typeof d === 'string' && (d.includes(':') || d.includes('.') || d.includes('-') || d.length <= 6)) return d;
        return new Date(d).toLocaleDateString('uz', { day: '2-digit', month: 'short' });
      }

      function buildLineChart(container, datasets, opts) {
        var el = document.getElementById(container);
        if (!el) return;

        var allDates = datasets[0].data.map(d => d.date);
        if (!allDates.length) { el.innerHTML = '<div class="empty">Ma\'lumot yo\'q</div>'; return; }

        var allValues = [];
        datasets.forEach(ds => ds.data.forEach(d => allValues.push(d.value)));
        var maxVal = Math.max(...allValues, 1);

        // Use actual pixel dimensions
        var rect = el.getBoundingClientRect();
        var W = Math.max(rect.width - 48, 300);
        var H = Math.max(rect.height - 20, 260);
        var padL = 52, padR = 16, padT = 16, padB = 36;
        var chartW = W - padL - padR;
        var chartH = H - padT - padB;

        var points = datasets.map(ds => {
          return ds.data.map((d, i) => {
            var x = padL + (allDates.length === 1 ? chartW / 2 : (i / (allDates.length - 1)) * chartW);
            var y = padT + chartH - (d.value / maxVal) * chartH;
            return { x: x, y: y, value: d.value };
          });
        });

        var svg = '';

        // Grid lines + Y labels
        var gridCount = 5;
        for (var g = 0; g <= gridCount; g++) {
          var gy = padT + (g / gridCount) * chartH;
          var gv = Math.round(maxVal - (g / gridCount) * maxVal);
          svg += '<line x1="' + padL + '" y1="' + gy + '" x2="' + (W - padR) + '" y2="' + gy + '" stroke="rgba(30,30,65,0.4)" stroke-dasharray="4,4"/>';
          var label = opts.formatValue ? opts.formatValue(gv) : gv;
          svg += '<text x="' + (padL - 8) + '" y="' + (gy + 4) + '" text-anchor="end" fill="#5a5a78" font-size="11" font-family="Inter,sans-serif">' + label + '</text>';
        }

        // X date labels
        var maxLabels = Math.min(allDates.length, Math.floor(chartW / 60));
        var step = Math.max(1, Math.ceil(allDates.length / maxLabels));
        for (var di = 0; di < allDates.length; di += step) {
          var dx = padL + (allDates.length === 1 ? chartW / 2 : (di / (allDates.length - 1)) * chartW);
          svg += '<text x="' + dx + '" y="' + (H - 8) + '" text-anchor="middle" fill="#5a5a78" font-size="11" font-family="Inter,sans-serif">' + fmtDate(allDates[di]) + '</text>';
        }

        // Area fills + lines + dots
        points.forEach((pts, si) => {
          var ds = datasets[si];
          if (pts.length < 2) {
            svg += '<circle cx="' + pts[0].x + '" cy="' + pts[0].y + '" r="5" fill="' + ds.color + '"/>';
            return;
          }

          // Smooth curve (catmull-rom to bezier)
          var lineD = 'M' + pts[0].x + ',' + pts[0].y;
          for (var k = 0; k < pts.length - 1; k++) {
            var p0 = pts[Math.max(k - 1, 0)];
            var p1 = pts[k];
            var p2 = pts[k + 1];
            var p3 = pts[Math.min(k + 2, pts.length - 1)];
            var cp1x = p1.x + (p2.x - p0.x) / 6;
            var cp1y = p1.y + (p2.y - p0.y) / 6;
            var cp2x = p2.x - (p3.x - p1.x) / 6;
            var cp2y = p2.y - (p3.y - p1.y) / 6;
            lineD += ' C' + cp1x + ',' + cp1y + ' ' + cp2x + ',' + cp2y + ' ' + p2.x + ',' + p2.y;
          }

          // Gradient area
          var gradId = container + '-grad-' + si;
          svg += '<defs><linearGradient id="' + gradId + '" x1="0" y1="0" x2="0" y2="1">';
          svg += '<stop offset="0%" stop-color="' + ds.color + '" stop-opacity="0.2"/>';
          svg += '<stop offset="100%" stop-color="' + ds.color + '" stop-opacity="0.01"/>';
          svg += '</linearGradient></defs>';

          var areaD = lineD + ' L' + pts[pts.length - 1].x + ',' + (padT + chartH) + ' L' + pts[0].x + ',' + (padT + chartH) + ' Z';
          svg += '<path d="' + areaD + '" fill="url(#' + gradId + ')"/>';
          svg += '<path d="' + lineD + '" fill="none" stroke="' + ds.color + '" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>';

          // Dots
          pts.forEach(p => {
            svg += '<circle cx="' + p.x + '" cy="' + p.y + '" r="3.5" fill="' + ds.color + '" stroke="#101025" stroke-width="2"/>';
          });
        });

        // Hover columns (invisible, for tooltip)
        allDates.forEach((date, i) => {
          var cx = padL + (allDates.length === 1 ? chartW / 2 : (i / (allDates.length - 1)) * chartW);
          var colW = allDates.length === 1 ? chartW : chartW / Math.max(allDates.length - 1, 1);
          var vals = datasets.map(function(ds) {
            return { label: ds.label, color: ds.color, value: ds.data[i].value };
          });
          // Vertical hover line
          svg += '<line x1="' + cx + '" y1="' + padT + '" x2="' + cx + '" y2="' + (padT + chartH) + '" stroke="rgba(124,58,237,0.3)" stroke-width="1" opacity="0" class="hover-line" data-idx="' + i + '"/>';
          svg += '<rect x="' + (cx - colW / 2) + '" y="0" width="' + colW + '" height="' + H + '" fill="transparent" class="chart-hover-col" data-idx="' + i + '" data-date="' + date + '" data-vals=\'' + JSON.stringify(vals).replace(/'/g, '&#39;') + '\' style="cursor:crosshair"/>';
        });

        el.innerHTML = '<div style="position:relative"><svg width="' + W + '" height="' + H + '" style="display:block">' +
          svg + '</svg><div class="chart-tooltip" id="tooltip-' + container + '"></div></div>';

        // Tooltip + hover line events
        el.querySelectorAll('.chart-hover-col').forEach(col => {
          col.addEventListener('mouseenter', function() {
            var tt = document.getElementById('tooltip-' + container);
            var vals = JSON.parse(this.dataset.vals.replace(/&#39;/g, "'"));
            var html = '<div class="ct-date">' + fmtDate(this.dataset.date) + '</div>';
            vals.forEach(v => {
              html += '<div class="ct-row"><span class="ct-dot" style="background:' + v.color + '"></span>' + v.label + ': <b>' + (opts.formatValue ? opts.formatValue(v.value) : v.value) + '</b></div>';
            });
            tt.innerHTML = html;
            tt.classList.add('visible');
            // Show hover line
            var line = el.querySelector('.hover-line[data-idx="' + this.dataset.idx + '"]');
            if (line) line.setAttribute('opacity', '1');
          });
          col.addEventListener('mousemove', function(e) {
            var tt = document.getElementById('tooltip-' + container);
            var r = el.getBoundingClientRect();
            var x = e.clientX - r.left + 16;
            var y = e.clientY - r.top - 16;
            if (x + 160 > r.width) x = e.clientX - r.left - 170;
            if (y < 0) y = 10;
            tt.style.left = x + 'px';
            tt.style.top = y + 'px';
          });
          col.addEventListener('mouseleave', function() {
            document.getElementById('tooltip-' + container).classList.remove('visible');
            var line = el.querySelector('.hover-line[data-idx="' + this.dataset.idx + '"]');
            if (line) line.setAttribute('opacity', '0');
          });
        });
      }

      function renderSalesChart(data) {
        if (!data) return;
        buildLineChart('salesChart', [
          { label: 'Daromad', color: '#10b981', data: data.map(d => ({ date: d.label, value: d.revenue })) },
        ], { formatValue: v => fmtMoney(v) + " so'm" });
      }

      function renderVisitsChart(data) {
        if (!data) return;
        buildLineChart('visitsChart', [
          { label: 'Real userlar', color: '#10b981', data: data.map(d => ({ date: d.label, value: d.humans })) },
          { label: 'Botlar', color: '#f59e0b', data: data.map(d => ({ date: d.label, value: d.bots })) },
        ], {});
      }

      function renderConversionChart(data) {
        if (!data) return;
        buildLineChart('conversionChart', [
          { label: 'Tashriflar', color: '#a78bfa', data: data.map(d => ({ date: d.label, value: d.visits })) },
          { label: 'Sotuvlar', color: '#10b981', data: data.map(d => ({ date: d.label, value: d.orders })) },
        ], {});
      }

      async function deleteOrder(id) {
        if (!confirm("Bu buyurtmani o'chirishni xohlaysizmi?")) return;
        var row = document.getElementById('order-row-' + id);
        if (row) row.style.opacity = '0.3';
        try {
          var res = await fetch('/api/stats', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'delete_order', id: id }),
          });
          if (res.ok) {
            if (row) row.remove();
            fetchSales();
          } else {
            if (row) row.style.opacity = '1';
            alert("O'chirishda xatolik");
          }
        } catch {
          if (row) row.style.opacity = '1';
          alert("Server xatoligi");
        }
      }

      async function exportCSV() {
        var btn = document.querySelector('.tb-btn');
        if (btn) { btn.disabled = true; btn.style.opacity = '0.5'; }
        try {
          var res = await fetch('/api/stats?period=' + currentPeriod + '&export=csv');
          if (res.status === 401) { location.reload(); return; }
          var visits = await res.json();
          var header = 'Turi,Sahifa,Mamlakat,IP,Vaqt,Davomiylik,Sessiya,Bot nomi\n';
          var rows = visits.map(function(v) {
            return [v.isBot ? 'Bot' : 'Odam', v.path, v.country, v.ip, v.timestamp, v.duration + 's', v.sessionId || '', v.botName || ''].map(function(c) { return '"' + String(c).replace(/"/g, '""') + '"'; }).join(',');
          }).join('\n');
          var blob = new Blob([header + rows], { type: 'text/csv;charset=utf-8;' });
          var a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'starsjoy-analytics-' + currentPeriod + '.csv';
          a.click();
        } catch (e) { console.error('Export error:', e); }
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
      }

      async function changePassword() {
        const msg = document.getElementById('passMsg');
        const current = document.getElementById('currentPass').value;
        const newP = document.getElementById('newPass').value;
        const confirm = document.getElementById('confirmPass').value;
        if (newP !== confirm) {
          msg.className = 'form-msg err'; msg.textContent = 'Parollar mos kelmaydi'; return;
        }
        try {
          const res = await fetch('/api/stats', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'change_password', current: current, newPass: newP }),
          });
          const data = await res.json();
          if (data.ok) {
            msg.className = 'form-msg ok'; msg.textContent = 'Parol o\'zgartirildi';
            document.getElementById('currentPass').value = '';
            document.getElementById('newPass').value = '';
            document.getElementById('confirmPass').value = '';
          } else {
            msg.className = 'form-msg err'; msg.textContent = data.error || 'Xatolik';
          }
        } catch {
          msg.className = 'form-msg err'; msg.textContent = 'Server xatoligi';
        }
      }

      // Detect horizontal scroll on panel-body elements for fade hint
      function checkScrollHints() {
        document.querySelectorAll('.panel-body').forEach(el => {
          el.classList.toggle('has-scroll', el.scrollWidth > el.clientWidth + 4);
          el.addEventListener('scroll', function() {
            this.classList.toggle('has-scroll', this.scrollLeft < this.scrollWidth - this.clientWidth - 4);
          }, { passive: true });
        });
      }

      var _origRenderAll = renderAll;
      renderAll = function() { _origRenderAll(); setTimeout(checkScrollHints, 50); };

      showSection('overview');
      fetchStats();
      setInterval(fetchStats, 30000);
    </script>
  )}
</body>
</html>
