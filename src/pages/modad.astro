  <style is:global>
    :root {
      --bg-0: #06060e;
      --bg-1: #0b0b19;
      --bg-2: #101025;
      --bg-3: #161635;
      --bg-4: #1c1c42;
      --border: #1a1a3a;
      --border-light: #222250;
      --text-0: #ffffff;
      --text-1: #c8c8e4;
      --text-2: #8888a8;
      --text-3: #5a5a78;
      --text-4: #3e3e58;
      --accent: #7C3AED;
      --accent-light: #a78bfa;
      --accent-dark: #5b21b6;
      --accent-bg: rgba(124, 58, 237, 0.10);
      --accent-bg-strong: rgba(124, 58, 237, 0.18);
      --green: #10b981;
      --green-bg: rgba(16, 185, 129, 0.12);
      --orange: #f59e0b;
      --orange-bg: rgba(245, 158, 11, 0.12);
      --red: #ef4444;
      --blue: #3b82f6;
      --radius: 12px;
      --radius-sm: 8px;
      --radius-pill: 100px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg-0); color: var(--text-1); min-height: 100vh; -webkit-font-smoothing: antialiased; }

    /* ───── LOGIN ───── */
    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 24px; background: var(--bg-0); }
    .login-box { background: var(--bg-2); border: 1px solid var(--border); border-radius: 20px; padding: 48px 40px; width: 100%; max-width: 400px; text-align: center; box-shadow: 0 24px 80px rgba(0,0,0,0.4); }
    .login-brand { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 28px; }
    .login-logo { width: 44px; height: 44px; background: linear-gradient(135deg, var(--accent), var(--blue)); border-radius: 12px; display: flex; align-items: center; justify-content: center; }
    .login-brand-text { font-size: 1.2rem; font-weight: 800; color: var(--text-0); letter-spacing: -0.3px; }
    .login-box h1 { font-size: 1.25rem; font-weight: 700; margin-bottom: 6px; color: var(--text-0); letter-spacing: -0.3px; }
    .login-box p { font-size: 0.82rem; color: var(--text-3); margin-bottom: 28px; }
    .login-box input { width: 100%; padding: 13px 16px; background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-1); font-size: 0.9rem; font-family: inherit; outline: none; margin-bottom: 14px; transition: border-color 0.2s; }
    .login-box input:focus { border-color: var(--accent); }
    .login-box button { width: 100%; padding: 13px; background: var(--accent); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: background 0.2s; }
    .login-box button:hover { background: var(--accent-dark); }
    .login-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: var(--red); font-size: 0.82rem; padding: 10px 14px; border-radius: var(--radius-sm); margin-bottom: 14px; }

    /* ───── APP LAYOUT ───── */
    .app { display: flex; min-height: 100vh; }

    /* ───── SIDEBAR ───── */
    .sidebar {
      width: 252px; background: var(--bg-1); border-right: 1px solid var(--border);
      display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .sb-header { display: flex; align-items: center; gap: 12px; padding: 24px 22px 28px; }
    .sb-logo {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--accent), var(--blue));
      border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
      box-shadow: 0 4px 16px rgba(124, 58, 237, 0.3);
    }
    .sb-brand-name { display: block; font-size: 1.05rem; font-weight: 800; color: var(--text-0); letter-spacing: -0.3px; line-height: 1.2; }
    .sb-brand-sub { display: block; font-size: 0.68rem; font-weight: 500; color: var(--text-3); text-transform: uppercase; letter-spacing: 1px; }

    .sb-label { padding: 0 22px; margin-bottom: 6px; font-size: 0.65rem; font-weight: 600; color: var(--text-4); text-transform: uppercase; letter-spacing: 1.2px; }

    #sidebar-nav { flex: 1; padding: 0 10px; }
    #sidebar-nav a {
      display: flex; align-items: center; gap: 12px; padding: 11px 14px; margin-bottom: 2px;
      border-radius: var(--radius-sm); color: var(--text-2); font-size: 0.85rem; font-weight: 500;
      cursor: pointer; text-decoration: none; transition: all 0.2s; position: relative;
    }
    #sidebar-nav a:hover { background: var(--bg-3); color: var(--text-1); }
    #sidebar-nav a .sb-icon {
      width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;
      border-radius: 8px; background: var(--bg-3); transition: all 0.2s; flex-shrink: 0;
    }
    #sidebar-nav a:hover .sb-icon { background: var(--bg-4); }
    #sidebar-nav a.active {
      background: var(--accent-bg-strong); color: var(--accent-light);
    }
    #sidebar-nav a.active .sb-icon {
      background: var(--accent); color: #fff; box-shadow: 0 4px 12px rgba(124,58,237,0.35);
    }
    #sidebar-nav a.active::before {
      content: ''; position: absolute; left: -10px; top: 50%; transform: translateY(-50%);
      width: 4px; height: 24px; background: var(--accent); border-radius: 0 4px 4px 0;
    }

    .sb-bottom { padding: 16px 22px; border-top: 1px solid var(--border); }
    .sb-logout {
      display: flex; align-items: center; gap: 10px; color: var(--text-3); font-size: 0.82rem;
      font-weight: 500; cursor: pointer; text-decoration: none; padding: 8px 0; transition: color 0.2s;
    }
    .sb-logout:hover { color: var(--red); }

    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 90; backdrop-filter: blur(4px); }

    /* ───── MAIN ───── */
    .main { flex: 1; margin-left: 252px; display: flex; flex-direction: column; min-height: 100vh; background: var(--bg-0); }

    /* ───── TOPBAR ───── */
    .topbar {
      display: flex; align-items: center; gap: 16px; padding: 18px 28px;
      border-bottom: 1px solid var(--border); background: rgba(6,6,14,0.85);
      backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 50;
    }
    .menu-btn {
      display: none; background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 8px 10px; color: var(--text-1); cursor: pointer;
    }
    .tb-filters { display: flex; gap: 2px; background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 3px; }
    .tb-filters button {
      padding: 7px 18px; border: none; border-radius: 6px; background: transparent;
      color: var(--text-3); font-size: 0.8rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s;
    }
    .tb-filters button.active { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(124,58,237,0.3); }
    .tb-filters button:hover:not(.active) { color: var(--text-1); }

    .tb-right { display: flex; align-items: center; gap: 14px; margin-left: auto; }
    .tb-btn {
      display: flex; align-items: center; gap: 7px; padding: 8px 16px; border: 1px solid var(--border);
      border-radius: var(--radius-sm); background: var(--bg-2); color: var(--text-2); font-size: 0.8rem;
      font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s;
    }
    .tb-btn:hover { border-color: var(--accent); color: var(--accent-light); background: var(--accent-bg); }

    .tb-live { display: flex; align-items: center; gap: 6px; }
    .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px rgba(16,185,129,0.5); animation: pulse 2s ease-in-out infinite; }
    .live-text { font-size: 0.72rem; font-weight: 600; color: var(--green); text-transform: uppercase; letter-spacing: 0.5px; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

    /* ───── CONTENT ───── */
    .content { padding: 28px; flex: 1; }

    .loading-state {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 80px; gap: 16px; color: var(--text-3); font-size: 0.88rem;
    }
    .loading-spinner {
      width: 28px; height: 28px; border: 3px solid var(--border); border-top-color: var(--accent);
      border-radius: 50%; animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ───── STAT CARDS ───── */
    .stat-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-bottom: 28px; }
    .stat-card {
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 24px; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .stat-card.highlighted { border-color: rgba(124,58,237,0.35); box-shadow: 0 0 0 1px rgba(124,58,237,0.1), 0 8px 32px rgba(124,58,237,0.08); }
    .stat-card .sc-label { font-size: 0.7rem; font-weight: 600; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 10px; }
    .stat-card .sc-value { font-size: 2.4rem; font-weight: 900; color: var(--text-0); letter-spacing: -1px; line-height: 1; margin-bottom: 10px; }
    .stat-card .sc-sub { display: flex; align-items: center; gap: 14px; font-size: 0.76rem; font-weight: 500; color: var(--text-3); }
    .stat-card .sc-sub .sc-green { color: var(--green); }
    .stat-card .sc-sub .sc-orange { color: var(--orange); }
    .sc-divider { width: 1px; height: 12px; background: var(--border); }

    /* ───── PANELS ───── */
    .panel {
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius);
      overflow: hidden; margin-bottom: 24px;
    }
    .panel-header { padding: 16px 20px; }
    .panel-header h2 { font-size: 0.82rem; font-weight: 600; color: var(--text-2); letter-spacing: -0.1px; }
    .panel-body { overflow-x: auto; padding: 14px 0 6px; }
    .panel-pad { padding: 16px 20px !important; }

    /* ───── TABLES (Notion/Linear style) ───── */
    table { width: 100%; border-collapse: collapse; }
    th {
      background: transparent; color: var(--text-3); font-weight: 500; font-size: 0.72rem;
      text-transform: uppercase; letter-spacing: 0.6px; text-align: left;
      padding: 0 14px 10px; white-space: nowrap;
    }
    th:first-child { padding-left: 20px; }
    th:last-child { padding-right: 20px; }
    thead tr { border-bottom: 1px solid var(--border); }
    td {
      padding: 0 14px; color: var(--text-1); white-space: nowrap;
      font-size: 0.82rem; vertical-align: middle; height: 44px;
      border-bottom: 1px solid rgba(26, 26, 58, 0.4);
    }
    td:first-child { padding-left: 20px; }
    td:last-child { padding-right: 20px; }
    tr:last-child td { border-bottom: none; }
    tbody tr { transition: background 0.1s; }
    tbody tr:nth-child(even) { background: rgba(12, 12, 30, 0.3); }
    tbody tr:hover { background: rgba(124, 58, 237, 0.05); }
    .td-num { font-weight: 700; color: var(--text-0); font-variant-numeric: tabular-nums; }

    /* Path chip — monospace, subtle bg */
    .path-chip {
      display: inline-block; padding: 3px 8px;
      background: rgba(20, 20, 50, 0.6); border: 1px solid rgba(30, 30, 65, 0.6);
      border-radius: 5px; font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', monospace;
      font-size: 0.76rem; color: var(--text-2); max-width: 260px; overflow: hidden;
      text-overflow: ellipsis; white-space: nowrap; vertical-align: middle;
    }

    /* Country */
    .country-cell { display: inline-flex; align-items: center; gap: 6px; }
    .country-cell .flag { font-size: 0.95rem; line-height: 1; }
    .country-cell .name { font-size: 0.8rem; font-weight: 600; color: var(--text-1); }

    /* Duration */
    .dur { font-variant-numeric: tabular-nums; font-weight: 500; color: var(--text-2); font-size: 0.8rem; }

    /* Session mono */
    .sess-id { font-family: 'SF Mono', 'Cascadia Code', monospace; font-size: 0.7rem; color: var(--text-4); letter-spacing: 0.3px; }

    /* User-Agent chip */
    .ua-chip {
      display: inline-block; padding: 2px 7px; background: rgba(16, 16, 40, 0.4);
      border-radius: 4px; font-family: 'SF Mono', 'Cascadia Code', monospace;
      font-size: 0.68rem; color: var(--text-3); max-width: 220px; overflow: hidden;
      text-overflow: ellipsis; white-space: nowrap; cursor: help;
    }

    /* ───── PILL BADGES ───── */
    .pill {
      display: inline-flex; align-items: center; justify-content: center; gap: 4px;
      padding: 4px 10px; border-radius: var(--radius-pill); font-size: 0.7rem; font-weight: 600;
      line-height: 1; white-space: nowrap;
    }
    .pill-human { background: rgba(16, 185, 129, 0.1); color: #34d399; }
    .pill-rank { background: var(--accent-bg); color: var(--accent-light); font-weight: 800; min-width: 26px; }

    /* Bot pills — unique color per bot */
    .pill-bot-orange { background: rgba(245, 158, 11, 0.1); color: #fbbf24; }
    .pill-bot-red { background: rgba(239, 68, 68, 0.1); color: #f87171; }
    .pill-bot-blue { background: rgba(59, 130, 246, 0.1); color: #60a5fa; }
    .pill-bot-cyan { background: rgba(6, 182, 212, 0.1); color: #22d3ee; }
    .pill-bot-purple { background: rgba(168, 85, 247, 0.1); color: #c084fc; }
    .pill-bot-pink { background: rgba(236, 72, 153, 0.1); color: #f472b6; }
    .pill-bot-teal { background: rgba(20, 184, 166, 0.1); color: #2dd4bf; }
    .pill-bot-lime { background: rgba(132, 204, 22, 0.1); color: #a3e635; }

    .empty { text-align: center; padding: 48px 24px; color: var(--text-4); font-size: 0.85rem; }

    /* ───── SALES ───── */
    .sales-filter {
      display: flex; align-items: center; gap: 14px; margin-bottom: 18px; flex-wrap: wrap;
    }
    .sf-tabs {
      display: flex; gap: 2px; background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 3px;
    }
    .sf-tab {
      padding: 7px 16px; border: none; border-radius: 6px; background: transparent;
      color: var(--text-3); font-size: 0.8rem; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: all 0.2s; white-space: nowrap;
    }
    .sf-tab.active { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(124,58,237,0.3); }
    .sf-tab:hover:not(.active) { color: var(--text-1); }
    .sf-date {
      display: flex; align-items: center; gap: 8px;
    }
    .sf-dash { color: var(--text-4); font-size: 0.8rem; }
    .sf-date input[type="date"] {
      padding: 7px 12px; background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text-1); font-size: 0.8rem;
      font-family: inherit; outline: none; transition: border-color 0.2s;
      color-scheme: dark;
    }
    .sf-date input[type="date"]:focus { border-color: var(--accent); }
    .sales-cards { grid-template-columns: repeat(4, 1fr); }
    .pill-stars { background: rgba(250, 204, 21, 0.1); color: #facc15; }
    .pill-gift { background: rgba(52, 211, 153, 0.1); color: #34d399; }
    .pill-premium { background: rgba(168, 85, 247, 0.1); color: #c084fc; }
    .sc-revenue { font-size: 0.82rem; font-weight: 700; color: var(--green); }

    /* Daily revenue bars */
    .dr-row { display: flex; align-items: center; gap: 10px; padding: 6px 0; }
    .dr-date { width: 70px; font-size: 0.76rem; font-weight: 600; color: var(--text-3); flex-shrink: 0; }
    .dr-bar-bg { flex: 1; height: 24px; background: var(--bg-3); border-radius: 6px; overflow: hidden; position: relative; }
    .dr-bar {
      height: 100%; border-radius: 6px; min-width: 4px;
      background: linear-gradient(90deg, var(--green), #34d399);
      transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .dr-info { width: 100px; text-align: right; font-size: 0.74rem; flex-shrink: 0; }
    .del-btn {
      background: none; border: 1px solid transparent; color: var(--text-4); font-size: 1.1rem;
      cursor: pointer; padding: 2px 8px; border-radius: 4px; line-height: 1; transition: all 0.15s;
    }
    .del-btn:hover { color: var(--red); background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.2); }
    .dr-amount { font-weight: 700; color: var(--text-0); }
    .dr-orders { color: var(--text-3); margin-left: 4px; }

    /* Row filters */
    .row-filters { display: flex; gap: 2px; background: var(--bg-3); border-radius: 6px; padding: 2px; }
    .rf-btn {
      padding: 4px 10px; border: none; border-radius: 4px; background: transparent;
      color: var(--text-3); font-size: 0.72rem; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: all 0.15s;
    }
    .rf-btn.active { background: var(--accent); color: #fff; }
    .rf-btn:hover:not(.active) { color: var(--text-1); }

    /* ───── COUNTRY CHART ───── */
    .c-row { display: flex; align-items: center; gap: 12px; padding: 7px 0; }
    .c-flag { font-size: 1rem; width: 24px; text-align: center; }
    .c-code { width: 32px; font-size: 0.78rem; font-weight: 700; color: var(--accent-light); }
    .c-bar-bg { flex: 1; height: 26px; background: var(--bg-3); border-radius: 6px; overflow: hidden; position: relative; }
    .c-bar {
      height: 100%; border-radius: 6px; min-width: 4px;
      background: linear-gradient(90deg, var(--accent), var(--blue));
      transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .c-val { width: 40px; text-align: right; font-size: 0.78rem; font-weight: 700; color: var(--text-1); }

    /* ───── PROFIT ───── */
    .profit-filter {
      display: flex; gap: 2px; background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 3px; margin-bottom: 20px; width: fit-content;
    }
    .pf-btn {
      padding: 7px 16px; border: none; border-radius: 6px; background: transparent;
      color: var(--text-3); font-size: 0.78rem; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: all 0.15s; white-space: nowrap;
    }
    .pf-btn.active { background: var(--green); color: #fff; box-shadow: 0 2px 8px rgba(16,185,129,0.3); }
    .pf-btn:hover:not(.active) { color: var(--text-1); }

    .profit-cards { display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: 16px; margin-bottom: 20px; }
    .profit-card {
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 28px 24px; text-align: center;
    }
    .profit-main { border-color: rgba(16,185,129,0.3); background: rgba(16,185,129,0.04); }
    .pc-label { font-size: 0.72rem; font-weight: 600; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 12px; }
    .pc-value { font-size: 2.6rem; font-weight: 900; color: var(--green); letter-spacing: -1.5px; line-height: 1; }
    .pc-dim { color: var(--text-0); }
    .pc-sub { font-size: 0.78rem; color: var(--text-3); margin-top: 8px; font-weight: 500; }

    .profit-breakdown {
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 20px 24px; max-width: 500px;
    }
    .pb-header { font-size: 0.72rem; font-weight: 600; color: var(--text-4); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; }
    .pb-row {
      display: flex; align-items: center; gap: 12px; padding: 12px 0;
      border-bottom: 1px solid var(--border); font-size: 0.85rem;
    }
    .pb-row:last-child { border-bottom: none; }
    .pb-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .pb-name { font-weight: 600; color: var(--text-1); width: 70px; }
    .pb-revenue { color: var(--text-2); font-weight: 500; }
    .pb-arrow { color: var(--text-4); font-size: 0.75rem; }
    .pb-profit { color: var(--green); font-weight: 700; }

    /* ───── ANALYTICS TABS ───── */
    .an-tabs {
      display: flex; gap: 8px; margin-bottom: 16px;
    }
    .an-tab {
      display: flex; align-items: center; gap: 8px; padding: 12px 20px;
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius);
      color: var(--text-2); font-size: 0.85rem; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: all 0.2s; flex: 1; justify-content: center;
    }
    .an-tab:hover { border-color: var(--border-light); color: var(--text-1); }
    .an-tab.active {
      background: var(--accent-bg-strong); border-color: var(--accent);
      color: var(--accent-light); box-shadow: 0 0 0 1px rgba(124,58,237,0.15);
    }
    .an-tab-icon { display: flex; align-items: center; }
    .an-period {
      display: flex; gap: 2px; background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 3px; margin-bottom: 16px; width: fit-content;
    }
    .cf-btn {
      padding: 7px 16px; border: none; border-radius: 6px; background: transparent;
      color: var(--text-3); font-size: 0.78rem; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: all 0.15s; white-space: nowrap;
    }
    .cf-btn.active { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(124,58,237,0.3); }
    .cf-btn:hover:not(.active) { color: var(--text-1); }

    /* ───── CHARTS ───── */
    .chart-panel {
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius);
      overflow: hidden;
    }
    .chart-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 24px; flex-wrap: wrap; gap: 10px;
    }
    .chart-header h2 { font-size: 0.9rem; font-weight: 700; color: var(--text-0); letter-spacing: -0.2px; }
    .chart-body-lg { padding: 12px 24px 24px; height: 340px; overflow-x: auto; overflow-y: hidden; }
    .chart-body-lg svg { display: block; overflow: visible; }
    .chart-legend {
      display: flex; gap: 16px; flex-wrap: wrap;
    }
    .cl-item { display: flex; align-items: center; gap: 6px; font-size: 0.76rem; color: var(--text-2); font-weight: 500; }
    .cl-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    /* Tooltip */
    .chart-tooltip {
      position: absolute; background: var(--bg-1); border: 1px solid var(--border-light);
      border-radius: 10px; padding: 12px 16px; font-size: 0.8rem; color: var(--text-1);
      pointer-events: none; z-index: 10; white-space: nowrap;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5); opacity: 0; transition: opacity 0.15s;
    }
    .chart-tooltip.visible { opacity: 1; }
    .ct-date { font-weight: 700; color: var(--text-0); margin-bottom: 6px; font-size: 0.82rem; }
    .ct-row { display: flex; align-items: center; gap: 6px; margin-top: 3px; }
    .ct-dot { width: 7px; height: 7px; border-radius: 50%; }

    /* ───── GRIDS ───── */
    .grid-2 { display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px; }
    .grid-2 .panel { margin-bottom: 0; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
    .grid-3 .panel { margin-bottom: 0; }

    /* ───── SETTINGS ───── */
