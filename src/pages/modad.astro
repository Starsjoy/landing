      function fmtDate(d) {
        // Labels already formatted from server, just return
        if (typeof d === 'string' && (d.includes(':') || d.includes('.') || d.includes('-') || d.length <= 6)) return d;
        return new Date(d).toLocaleDateString('uz', { day: '2-digit', month: 'short' });
      }

      function buildLineChart(container, datasets, opts) {
        var el = document.getElementById(container);
        if (!el) return;

        var allDates = datasets[0].data.map(d => d.date);
        if (!allDates.length) { el.innerHTML = '<div class="empty">Ma\'lumot yo\'q</div>'; return; }

        var allValues = [];
        datasets.forEach(ds => ds.data.forEach(d => allValues.push(d.value)));
        var maxVal = Math.max(...allValues, 1);

        // Use actual pixel dimensions
        var rect = el.getBoundingClientRect();
        var W = Math.max(rect.width - 48, 300);
        var H = Math.max(rect.height - 20, 260);
        var padL = 52, padR = 16, padT = 16, padB = 36;
        var chartW = W - padL - padR;
        var chartH = H - padT - padB;

        var points = datasets.map(ds => {
          return ds.data.map((d, i) => {
            var x = padL + (allDates.length === 1 ? chartW / 2 : (i / (allDates.length - 1)) * chartW);
            var y = padT + chartH - (d.value / maxVal) * chartH;
            return { x: x, y: y, value: d.value };
          });
        });

        var svg = '';

        // Grid lines + Y labels
        var gridCount = 5;
        for (var g = 0; g <= gridCount; g++) {
          var gy = padT + (g / gridCount) * chartH;
          var gv = Math.round(maxVal - (g / gridCount) * maxVal);
          svg += '<line x1="' + padL + '" y1="' + gy + '" x2="' + (W - padR) + '" y2="' + gy + '" stroke="rgba(30,30,65,0.4)" stroke-dasharray="4,4"/>';
          var label = opts.formatValue ? opts.formatValue(gv) : gv;
          svg += '<text x="' + (padL - 8) + '" y="' + (gy + 4) + '" text-anchor="end" fill="#5a5a78" font-size="11" font-family="Inter,sans-serif">' + label + '</text>';
        }

        // X date labels
        var maxLabels = Math.min(allDates.length, Math.floor(chartW / 60));
        var step = Math.max(1, Math.ceil(allDates.length / maxLabels));
        for (var di = 0; di < allDates.length; di += step) {
          var dx = padL + (allDates.length === 1 ? chartW / 2 : (di / (allDates.length - 1)) * chartW);
          svg += '<text x="' + dx + '" y="' + (H - 8) + '" text-anchor="middle" fill="#5a5a78" font-size="11" font-family="Inter,sans-serif">' + fmtDate(allDates[di]) + '</text>';
        }

        // Area fills + lines + dots
        points.forEach((pts, si) => {
          var ds = datasets[si];
          if (pts.length < 2) {
            svg += '<circle cx="' + pts[0].x + '" cy="' + pts[0].y + '" r="5" fill="' + ds.color + '"/>';
            return;
          }

          // Smooth curve (catmull-rom to bezier)
          var lineD = 'M' + pts[0].x + ',' + pts[0].y;
          for (var k = 0; k < pts.length - 1; k++) {
            var p0 = pts[Math.max(k - 1, 0)];
            var p1 = pts[k];
            var p2 = pts[k + 1];
            var p3 = pts[Math.min(k + 2, pts.length - 1)];
            var cp1x = p1.x + (p2.x - p0.x) / 6;
            var cp1y = p1.y + (p2.y - p0.y) / 6;
            var cp2x = p2.x - (p3.x - p1.x) / 6;
            var cp2y = p2.y - (p3.y - p1.y) / 6;
            lineD += ' C' + cp1x + ',' + cp1y + ' ' + cp2x + ',' + cp2y + ' ' + p2.x + ',' + p2.y;
          }

          // Gradient area
          var gradId = container + '-grad-' + si;
          svg += '<defs><linearGradient id="' + gradId + '" x1="0" y1="0" x2="0" y2="1">';
          svg += '<stop offset="0%" stop-color="' + ds.color + '" stop-opacity="0.2"/>';
          svg += '<stop offset="100%" stop-color="' + ds.color + '" stop-opacity="0.01"/>';
          svg += '</linearGradient></defs>';

          var areaD = lineD + ' L' + pts[pts.length - 1].x + ',' + (padT + chartH) + ' L' + pts[0].x + ',' + (padT + chartH) + ' Z';
          svg += '<path d="' + areaD + '" fill="url(#' + gradId + ')"/>';
          svg += '<path d="' + lineD + '" fill="none" stroke="' + ds.color + '" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>';

          // Dots
          pts.forEach(p => {
            svg += '<circle cx="' + p.x + '" cy="' + p.y + '" r="3.5" fill="' + ds.color + '" stroke="#101025" stroke-width="2"/>';
          });
        });

        // Hover columns (invisible, for tooltip)
        allDates.forEach((date, i) => {
          var cx = padL + (allDates.length === 1 ? chartW / 2 : (i / (allDates.length - 1)) * chartW);
          var colW = allDates.length === 1 ? chartW : chartW / Math.max(allDates.length - 1, 1);
          var vals = datasets.map(function(ds) {
            return { label: ds.label, color: ds.color, value: ds.data[i].value };
          });
          // Vertical hover line
          svg += '<line x1="' + cx + '" y1="' + padT + '" x2="' + cx + '" y2="' + (padT + chartH) + '" stroke="rgba(255,255,255,0.25)" stroke-width="1" opacity="0" class="hover-line" data-idx="' + i + '"/>';
          svg += '<rect x="' + (cx - colW / 2) + '" y="0" width="' + colW + '" height="' + H + '" fill="transparent" class="chart-hover-col" data-idx="' + i + '" data-date="' + date + '" data-vals=\'' + JSON.stringify(vals).replace(/'/g, '&#39;') + '\' style="cursor:crosshair"/>';
        });

        el.innerHTML = '<div style="position:relative"><svg width="' + W + '" height="' + H + '" style="display:block">' +
          svg + '</svg><div class="chart-tooltip" id="tooltip-' + container + '"></div></div>';

        // Tooltip + hover line events
        el.querySelectorAll('.chart-hover-col').forEach(col => {
          col.addEventListener('mouseenter', function() {
            var tt = document.getElementById('tooltip-' + container);
            var vals = JSON.parse(this.dataset.vals.replace(/&#39;/g, "'"));
            var html = '<div class="ct-date">' + fmtDate(this.dataset.date) + '</div>';
            vals.forEach(v => {
              html += '<div class="ct-row"><span class="ct-dot" style="background:' + v.color + '"></span>' + v.label + ': <b>' + (opts.formatValue ? opts.formatValue(v.value) : v.value) + '</b></div>';
            });
            tt.innerHTML = html;
            tt.classList.add('visible');
            // Show hover line
            var line = el.querySelector('.hover-line[data-idx="' + this.dataset.idx + '"]');
            if (line) line.setAttribute('opacity', '1');
          });
          col.addEventListener('mousemove', function(e) {
            var tt = document.getElementById('tooltip-' + container);
            var r = el.getBoundingClientRect();
            var x = e.clientX - r.left + 16;
            var y = e.clientY - r.top - 16;
            if (x + 160 > r.width) x = e.clientX - r.left - 170;
            if (y < 0) y = 10;
            tt.style.left = x + 'px';
            tt.style.top = y + 'px';
          });
          col.addEventListener('mouseleave', function() {
            document.getElementById('tooltip-' + container).classList.remove('visible');
            var line = el.querySelector('.hover-line[data-idx="' + this.dataset.idx + '"]');
            if (line) line.setAttribute('opacity', '0');
          });
        });
      }

