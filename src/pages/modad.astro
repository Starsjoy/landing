            </span>
            <span>Bot trafik</span>
          </a>
          <a data-section="users" onclick="showSection('users')">
            <span class="sb-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </span>
            <span>Real userlar</span>
          </a>
          <a data-section="pages" onclick="showSection('pages')">
            <span class="sb-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </span>
            <span>Sahifalar</span>
          </a>
          <a data-section="settings" onclick="showSection('settings')">
            <span class="sb-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            </span>
            <span>Sozlamalar</span>
          </a>
        </nav>

        <div class="sb-bottom">
          <a class="sb-logout" onclick="logout()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            <span>Chiqish</span>
          </a>
        </div>
      </aside>

      <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

      <!-- Main area -->
      <main class="main">
        <header class="topbar">
          <button class="menu-btn" id="menuBtn" onclick="toggleSidebar()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="15" y2="17"/></svg>
          </button>

          <div class="tb-filters" id="filters">
            <button data-period="today" class="active" onclick="setPeriod('today')">Bugun</button>
            <button data-period="week" onclick="setPeriod('week')">Hafta</button>
            <button data-period="month" onclick="setPeriod('month')">Oy</button>
          </div>

          <div class="tb-right">
            <button class="tb-btn" onclick="exportCSV()" title="CSV yuklab olish">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              <span>Export</span>
            </button>
            <div class="tb-live" id="refreshDot" title="Har 30s yangilanadi">
              <span class="live-dot"></span>
              <span class="live-text">Live</span>
            </div>
          </div>
        </header>

        <div class="content">
          <div id="loading" class="loading-state">
            <div class="loading-spinner"></div>
            <span>Yuklanmoqda...</span>
          </div>

          <!-- Overview -->
          <div id="section-overview" class="section-content" hidden>
            <div class="stat-cards" id="statCards"></div>
            <div class="panel">
              <div class="panel-header">
                <h2>So'nggi tashriflar</h2>
              </div>
              <div class="panel-body" id="recentTable"></div>
            </div>
          </div>

          <!-- Bots -->
          <div id="section-bots" class="section-content" hidden>
            <div class="panel">
              <div class="panel-header"><h2>Bot trafik</h2></div>
              <div class="panel-body" id="botTable"></div>
            </div>
          </div>

          <!-- Users -->
          <div id="section-users" class="section-content" hidden>
            <div class="grid-2">
              <div class="panel">
                <div class="panel-header"><h2>Real foydalanuvchilar</h2></div>
                <div class="panel-body" id="usersTable"></div>
              </div>
              <div class="panel">
                <div class="panel-header"><h2>Mamlakatlar</h2></div>
                <div class="panel-body panel-pad" id="countryChart"></div>
              </div>
            </div>
          </div>

          <!-- Pages -->
          <div id="section-pages" class="section-content" hidden>
            <div class="panel">
              <div class="panel-header"><h2>Sahifalar reytingi</h2></div>
              <div class="panel-body" id="pagesTable"></div>
            </div>
          </div>

          <!-- Settings -->
          <div id="section-settings" class="section-content" hidden>
            <div class="settings-grid">
              <div class="panel">
                <div class="panel-header"><h2>Parolni o'zgartirish</h2></div>
                <div class="panel-body panel-pad">
                  <div class="form-stack" id="passForm">
                    <input type="password" id="currentPass" placeholder="Joriy parol" />
                    <input type="password" id="newPass" placeholder="Yangi parol" />
                    <input type="password" id="confirmPass" placeholder="Yangi parolni tasdiqlang" />
                    <button class="form-btn" onclick="changePassword()">Saqlash</button>
                    <div class="form-msg" id="passMsg"></div>
                  </div>
                </div>
              </div>
              <div class="panel">
                <div class="panel-header"><h2>Ma'lumot</h2></div>
                <div class="panel-body panel-pad">
                  <div class="info-item"><span class="info-dot green"></span> Dashboard har 30 soniyada avtomatik yangilanadi</div>
                  <div class="info-item"><span class="info-dot purple"></span> Session — 30 daqiqa ichidagi barcha sahifa ko'rishlari bitta sessiya</div>
                  <div class="info-item"><span class="info-dot blue"></span> CSV export tanlangan davr uchun barcha ma'lumotlarni yuklab oladi</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  )}

  <style>
    :root {
      --bg-0: #06060e;
      --bg-1: #0b0b19;
      --bg-2: #101025;
      --bg-3: #161635;
      --bg-4: #1c1c42;
      --border: #1a1a3a;
      --border-light: #222250;
      --text-0: #ffffff;
      --text-1: #c8c8e4;
      --text-2: #8888a8;
      --text-3: #5a5a78;
      --text-4: #3e3e58;
      --accent: #7C3AED;
      --accent-light: #a78bfa;
      --accent-dark: #5b21b6;
      --accent-bg: rgba(124, 58, 237, 0.10);
      --accent-bg-strong: rgba(124, 58, 237, 0.18);
      --green: #10b981;
      --green-bg: rgba(16, 185, 129, 0.12);
      --orange: #f59e0b;
      --orange-bg: rgba(245, 158, 11, 0.12);
      --red: #ef4444;
      --blue: #3b82f6;
      --radius: 12px;
      --radius-sm: 8px;
      --radius-pill: 100px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg-0); color: var(--text-1); min-height: 100vh; -webkit-font-smoothing: antialiased; }

    /* ───── LOGIN ───── */
    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 24px; background: var(--bg-0); }
    .login-box { background: var(--bg-2); border: 1px solid var(--border); border-radius: 20px; padding: 48px 40px; width: 100%; max-width: 400px; text-align: center; box-shadow: 0 24px 80px rgba(0,0,0,0.4); }
    .login-brand { display: flex; align-items: center; justify-content: center; gap: 10px; margin-bottom: 28px; }
    .login-logo { width: 44px; height: 44px; background: linear-gradient(135deg, var(--accent), var(--blue)); border-radius: 12px; display: flex; align-items: center; justify-content: center; }
    .login-brand-text { font-size: 1.2rem; font-weight: 800; color: var(--text-0); letter-spacing: -0.3px; }
    .login-box h1 { font-size: 1.25rem; font-weight: 700; margin-bottom: 6px; color: var(--text-0); letter-spacing: -0.3px; }
    .login-box p { font-size: 0.82rem; color: var(--text-3); margin-bottom: 28px; }
    .login-box input { width: 100%; padding: 13px 16px; background: var(--bg-1); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text-1); font-size: 0.9rem; font-family: inherit; outline: none; margin-bottom: 14px; transition: border-color 0.2s; }
    .login-box input:focus { border-color: var(--accent); }
    .login-box button { width: 100%; padding: 13px; background: var(--accent); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 0.9rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: background 0.2s; }
    .login-box button:hover { background: var(--accent-dark); }
    .login-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: var(--red); font-size: 0.82rem; padding: 10px 14px; border-radius: var(--radius-sm); margin-bottom: 14px; }

    /* ───── APP LAYOUT ───── */
    .app { display: flex; min-height: 100vh; }

    /* ───── SIDEBAR ───── */
    .sidebar {
      width: 252px; background: var(--bg-1); border-right: 1px solid var(--border);
      display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .sb-header { display: flex; align-items: center; gap: 12px; padding: 24px 22px 28px; }
    .sb-logo {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--accent), var(--blue));
      border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
      box-shadow: 0 4px 16px rgba(124, 58, 237, 0.3);
    }
    .sb-brand-name { display: block; font-size: 1.05rem; font-weight: 800; color: var(--text-0); letter-spacing: -0.3px; line-height: 1.2; }
    .sb-brand-sub { display: block; font-size: 0.68rem; font-weight: 500; color: var(--text-3); text-transform: uppercase; letter-spacing: 1px; }

    .sb-label { padding: 0 22px; margin-bottom: 6px; font-size: 0.65rem; font-weight: 600; color: var(--text-4); text-transform: uppercase; letter-spacing: 1.2px; }

    #sidebar-nav { flex: 1; padding: 0 10px; }
    #sidebar-nav a {
      display: flex; align-items: center; gap: 12px; padding: 11px 14px; margin-bottom: 2px;
      border-radius: var(--radius-sm); color: var(--text-2); font-size: 0.85rem; font-weight: 500;
      cursor: pointer; text-decoration: none; transition: all 0.2s; position: relative;
    }
    #sidebar-nav a:hover { background: var(--bg-3); color: var(--text-1); }
    #sidebar-nav a .sb-icon {
      width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;
      border-radius: 8px; background: var(--bg-3); transition: all 0.2s; flex-shrink: 0;
    }
    #sidebar-nav a:hover .sb-icon { background: var(--bg-4); }
    #sidebar-nav a.active {
      background: var(--accent-bg-strong); color: var(--accent-light);
    }
    #sidebar-nav a.active .sb-icon {
      background: var(--accent); color: #fff; box-shadow: 0 4px 12px rgba(124,58,237,0.35);
    }
    #sidebar-nav a.active::before {
      content: ''; position: absolute; left: -10px; top: 50%; transform: translateY(-50%);
      width: 4px; height: 24px; background: var(--accent); border-radius: 0 4px 4px 0;
    }

    .sb-bottom { padding: 16px 22px; border-top: 1px solid var(--border); }
    .sb-logout {
      display: flex; align-items: center; gap: 10px; color: var(--text-3); font-size: 0.82rem;
      font-weight: 500; cursor: pointer; text-decoration: none; padding: 8px 0; transition: color 0.2s;
    }
    .sb-logout:hover { color: var(--red); }

    .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 90; backdrop-filter: blur(4px); }

    /* ───── MAIN ───── */
    .main { flex: 1; margin-left: 252px; display: flex; flex-direction: column; min-height: 100vh; background: var(--bg-0); }

    /* ───── TOPBAR ───── */
    .topbar {
      display: flex; align-items: center; gap: 16px; padding: 18px 28px;
      border-bottom: 1px solid var(--border); background: rgba(6,6,14,0.85);
      backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 50;
    }
    .menu-btn {
      display: none; background: var(--bg-2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); padding: 8px 10px; color: var(--text-1); cursor: pointer;
    }
    .tb-filters { display: flex; gap: 2px; background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 3px; }
    .tb-filters button {
      padding: 7px 18px; border: none; border-radius: 6px; background: transparent;
      color: var(--text-3); font-size: 0.8rem; font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s;
    }
    .tb-filters button.active { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(124,58,237,0.3); }
    .tb-filters button:hover:not(.active) { color: var(--text-1); }

    .tb-right { display: flex; align-items: center; gap: 14px; margin-left: auto; }
    .tb-btn {
      display: flex; align-items: center; gap: 7px; padding: 8px 16px; border: 1px solid var(--border);
      border-radius: var(--radius-sm); background: var(--bg-2); color: var(--text-2); font-size: 0.8rem;
      font-weight: 600; font-family: inherit; cursor: pointer; transition: all 0.2s;
    }
    .tb-btn:hover { border-color: var(--accent); color: var(--accent-light); background: var(--accent-bg); }

    .tb-live { display: flex; align-items: center; gap: 6px; }
    .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px rgba(16,185,129,0.5); animation: pulse 2s ease-in-out infinite; }
    .live-text { font-size: 0.72rem; font-weight: 600; color: var(--green); text-transform: uppercase; letter-spacing: 0.5px; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

    /* ───── CONTENT ───── */
    .content { padding: 28px; flex: 1; }

    .loading-state {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 80px; gap: 16px; color: var(--text-3); font-size: 0.88rem;
    }
    .loading-spinner {
      width: 28px; height: 28px; border: 3px solid var(--border); border-top-color: var(--accent);
      border-radius: 50%; animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ───── STAT CARDS ───── */
    .stat-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; margin-bottom: 28px; }
    .stat-card {
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 24px; transition: border-color 0.2s, box-shadow 0.2s;
    }
    .stat-card.highlighted { border-color: rgba(124,58,237,0.35); box-shadow: 0 0 0 1px rgba(124,58,237,0.1), 0 8px 32px rgba(124,58,237,0.08); }
    .stat-card .sc-label { font-size: 0.7rem; font-weight: 600; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 10px; }
    .stat-card .sc-value { font-size: 2.4rem; font-weight: 900; color: var(--text-0); letter-spacing: -1px; line-height: 1; margin-bottom: 10px; }
    .stat-card .sc-sub { display: flex; align-items: center; gap: 14px; font-size: 0.76rem; font-weight: 500; color: var(--text-3); }
    .stat-card .sc-sub .sc-green { color: var(--green); }
    .stat-card .sc-sub .sc-orange { color: var(--orange); }
    .sc-divider { width: 1px; height: 12px; background: var(--border); }

    /* ───── PANELS ───── */
    .panel {
      background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius);
      overflow: hidden; margin-bottom: 24px;
    }
    .panel-header {
      padding: 18px 22px; border-bottom: 1px solid var(--border);
    }
    .panel-header h2 { font-size: 0.88rem; font-weight: 700; color: var(--text-0); letter-spacing: -0.2px; }
    .panel-body { overflow-x: auto; }
    .panel-pad { padding: 20px 22px; }

    /* ───── TABLES ───── */
    table { width: 100%; border-collapse: separate; border-spacing: 0; }
    thead { position: sticky; top: 0; z-index: 2; }
    th {
      background: var(--bg-1); color: var(--text-3); font-weight: 600; font-size: 0.68rem;
      text-transform: uppercase; letter-spacing: 1px; text-align: left;
      padding: 14px 18px; white-space: nowrap; border-bottom: 1px solid var(--border-light);
    }
    th:first-child { padding-left: 24px; }
    th:last-child { padding-right: 24px; }
    td {
      padding: 16px 18px; color: var(--text-1); white-space: nowrap;
      font-size: 0.84rem; vertical-align: middle; line-height: 1.5;
    }
    td:first-child { padding-left: 24px; }
    td:last-child { padding-right: 24px; }
    tbody tr:nth-child(odd) { background: transparent; }
    tbody tr:nth-child(even) { background: rgba(16, 16, 45, 0.25); }
    tbody tr { transition: all 0.15s ease; cursor: default; }
    tbody tr:hover { background: rgba(124, 58, 237, 0.06); }
    tbody tr:hover td { color: var(--text-0); }
    .td-num { font-weight: 800; color: var(--text-0); font-size: 0.92rem; font-variant-numeric: tabular-nums; }

    /* Path chip */
    .path-chip {
      display: inline-block; padding: 4px 10px; background: rgba(16, 16, 45, 0.5);
      border-radius: 6px; font-family: 'SF Mono', 'Cascadia Code', 'Fira Code', monospace;
      font-size: 0.78rem; color: var(--text-1); max-width: 280px; overflow: hidden;
      text-overflow: ellipsis; white-space: nowrap; vertical-align: middle;
      border: 1px solid rgba(30, 30, 60, 0.5);
    }

    /* Country cell */
    .country-cell { display: inline-flex; align-items: center; gap: 7px; }
    .country-cell .flag { font-size: 1.05rem; line-height: 1; }
    .country-cell .name { font-size: 0.82rem; font-weight: 600; color: var(--accent-light); }

    /* Duration */
    .dur { font-variant-numeric: tabular-nums; font-weight: 500; color: var(--text-1); }

    /* Muted placeholder */
    .na { color: var(--text-4); font-size: 0.78rem; }

    /* Session mono */
    .sess-id { font-family: 'SF Mono', 'Cascadia Code', monospace; font-size: 0.72rem; color: var(--text-4); letter-spacing: 0.3px; }

    /* ───── PILL BADGES ───── */
    .pill {
      display: inline-flex; align-items: center; justify-content: center; gap: 5px;
      padding: 5px 12px; border-radius: var(--radius-pill); font-size: 0.72rem; font-weight: 600;
      line-height: 1; white-space: nowrap; letter-spacing: 0.2px;
    }
    .pill-human { background: rgba(16, 185, 129, 0.12); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.2); }
    .pill-rank { background: var(--accent-bg); color: var(--accent-light); font-weight: 800; min-width: 28px; }

    /* Bot pills — each bot gets a unique color */
    .pill-bot { border: 1px solid rgba(245, 158, 11, 0.2); }
    .pill-bot-orange { background: rgba(245, 158, 11, 0.1); color: #fbbf24; border-color: rgba(245, 158, 11, 0.2); }
    .pill-bot-red { background: rgba(239, 68, 68, 0.1); color: #f87171; border-color: rgba(239, 68, 68, 0.2); }
    .pill-bot-blue { background: rgba(59, 130, 246, 0.1); color: #60a5fa; border-color: rgba(59, 130, 246, 0.2); }
    .pill-bot-cyan { background: rgba(6, 182, 212, 0.1); color: #22d3ee; border-color: rgba(6, 182, 212, 0.2); }
    .pill-bot-purple { background: rgba(168, 85, 247, 0.1); color: #c084fc; border-color: rgba(168, 85, 247, 0.2); }
    .pill-bot-pink { background: rgba(236, 72, 153, 0.1); color: #f472b6; border-color: rgba(236, 72, 153, 0.2); }
    .pill-bot-teal { background: rgba(20, 184, 166, 0.1); color: #2dd4bf; border-color: rgba(20, 184, 166, 0.2); }
    .pill-bot-lime { background: rgba(132, 204, 22, 0.1); color: #a3e635; border-color: rgba(132, 204, 22, 0.2); }

    .empty { text-align: center; padding: 48px 24px; color: var(--text-4); font-size: 0.85rem; }

    /* ───── COUNTRY CHART ───── */
    .c-row { display: flex; align-items: center; gap: 12px; padding: 7px 0; }
    .c-flag { font-size: 1rem; width: 24px; text-align: center; }
    .c-code { width: 32px; font-size: 0.78rem; font-weight: 700; color: var(--accent-light); }
    .c-bar-bg { flex: 1; height: 26px; background: var(--bg-3); border-radius: 6px; overflow: hidden; position: relative; }
    .c-bar {
      height: 100%; border-radius: 6px; min-width: 4px;
      background: linear-gradient(90deg, var(--accent), var(--blue));
      transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .c-val { width: 40px; text-align: right; font-size: 0.78rem; font-weight: 700; color: var(--text-1); }

    /* ───── TWO-COL GRID ───── */
    .grid-2 { display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px; }
    .grid-2 .panel { margin-bottom: 0; }

    /* ───── SETTINGS ───── */
    .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 720px; }
    .form-stack { display: flex; flex-direction: column; gap: 10px; }
    .form-stack input {
      width: 100%; padding: 12px 16px; background: var(--bg-1); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text-1); font-size: 0.88rem; font-family: inherit; outline: none; transition: border-color 0.2s;
    }
    .form-stack input:focus { border-color: var(--accent); }
    .form-btn {
      padding: 12px 24px; background: var(--accent); color: #fff; border: none;
      border-radius: var(--radius-sm); font-size: 0.88rem; font-weight: 600; font-family: inherit;
      cursor: pointer; transition: background 0.2s; align-self: flex-start;
    }
    .form-btn:hover { background: var(--accent-dark); }
    .form-msg { font-size: 0.82rem; }
    .form-msg.ok { color: var(--green); }
    .form-msg.err { color: var(--red); }

    .info-item {
      display: flex; align-items: center; gap: 10px; padding: 10px 0;
      font-size: 0.82rem; color: var(--text-2); line-height: 1.5;
      border-bottom: 1px solid var(--border);
    }
    .info-item:last-child { border-bottom: none; }
    .info-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .info-dot.green { background: var(--green); }
    .info-dot.purple { background: var(--accent); }
    .info-dot.blue { background: var(--blue); }

    /* ───── RESPONSIVE ───── */
    @media (max-width: 900px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); box-shadow: 16px 0 48px rgba(0,0,0,0.4); }
      .overlay.open { display: block; }
      .main { margin-left: 0; }
      .menu-btn { display: flex; }
      .stat-cards { grid-template-columns: 1fr; }
      .grid-2 { grid-template-columns: 1fr; }
      .settings-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 540px) {
      .content { padding: 16px; }
      .topbar { padding: 14px 16px; gap: 10px; }
      .tb-filters button { padding: 6px 12px; font-size: 0.75rem; }
      .tb-btn span { display: none; }
      .stat-card .sc-value { font-size: 1.8rem; }
      .panel-header { padding: 14px 16px; }
      th, td { padding: 10px 12px; }
      th:first-child, td:first-child { padding-left: 16px; }
    }
  </style>

  {authenticated && (
    <script is:inline>
      let currentSection = 'overview';
      let currentPeriod = 'today';
      let statsData = null;

      function showSection(name) {
        currentSection = name;
        document.querySelectorAll('.section-content').forEach(el => el.hidden = true);
        const sec = document.getElementById('section-' + name);
        if (sec) sec.hidden = false;
        document.querySelectorAll('#sidebar-nav a').forEach(a => {
          a.classList.toggle('active', a.dataset.section === name);
        });
        closeSidebar();
      }

      function setPeriod(p) {
        currentPeriod = p;
        document.querySelectorAll('#filters button').forEach(b => {
          b.classList.toggle('active', b.dataset.period === p);
        });
        fetchStats();
      }

      function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('open');
        document.getElementById('overlay').classList.toggle('open');
      }
      function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('overlay').classList.remove('open');
      }

      function logout() {
        document.cookie = 'moda_token=;path=/;max-age=0';
        location.reload();
      }

      function timeAgo(ts) {
        const diff = Date.now() - new Date(ts).getTime();
        const m = Math.floor(diff / 60000);
        if (m < 1) return 'hozirgina';
        if (m < 60) return m + ' daq oldin';
        const h = Math.floor(m / 60);
        if (h < 24) return h + ' soat oldin';
        const d = Math.floor(h / 24);
        return d + ' kun oldin';
      }

      function fmtDur(sec) {
        if (!sec || sec <= 0) return '';
        if (sec < 60) return sec + ' son';
        var m = Math.floor(sec / 60);
        var s = sec % 60;
        if (s === 0) return m + ' daq';
        return m + ' daq ' + s + ' son';
      }

      function countryFlag(code) {
        if (!code || code.length !== 2) return '';
        return String.fromCodePoint(...[...code.toUpperCase()].map(c => 0x1F1E6 + c.charCodeAt(0) - 65));
      }

      var botColors = {};
      var colorPool = ['orange','blue','purple','cyan','red','pink','teal','lime'];
      var colorIdx = 0;
      function botPillClass(name) {
        if (!botColors[name]) { botColors[name] = colorPool[colorIdx % colorPool.length]; colorIdx++; }
        return 'pill pill-bot pill-bot-' + botColors[name];
      }

      async function fetchStats() {
        var dot = document.querySelector('.live-dot');
        var txt = document.querySelector('.live-text');
        if (dot) { dot.style.background = 'var(--orange)'; dot.style.boxShadow = '0 0 8px rgba(245,158,11,0.5)'; }
        if (txt) txt.style.color = 'var(--orange)';
        try {
          const res = await fetch('/api/stats?period=' + currentPeriod);
          if (res.status === 401) { location.reload(); return; }
          statsData = await res.json();
          renderAll();
          if (dot) { dot.style.background = 'var(--green)'; dot.style.boxShadow = '0 0 8px rgba(16,185,129,0.5)'; }
          if (txt) txt.style.color = 'var(--green)';
        } catch (e) {
          if (dot) { dot.style.background = 'var(--red)'; dot.style.boxShadow = '0 0 8px rgba(239,68,68,0.5)'; }
          if (txt) txt.style.color = 'var(--red)';
        }
        var loader = document.getElementById('loading');
        if (loader) loader.style.display = 'none';
      }

      function renderAll() {
        if (!statsData) return;
        renderStatCards();
        renderRecent();
        renderBots();
        renderUsers();
        renderCountries();
        renderPages();
      }

      function renderStatCards() {
        const d = statsData;
        const cards = [
          { label: 'Bugun', data: d.today, active: currentPeriod === 'today' },
          { label: 'Hafta (7 kun)', data: d.week, active: currentPeriod === 'week' },
          { label: 'Oy (30 kun)', data: d.month, active: currentPeriod === 'month' },
        ];
        document.getElementById('statCards').innerHTML = cards.map(c => `
          <div class="stat-card${c.active ? ' highlighted' : ''}">
            <div class="sc-label">${c.label}</div>
            <div class="sc-value">${c.data.sessions}</div>
            <div class="sc-sub">
              <span class="sc-green">${c.data.humanSessions} sessiya</span>
              <span class="sc-divider"></span>
              <span class="sc-orange">${c.data.botViews} bot</span>
              <span class="sc-divider"></span>
              <span>${c.data.views} ko'rish</span>
            </div>
          </div>
        `).join('');
      }

      function renderRecent() {
        const rows = statsData.recent;
        if (!rows.length) {
          document.getElementById('recentTable').innerHTML = '<div class="empty">Tashriflar hali yo\'q</div>';
          return;
        }
        document.getElementById('recentTable').innerHTML = `<table>
          <thead><tr><th>Turi</th><th>Sahifa</th><th>Mamlakat</th><th>Vaqt</th><th>Davomiylik</th></tr></thead>
          <tbody>${rows.map(v => `<tr>
            <td>${v.isBot ? '<span class="' + botPillClass(v.botName) + '">' + v.botName + '</span>' : '<span class="pill pill-human">Odam</span>'}</td>
            <td><span class="path-chip">${v.path}</span></td>
            <td>${v.country && v.country !== 'Local' && v.country !== '—' ? '<span class="country-cell"><span class="flag">' + countryFlag(v.country) + '</span><span class="name">' + v.country + '</span></span>' : '<span class="na"></span>'}</td>
            <td style="color:var(--text-3)">${timeAgo(v.timestamp)}</td>
            <td>${fmtDur(v.duration) ? '<span class="dur">' + fmtDur(v.duration) + '</span>' : '<span class="na"></span>'}</td>
          </tr>`).join('')}</tbody>
        </table>`;
      }

      function renderBots() {
        const rows = statsData.botTraffic;
        if (!rows.length) {
          document.getElementById('botTable').innerHTML = '<div class="empty">Bot trafik hali yo\'q</div>';
          return;
        }
        document.getElementById('botTable').innerHTML = `<table>
          <thead><tr><th>Bot</th><th>Sahifalar crawl</th><th>Sessiyalar</th><th>Oxirgi tashrif</th><th>Ko'rgan sahifalar</th></tr></thead>
          <tbody>${rows.map(b => `<tr>
            <td><span class="${botPillClass(b.name)}">${b.name}</span></td>
            <td class="td-num">${b.pagesCrawled}</td>
            <td class="td-num">${b.sessions}</td>
            <td style="color:var(--text-3)">${timeAgo(b.lastSeen)}</td>
            <td>${b.pages.slice(0, 3).map(p => '<span class="path-chip">' + p + '</span> ').join('')}${b.pages.length > 3 ? '<span class="na">+' + (b.pages.length - 3) + '</span>' : ''}</td>
          </tr>`).join('')}</tbody>
        </table>`;
      }

      function renderUsers() {
        const rows = statsData.realUsers;
        if (!rows.length) {
          document.getElementById('usersTable').innerHTML = '<div class="empty">Real foydalanuvchilar yo\'q</div>';
          return;
        }
        document.getElementById('usersTable').innerHTML = `<table>
          <thead><tr><th>Sahifa</th><th>Mamlakat</th><th>Vaqt</th><th>Davomiylik</th><th>Sessiya</th></tr></thead>
          <tbody>${rows.map(u => `<tr>
            <td><span class="path-chip">${u.path}</span></td>
            <td>${u.country && u.country !== 'Local' && u.country !== '—' ? '<span class="country-cell"><span class="flag">' + countryFlag(u.country) + '</span><span class="name">' + u.country + '</span></span>' : '<span class="na"></span>'}</td>
            <td style="color:var(--text-3)">${timeAgo(u.timestamp)}</td>
            <td>${fmtDur(u.duration) ? '<span class="dur">' + fmtDur(u.duration) + '</span>' : '<span class="na"></span>'}</td>
            <td><span class="sess-id">${(u.sessionId || '').slice(0, 8)}</span></td>
          </tr>`).join('')}</tbody>
        </table>`;
      }

      function renderCountries() {
        const rows = statsData.countries;
        if (!rows.length) {
          document.getElementById('countryChart').innerHTML = '<div class="empty">Mamlakat ma\'lumoti yo\'q</div>';
          return;
        }
        const max = rows[0].sessions;
        document.getElementById('countryChart').innerHTML = rows.map(c => `
          <div class="c-row">
            <div class="c-flag">${countryFlag(c.country)}</div>
            <div class="c-code">${c.country}</div>
            <div class="c-bar-bg"><div class="c-bar" style="width:${Math.max((c.sessions / max) * 100, 4)}%"></div></div>
            <div class="c-val">${c.sessions}</div>
          </div>
        `).join('');
      }

      function renderPages() {
        const rows = statsData.topPages;
        if (!rows.length) {
          document.getElementById('pagesTable').innerHTML = '<div class="empty">Sahifa ma\'lumoti yo\'q</div>';
          return;
        }
        document.getElementById('pagesTable').innerHTML = `<table>
          <thead><tr><th>#</th><th>Sahifa</th><th>Sessiyalar</th><th>Ko'rishlar</th><th>Odam</th><th>Bot</th></tr></thead>
          <tbody>${rows.map((p, i) => `<tr>
            <td><span class="pill pill-rank">${i + 1}</span></td>
            <td><span class="path-chip">${p.path}</span></td>
            <td class="td-num">${p.sessions}</td>
            <td style="color:var(--text-2)">${p.views}</td>
            <td><span class="pill pill-human">${p.humanViews}</span></td>
            <td><span class="pill pill-bot pill-bot-orange">${p.botViews}</span></td>
          </tr>`).join('')}</tbody>
        </table>`;
      }

      function exportCSV() {
        if (!statsData) return;
        const all = [...statsData.recent, ...statsData.realUsers];
        const seen = new Set();
        const unique = all.filter(v => { if (seen.has(v.id)) return false; seen.add(v.id); return true; });
        const header = 'Turi,Sahifa,Mamlakat,IP,Vaqt,Davomiylik,Sessiya,Bot nomi\n';
        const rows = unique.map(v =>
          [v.isBot ? 'Bot' : 'Odam', v.path, v.country, v.ip, v.timestamp, v.duration + 's', v.sessionId || '', v.botName || ''].map(c => '"' + String(c).replace(/"/g, '""') + '"').join(',')
        ).join('\n');
        const blob = new Blob([header + rows], { type: 'text/csv;charset=utf-8;' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'starsjoy-analytics-' + currentPeriod + '.csv';
        a.click();
      }

      async function changePassword() {
        const msg = document.getElementById('passMsg');
        const current = document.getElementById('currentPass').value;
        const newP = document.getElementById('newPass').value;
        const confirm = document.getElementById('confirmPass').value;
        if (newP !== confirm) {
          msg.className = 'form-msg err'; msg.textContent = 'Parollar mos kelmaydi'; return;
        }
        try {
          const res = await fetch('/api/stats', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'change_password', current: current, newPass: newP }),
          });
          const data = await res.json();
          if (data.ok) {
            msg.className = 'form-msg ok'; msg.textContent = 'Parol o\'zgartirildi';
            document.getElementById('currentPass').value = '';
            document.getElementById('newPass').value = '';
            document.getElementById('confirmPass').value = '';
          } else {
            msg.className = 'form-msg err'; msg.textContent = data.error || 'Xatolik';
          }
        } catch {
          msg.className = 'form-msg err'; msg.textContent = 'Server xatoligi';
        }
      }

      showSection('overview');
      fetchStats();
      setInterval(fetchStats, 30000);
    </script>
  )}
</body>
</html>
