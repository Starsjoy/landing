          return;
        }
        document.getElementById('salesTable').innerHTML = `<table>
          <thead><tr><th>#</th><th>Turi</th><th>Foydalanuvchi</th><th>Miqdor</th><th>Summa</th><th>Vaqt</th></tr></thead>
          <tbody>${rows.map(r => {
