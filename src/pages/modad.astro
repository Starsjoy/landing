      /* ── Tables — horizontal scroll with fade hint ── */
      .panel-body { position: relative; padding: 10px 0 4px; }
      .panel-body::after {
        content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 24px;
        background: linear-gradient(to right, transparent, var(--bg-2));
        pointer-events: none; opacity: 0; transition: opacity 0.2s;
      }
      .panel-body.has-scroll::after { opacity: 1; }

      table { min-width: 560px; }
      th, td { padding: 8px 10px; font-size: 0.78rem; height: auto; min-height: 40px; }
      th:first-child, td:first-child { padding-left: 14px; }
      th:last-child, td:last-child { padding-right: 14px; }
      th { font-size: 0.68rem; padding-bottom: 8px; }

      .path-chip { max-width: 160px; font-size: 0.72rem; }
      .ua-chip { max-width: 140px; font-size: 0.65rem; }
      .pill { padding: 3px 8px; font-size: 0.66rem; }

      /* ── Country chart ── */
      .c-row { gap: 8px; padding: 6px 0; }
      .c-bar-bg { height: 22px; }
      .c-code { font-size: 0.72rem; }
      .c-val { font-size: 0.72rem; }

      /* ── Settings ── */
      .form-stack input { padding: 12px 14px; font-size: 0.85rem; }
      .form-btn { padding: 12px 20px; font-size: 0.85rem; width: 100%; text-align: center; }
      .info-item { font-size: 0.78rem; padding: 8px 0; }

      /* ── Profit ── */
      .profit-filter {
        overflow-x: auto; -webkit-overflow-scrolling: touch;
        scrollbar-width: none; width: 100%;
      }
      .profit-filter::-webkit-scrollbar { display: none; }
      .pf-btn { flex-shrink: 0; }
      .profit-cards { grid-template-columns: 1fr; gap: 10px; }
      .pc-value { font-size: 2rem; }
      .profit-breakdown { max-width: 100%; }

      /* ── Analytics ── */
      .an-tabs { gap: 6px; }
