      function renderTopBuyers() {
        var o = statsData.orders;
        if (!o || !o.topBuyers || !o.topBuyers.length) {
          document.getElementById('topBuyers').innerHTML = '<div class="empty">Ma\'lumot yo\'q</div>';
          return;
        }
        document.getElementById('topBuyers').innerHTML = `<table>
          <thead><tr><th>#</th><th>Foydalanuvchi</th><th>Buyurtmalar</th><th>Jami</th></tr></thead>
          <tbody>${o.topBuyers.map((b, i) => {
            var details = [];
            if (b.starsOrders) details.push('⭐' + b.starsOrders);
            if (b.giftOrders) details.push('🎁' + b.giftOrders);
            if (b.premiumOrders) details.push('👑' + b.premiumOrders);
            if (b.psOrders) details.push('📤' + b.psOrders);
            if (b.p112Orders) details.push('💎' + b.p112Orders);
            if (b.uzStarsOrders) details.push('UZ⭐' + b.uzStarsOrders);
            if (b.uzPremiumOrders) details.push('UZ👑' + b.uzPremiumOrders);
            return '<tr>' +
              '<td><span class="pill pill-rank">' + (i + 1) + '</span></td>' +
              '<td>@' + b.username + '</td>' +
              '<td class="td-num">' + b.orders + ' <span style="color:var(--text-4);font-size:0.7rem">' + details.join(' ') + '</span></td>' +
              '<td class="td-num sc-revenue">' + fmtMoney(b.totalSpent) + '</td>' +
            '</tr>';
          }).join('')}</tbody>
