      async function deleteOrder(id) {
        if (!confirm("Bu buyurtmani o'chirishni xohlaysizmi?")) return;
        var row = document.getElementById('order-row-' + id);
        if (row) row.style.opacity = '0.3';
        try {
          var res = await fetch('/api/stats', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'delete_order', id: id }),
          });
          if (res.ok) {
            if (row) row.remove();
            fetchSales();
          } else {
            if (row) row.style.opacity = '1';
            alert("O'chirishda xatolik");
          }
        } catch {
          if (row) row.style.opacity = '1';
          alert("Server xatoligi");
        }
      }

      async function exportCSV() {
        var btn = document.querySelector('.tb-btn');
        if (btn) { btn.disabled = true; btn.style.opacity = '0.5'; }
        try {
          var res = await fetch('/api/stats?period=' + currentPeriod + '&export=csv');
          if (res.status === 401) { location.reload(); return; }
          var visits = await res.json();
          var header = 'Turi,Sahifa,Mamlakat,IP,Vaqt,Davomiylik,Sessiya,Bot nomi\n';
          var rows = visits.map(function(v) {
            return [v.isBot ? 'Bot' : 'Odam', v.path, v.country, v.ip, v.timestamp, v.duration + 's', v.sessionId || '', v.botName || ''].map(function(c) { return '"' + String(c).replace(/"/g, '""') + '"'; }).join(',');
          }).join('\n');
          var blob = new Blob([header + rows], { type: 'text/csv;charset=utf-8;' });
          var a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'starsjoy-analytics-' + currentPeriod + '.csv';
          a.click();
        } catch (e) { console.error('Export error:', e); }
        if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
