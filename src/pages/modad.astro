      var pagesFilter = 'all'; // 'all' | 'bots' | 'users'

      function setPagesFilter(name) {
        pagesFilter = name;
        document.querySelectorAll('#pagesFilters .rf-btn').forEach(b => {
          b.classList.toggle('active', b.dataset.pagesFilter === name);
        });
        renderPages();
      }

      function renderPages() {
        var raw = (statsData && statsData.topPages) || [];
        var rows;
        if (pagesFilter === 'bots') {
          rows = raw.filter(p => p.botViews > 0).slice().sort((a, b) => b.botViews - a.botViews);
        } else if (pagesFilter === 'users') {
          rows = raw.filter(p => p.humanViews > 0).slice().sort((a, b) => b.humanViews - a.humanViews);
        } else {
          rows = raw.slice().sort((a, b) => b.views - a.views);
        }
        if (!rows.length) {
          document.getElementById('pagesTable').innerHTML = '<div class="empty">Sahifa ma\'lumoti yo\'q</div>';
          return;
        }
        document.getElementById('pagesTable').innerHTML = `<table>
          <thead><tr><th>#</th><th>Sahifa</th><th>Sessiyalar</th><th>Ko'rishlar</th><th>Odam</th><th>Bot</th></tr></thead>
          <tbody>${rows.map((p, i) => `<tr>
            <td><span class="pill pill-rank">${i + 1}</span></td>
            <td><span class="path-chip">${fmtPath(p.path)}</span></td>
            <td class="td-num">${p.sessions}</td>
            <td style="color:var(--text-2)">${p.views}</td>
            <td><span class="pill pill-human">${p.humanViews}</span></td>
            <td><span class="pill pill-bot pill-bot-orange">${p.botViews}</span></td>
          </tr>`).join('')}</tbody>
        </table>`;
      }

      function fmtMoney(n) {
        return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
      }

      function getTypePill(type) {
        if (type === 'stars') return { pill: 'pill-stars', label: 'Stars' };
        if (type === 'gift') return { pill: 'pill-gift', label: 'Gift' };
        if (type === 'premium_send') return { pill: 'pill-premium_send', label: 'PS Premium' };
        if (type === 'premium_1_12') return { pill: 'pill-premium_1_12', label: 'P 1/12' };
        if (type === 'uzgets_stars') return { pill: 'pill-uzgets_stars', label: 'UZ Stars' };
        if (type === 'uzgets_premium') return { pill: 'pill-uzgets_premium', label: 'UZ Premium' };
        return { pill: 'pill-premium', label: 'Premium' };
      }

