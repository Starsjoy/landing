            <td>${b.pages.slice(0, 3).map(p => '<span class="path-chip">' + fmtPath(p) + '</span> ').join('')}${b.pages.length > 3 ? '<span class="na">+' + (b.pages.length - 3) + '</span>' : ''}</td>
          </tr>`).join('')}</tbody>
        </table>`;
