          if (res.status === 401) { location.reload(); return; }
          statsData = await res.json();
          sourceData[currentSource] = { orders: statsData.orders, analytics: statsData.analytics, buyerInsights: statsData.buyerInsights };
          renderAll();
          if (dot) { dot.style.background = 'var(--green)'; dot.style.boxShadow = '0 0 8px rgba(16,185,129,0.5)'; }
          if (txt) txt.style.color = 'var(--green)';
        } catch (e) {
          if (dot) { dot.style.background = 'var(--red)'; dot.style.boxShadow = '0 0 8px rgba(239,68,68,0.5)'; }
          if (txt) txt.style.color = 'var(--red)';
        }
        var loader = document.getElementById('loading');
        if (loader) loader.style.display = 'none';
      }

      async function fetchSourceData(source) {
        try {
          var params = 'period=' + currentPeriod + '&source=' + source + '&ap=' + chartPeriod;
          if (salesFrom) params += '&salesFrom=' + salesFrom;
          if (salesTo) params += '&salesTo=' + salesTo;
          var res = await fetch('/api/stats?' + params);
          if (res.status === 401) { location.reload(); return; }
          var data = await res.json();
          sourceData[source] = { orders: data.orders, analytics: data.analytics, buyerInsights: data.buyerInsights };
          statsData.orders = data.orders;
          statsData.analytics = data.analytics;
          statsData.buyerInsights = data.buyerInsights;
          renderSalesAll();
          renderBuyerInsights();
          renderProfit(statsData.orders);
          renderCharts();
        } catch (e) { console.error('Source fetch error:', e); }
      }

      var salesFrom = '';
      var salesTo = '';

      function setSalesCustomDate() {
        salesFrom = document.getElementById('salesDateFrom').value;
        salesTo = document.getElementById('salesDateTo').value;
        if (salesFrom) {
          fetchSales();
        }
      }

      async function fetchSales() {
        var params = salesFrom
          ? 'salesFrom=' + salesFrom + (salesTo ? '&salesTo=' + salesTo : '')
          : 'period=' + currentPeriod;
        try {
          var res = await fetch('/api/stats?' + params + '&period=' + currentPeriod + '&source=' + currentSource);
          if (res.status === 401) { location.reload(); return; }
          var data = await res.json();
          statsData.orders = data.orders;
          renderSalesAll();
        } catch (e) { console.error('Sales fetch error:', e); }
      }

      function renderSalesAll() {
        renderSales();
        renderDailyRevenue();
        renderTopBuyers();
        // Update daily chart title based on source
        var dsTitle = document.getElementById('dailyStarsTitle');
        if (dsTitle) dsTitle.textContent = (currentSource === 'premium_send' || currentSource === 'premium_1_12') ? 'Kunlik premium miqdori' : 'Kunlik stars miqdori';
        renderDailyStars();
      }

      function renderAll() {
        if (!statsData) return;
        renderStatCards();
        renderRecent();
        renderBots();
        renderUsers();
        renderCountries();
        renderPages();
        renderSalesAll();
        renderBuyerInsights();
        renderProfit(statsData.orders);
        renderCharts();
        renderMobileQuickStats();
      }

