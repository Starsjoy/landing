              <button class="cf-btn" data-cp="month" onclick="setChartPeriod('month')">Oy</button>
              <button class="cf-btn" data-cp="3months" onclick="setChartPeriod('3months')">3 oy</button>
              <button class="cf-btn" data-cp="6months" onclick="setChartPeriod('6months')">6 oy</button>
              <button class="cf-btn" data-cp="12months" onclick="setChartPeriod('12months')">1 yil</button>
