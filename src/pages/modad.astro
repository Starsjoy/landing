---
export const prerender = false;

import { verifyToken, verifyPassword, generateToken, initDB } from '../lib/analytics';

const token = Astro.cookies.get('moda_token')?.value || '';
let authenticated = await verifyToken(token);
let loginError = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = form.get('password')?.toString() || '';
  if (await verifyPassword(password)) {
    const newToken = generateToken(password);
    Astro.cookies.set('moda_token', newToken, { path: '/', httpOnly: true, secure: true, sameSite: 'lax', maxAge: 60 * 60 * 24 * 7 });
    authenticated = true;
  } else {
    loginError = "Parol noto'g'ri";
  }
}

let dbReady = false;
if (authenticated && !dbReady) {
  try { await initDB(); dbReady = true; } catch (e) { console.error('DB init error:', e); }
}
