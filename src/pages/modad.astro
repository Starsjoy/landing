        document.getElementById('botTable').innerHTML = `<table>
          <thead><tr><th>Bot</th><th>Sahifalar</th><th>Sessiyalar</th><th>Oxirgi</th><th>User-Agent</th><th>Sahifalar</th></tr></thead>
