                <div class="pc-value" id="profitValue">0</div>
                <div class="pc-sub">so'm</div>
              </div>
              <div class="profit-card">
                <div class="pc-label">Umumiy daromad</div>
                <div class="pc-value pc-dim" id="profitRevenue">0</div>
                <div class="pc-sub">so'm</div>
              </div>
              <div class="profit-card">
                <div class="pc-label">Buyurtmalar</div>
