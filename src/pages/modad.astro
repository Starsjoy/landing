      /* ── Panels ── */
      .panel { border-radius: 10px; margin-bottom: 14px; }
      .panel-header { padding: 14px 16px; }
      .panel-header h2 { font-size: 0.78rem; }

      /* Panel header flex — stack on mobile */
      .panel-header[style] {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 10px !important;
      }

      /* Row filters — scrollable */
      .row-filters {
