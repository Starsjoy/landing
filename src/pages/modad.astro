              <div class="chart-body chart-body-lg" id="visitsChart"></div>
            </div>

            <div class="chart-panel" id="chart-conversion" hidden>
              <div class="chart-header">
                <h2>Tashriflar va sotuvlar</h2>
                <div class="chart-legend">
                  <span class="cl-item"><span class="cl-dot" style="background:#a78bfa"></span> Tashriflar</span>
                  <span class="cl-item"><span class="cl-dot" style="background:#10b981"></span> Sotuvlar</span>
                </div>
