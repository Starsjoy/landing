        var circ = 2 * Math.PI * 52; // 326.73

        // Donut chart
        document.getElementById('buyersTotal').textContent = b.totalBuyers;
        document.getElementById('buyersNew').textContent = b.newBuyers;
        document.getElementById('buyersNewPct').textContent = b.newPercent + '%';
        document.getElementById('buyersRet').textContent = b.returningBuyers;
        document.getElementById('buyersRetPct').textContent = b.returningPercent + '%';

        // Animate arcs
        var newArc = document.querySelector('.bh-arc-new');
        var retArc = document.querySelector('.bh-arc-ret');
        var newLen = (b.newPercent / 100) * circ;
        var retLen = (b.returningPercent / 100) * circ;
        newArc.style.strokeDashoffset = circ - newLen;
        // Returning arc starts where new ends
        retArc.style.strokeDasharray = circ;
        retArc.style.strokeDashoffset = circ - retLen;
        retArc.setAttribute('transform', 'rotate(' + ((-90) + (b.newPercent / 100) * 360) + ' 60 60)');

        // Cards
        document.getElementById('bcNew').innerHTML = b.newBuyers + ' <small>' + b.newPercent + '%</small>';
