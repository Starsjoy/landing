      // ───── PLAN (REJA) ─────
      var planState = null;
      var planSelectedMonth = null; // YYYY-MM
      var planConfettiArmed = false; // showSection yoki planSave da true bo'ladi

      function launchSalyut() {
        var canvas = document.getElementById('salyutCanvas');
        if (canvas) canvas.remove();
        canvas = document.createElement('canvas');
        canvas.id = 'salyutCanvas';
        canvas.style.cssText = 'position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:9999;';
        document.body.appendChild(canvas);
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        var ctx = canvas.getContext('2d');
        var colors = ['#10b981','#fbbf24','#3b82f6','#ec4899','#a78bfa','#f59e0b','#f87171','#34d399'];
        var particles = [];

        function burst(cx, cy) {
          var n = 55;
          for (var i = 0; i < n; i++) {
            var angle = -Math.PI/2 + (Math.random() - 0.5) * 1.4;
            var speed = 9 + Math.random() * 11;
            particles.push({
              x: cx, y: cy,
              vx: Math.cos(angle) * speed,
              vy: Math.sin(angle) * speed,
              size: 4 + Math.random() * 5,
              color: colors[Math.floor(Math.random() * colors.length)],
              rot: Math.random() * Math.PI * 2,
              rotSpd: (Math.random() - 0.5) * 0.35,
            });
          }
        }

        burst(canvas.width * 0.2, canvas.height);
        burst(canvas.width * 0.8, canvas.height);
        setTimeout(function() {
          if (document.getElementById('salyutCanvas')) burst(canvas.width * 0.5, canvas.height);
        }, 220);

        var start = Date.now();
        var DUR = 2800;
        function tick() {
          var t = Date.now() - start;
          if (t > DUR) { canvas.remove(); return; }
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          var life = Math.max(0, 1 - t / DUR);
          for (var i = 0; i < particles.length; i++) {
            var p = particles[i];
            p.vy += 0.20; // gravity
            p.vx *= 0.997;
            p.x += p.vx;
            p.y += p.vy;
            p.rot += p.rotSpd;
            if (p.y > canvas.height + 40) continue;
            ctx.save();
            ctx.globalAlpha = life;
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rot);
            ctx.fillStyle = p.color;
            ctx.fillRect(-p.size/2, -p.size/2, p.size, p.size * 1.4);
            ctx.restore();
          }
          requestAnimationFrame(tick);
        }
        tick();
      }

      function planCurrentTashkentMonth() {
        var d = new Date();
        var tz = new Date(d.getTime() + 5 * 60 * 60 * 1000);
        return tz.getUTCFullYear() + '-' + String(tz.getUTCMonth() + 1).padStart(2, '0');
      }

      function planShiftStr(month, delta) {
        var p = month.split('-');
        var y = +p[0], m = +p[1];
        var total = y * 12 + (m - 1) + delta;
        var ny = Math.floor(total / 12);
        var nm = (total % 12) + 1;
        return ny + '-' + String(nm).padStart(2, '0');
      }

      function planJumpToCurrent() {
        planSelectedMonth = planCurrentTashkentMonth();
        fetchPlan();
      }

      function planShiftMonth(delta) {
        if (!planSelectedMonth) planSelectedMonth = planCurrentTashkentMonth();
        // Kelajakka qarab cheklash yo'q (kelasi oyga reja qo'yish mumkin)
        planSelectedMonth = planShiftStr(planSelectedMonth, delta);
        fetchPlan();
      }

      function formatPlanInput(input) {
        var raw = (input.value || '').replace(/\D/g, '');
        if (!raw) { input.value = ''; return; }
        input.value = parseInt(raw, 10).toLocaleString('en-US');
      }

      async function fetchPlan() {
        if (!planSelectedMonth) planSelectedMonth = planCurrentTashkentMonth();
        try {
          var res = await fetch('/api/plan?month=' + planSelectedMonth);
          if (!res.ok) {
            document.getElementById('planSignalText').textContent = 'Xato: ' + res.status;
            return;
          }
          planState = await res.json();
          renderPlan();
        } catch (e) {
          console.error('Plan fetch error:', e);
        }
      }

      function renderPlan() {
        if (!planState) return;
        var p = planState;

        // Month label
        document.getElementById('planMonthLabel').textContent = fmtMonthName(p.month);

        // Target
        var targetEl = document.getElementById('planTargetVal');
        if (p.target > 0) {
          targetEl.textContent = fmtMoney(p.target) + " so'm";
        } else {
          targetEl.textContent = '—';
        }
        document.getElementById('planDeleteBtn').hidden = !(p.target > 0);

        // Profit (joriy / oxirgi)
        document.getElementById('planProfitLabel').textContent = p.isCurrent
          ? (p.dayToday + '-kun foyda')
          : (p.isPast ? 'Oy yakunidagi foyda' : 'Foyda');
        document.getElementById('planProfitVal').textContent = fmtMoney(p.profitToDate) + " so'm";
        if (p.target > 0 && p.dayToday > 0) {
          var pct = Math.round((p.profitToDate / p.target) * 100);
          var diff = p.profitToDate - p.expectedToDate;
          var diffTxt = '';
          if (p.isCurrent) {
            if (diff >= 0) diffTxt = "tempdan +" + fmtMoney(diff) + ' oldinda';
            else diffTxt = "tempdan " + fmtMoney(Math.abs(diff)) + ' orqada';
          }
          document.getElementById('planProfitSub').textContent = "rejaning " + pct + '%' + (diffTxt ? ' · ' + diffTxt : '');
        } else {
          document.getElementById('planProfitSub').textContent = p.isCurrent ? 'davomida' : '';
        }

        // Forecast — qiymat + rang holati
        document.getElementById('planForecastVal').textContent = fmtMoney(p.forecast) + " so'm";
        var fcard = document.getElementById('planForecastCard');
        var fstate = 'none';
        if (p.target > 0) {
          if (!p.isCurrent && !p.isPast) {
            fstate = 'none'; // kelajak — neutral
          } else {
            var ratio = p.forecast / p.target;
            if (ratio >= 1.0) fstate = 'green';
            else if (ratio >= 0.9) fstate = 'yellow';
            else fstate = 'red';
          }
        }
        if (fstate === 'none') fcard.removeAttribute('data-state');
        else fcard.setAttribute('data-state', fstate);

        if (p.target > 0 && p.forecast > 0) {
          var fpct = Math.round((p.forecast / p.target) * 100);
          var fdiff = p.forecast - p.target;
          var fsign = fdiff >= 0 ? '+' : '−';
          document.getElementById('planForecastSub').textContent = "rejaning " + fpct + '% · ' + fsign + fmtMoney(Math.abs(fdiff));
        } else if (p.isPast) {
          document.getElementById('planForecastSub').textContent = 'yakun';
        } else {
          document.getElementById('planForecastSub').textContent = p.isCurrent ? 'kunlik o\'rtachadan' : '—';
        }

        // Signal
        var sigEl = document.getElementById('planSignal');
        var sigTxt = document.getElementById('planSignalText');
        sigEl.dataset.signal = p.signal;
        if (!p.target || p.target <= 0) {
          sigTxt.textContent = 'Reja kiritilmagan';
        } else if (p.isPast) {
          var done = p.profitToDate >= p.target;
          sigEl.dataset.signal = done ? 'green' : 'red';
          sigTxt.textContent = done
            ? "Reja bajarildi (" + Math.round(p.profitToDate / p.target * 100) + '%)'
            : "Reja bajarilmadi (" + Math.round(p.profitToDate / p.target * 100) + '%)';
        } else if (!p.isCurrent && p.dayToday === 0) {
          sigEl.dataset.signal = 'none';
          sigTxt.textContent = 'Kelajak oy — kuzatish boshlanmagan';
        } else if (p.signal === 'green') {
          sigTxt.textContent = "Reja bo'yicha ketyapti — prognoz reja ustida";
        } else if (p.signal === 'yellow') {
          sigTxt.textContent = "Yaqin chiqyapti — biroz tezlashtirish kerak";
        } else {
          sigTxt.textContent = "Rejadan orqada qolyapti";
        }

        // Tavsiya (faqat reja yo'q yoki kelajak oy uchun)
        var tipEl = document.getElementById('planTip');
        var tipTxt = document.getElementById('planTipText');
        var tipApply = document.getElementById('planTipApply');
        if (p.suggested > 0 && (!p.target || p.target <= 0)) {
          tipEl.hidden = false;
          tipApply.hidden = false;
          tipTxt.innerHTML = "Tavsiya: <b>" + fmtMoney(p.suggested) + " so'm</b> (o'tgan oydan +30% — "
            + fmtMonthName(p.prevMonth) + ' foydasi ' + fmtMoney(p.prevProfit) + " so'm)";
        } else {
          tipEl.hidden = true;
          tipApply.hidden = true;
        }

        // Kunlik info
        var info = '';
        if (p.target > 0) {
          info += 'Kunlik o\'rtacha kerakli: <b>' + fmtMoney(p.dailyTargetAvg) + " so'm</b>";
          if (p.isCurrent) {
            if (p.profitToDate >= p.target) {
              info += ' · Reja allaqachon bajarilgan ✓';
            } else if (p.daysRemaining > 0 && p.dailyPaceNeeded > 0) {
              info += ' · Bugundan boshlab har kuni <b>' + fmtMoney(p.dailyPaceNeeded) + " so'm</b> bo'lsa, reja bajariladi";
            } else if (p.daysRemaining === 0) {
              info += ' · Oyning oxirgi kuni';
            }
          }
        } else {
          info = "Reja kiritilsa, kunlik o'rtacha va kerakli pace ko'rsatiladi";
        }
        document.getElementById('planDailyInfo').innerHTML = info;

        // Bars
        renderPlanBars(p);

        // Kunlik kerakli — katta blok
        renderPlanNeeded(p);

        // Salyut: armed bo'lsa va prognoz reja ustida bo'lsa
        if (planConfettiArmed && p.target > 0 && (p.signal === 'green' || (p.isPast && p.profitToDate >= p.target))) {
          planConfettiArmed = false;
          setTimeout(launchSalyut, 250);
        } else if (planConfettiArmed && (p.signal === 'yellow' || p.signal === 'red')) {
          // Armed bo'lsa-da, yashil emas — disarm (toza holatga keltiramiz)
          planConfettiArmed = false;
        }

        // Hide edit if open
        planCloseEdit();
      }

      function renderPlanNeeded(p) {
        var box = document.getElementById('planNeeded');
        var valEl = document.getElementById('planNeededVal');
        var labEl = document.getElementById('planNeededLabel');
        var subEl = document.getElementById('planNeededSub');

        if (!p.target || p.target <= 0) {
          box.hidden = true;
          return;
        }
        box.hidden = false;

        if (p.isPast) {
          // O'tgan oy — yakuniy kunlik o'rtacha vs nishon
          labEl.textContent = "Yakuniy kunlik o'rtacha";
          valEl.textContent = fmtMoney(p.dailyAvg) + " so'm";
          var diff = p.dailyAvg - p.dailyTargetAvg;
          var ratio = p.dailyTargetAvg > 0 ? p.dailyAvg / p.dailyTargetAvg : 0;
          var state = 'red';
          if (ratio >= 1.0) state = 'green';
          else if (ratio >= 0.9) state = 'yellow';
          box.setAttribute('data-state', state);
          subEl.innerHTML = "Nishon: <b>" + fmtMoney(p.dailyTargetAvg) + " so'm/kun</b> · "
            + (diff >= 0 ? '+' : '−') + fmtMoney(Math.abs(diff)) + " so'm";
          return;
        }

        if (!p.isCurrent && !p.isPast) {
          // Kelajak — rejalashtirilgan kunlik o'rtacha
          labEl.textContent = "Kunlik o'rtacha (rejaga ko'ra)";
          valEl.textContent = fmtMoney(p.dailyTargetAvg) + " so'm";
          box.setAttribute('data-state', 'none');
          subEl.innerHTML = "Oy boshlangach, bugungi kerakli summa shu yerda ko'rsatiladi";
          return;
        }

        // Joriy oy — reja allaqachon bajarilganmi?
        if (p.profitToDate >= p.target) {
          labEl.textContent = "Reja bajarildi 🎉";
          var pctDone = Math.round((p.profitToDate / p.target) * 100);
          valEl.textContent = pctDone + '%';
          box.setAttribute('data-state', 'green');
          subEl.innerHTML = "Hozirgi foyda: <b>" + fmtMoney(p.profitToDate) + " so'm</b> · Reja: <b>" + fmtMoney(p.target) + " so'm</b>";
          return;
        }

        if (p.todayNeeded <= 0) {
          // Kechagacha allaqachon temp ustida — bugun shart emas
          labEl.textContent = "Bugun shart emas — tempdan oldindasiz";
          valEl.textContent = "0 so'm";
          box.setAttribute('data-state', 'green');
          subEl.innerHTML = "Bugungi joriy: <b>" + fmtMoney(p.todayProfit) + " so'm</b> · bonus";
          return;
        }

        labEl.textContent = "Bugun shuncha bo'lsa, prognoz rejaga to'g'ri keladi";
        valEl.textContent = fmtMoney(p.todayNeeded) + " so'm";

        // Rang: bugungi joriy (todayProfit) vs kerakli (todayNeeded)
        var ratio = p.todayProfit / p.todayNeeded;
        var pstate = 'red';
        if (ratio >= 1.0) pstate = 'green';
        else if (ratio >= 0.9) pstate = 'yellow';
        box.setAttribute('data-state', pstate);

        var pct = Math.round(ratio * 100);
        var remaining = Math.max(0, p.todayNeeded - p.todayProfit);
        subEl.innerHTML = "Bugun hozir: <b>" + fmtMoney(p.todayProfit) + " so'm</b> (" + pct + "%) · qoldi <b>" + fmtMoney(remaining) + " so'm</b>";
      }

      function renderPlanBars(p) {
        var container = document.getElementById('planBars');
        // Maksimumni topish (scaling uchun)
        var maxVal = 1;
        p.breakdown.forEach(function(b) { if (b.profit > maxVal) maxVal = b.profit; });
        if (p.dailyTargetAvg > maxVal) maxVal = p.dailyTargetAvg;

        var todayDay = p.isCurrent ? p.dayToday : -1;
        var html = '';
        p.breakdown.forEach(function(b) {
          var h = Math.round((b.profit / maxVal) * 100);
          if (h < 2 && !b.future) h = 2;
          var state;
          if (b.future) state = 'future';
          else if (b.profit === 0) state = 'zero';
          else if (p.dailyTargetAvg > 0 && b.profit >= p.dailyTargetAvg) state = 'over';
          else state = 'under';
          var isToday = b.day === todayDay ? '1' : '0';
          var tipLabel = b.day + '-kun: ' + fmtMoney(b.profit) + " so'm";
          html += '<div class="pd-bar" style="height:' + (b.future ? 100 : Math.max(h, 2)) + '%"'
                + ' data-state="' + state + '" data-today="' + isToday + '">'
                + '<span class="pd-tip">' + tipLabel + '</span></div>';
        });
        container.innerHTML = html;
        // Grid columns soni oydagi kun soniga moslab
        container.style.gridTemplateColumns = 'repeat(' + p.totalDays + ', 1fr)';
      }

      function planOpenEdit() {
        var box = document.getElementById('planEdit');
        box.hidden = false;
        var inp = document.getElementById('planInput');
        if (planState && planState.target > 0) {
          inp.value = planState.target.toLocaleString('en-US');
        } else {
          inp.value = '';
        }
        inp.focus();
      }

      function planCloseEdit() {
        document.getElementById('planEdit').hidden = true;
        var msg = document.getElementById('planMsg');
        msg.textContent = '';
        msg.className = 'pe-msg';
      }

      function planApplySuggested() {
        if (!planState || !planState.suggested) return;
        planOpenEdit();
        document.getElementById('planInput').value = planState.suggested.toLocaleString('en-US');
      }

      async function planSave() {
        var msg = document.getElementById('planMsg');
        msg.textContent = '';
        msg.className = 'pe-msg';
        var raw = document.getElementById('planInput').value.replace(/\D/g, '');
        var target = parseInt(raw, 10);
        if (!target || target <= 0) {
          msg.textContent = "Reja noto'g'ri";
          msg.classList.add('err');
          return;
        }
        try {
          var res = await fetch('/api/plan', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'set', month: planSelectedMonth, target: target }),
          });
          var data = await res.json();
          if (!res.ok || data.error) {
            msg.textContent = data.error || ('Xato: ' + res.status);
            msg.classList.add('err');
            return;
          }
          msg.textContent = 'Saqlandi';
          msg.classList.add('ok');
          planConfettiArmed = true; // saqlangach yashil bo'lsa salyut
          fetchPlan();
        } catch (e) {
          msg.textContent = 'Tarmoq xatosi';
          msg.classList.add('err');
        }
      }

      async function planDelete() {
        if (!confirm("Bu oy uchun rejani o'chirasizmi?")) return;
        try {
          var res = await fetch('/api/plan', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'delete', month: planSelectedMonth }),
          });
          var data = await res.json();
          if (!res.ok || data.error) {
            alert(data.error || ('Xato: ' + res.status));
            return;
          }
          fetchPlan();
        } catch (e) {
          alert('Tarmoq xatosi');
        }
      }

      async function changePassword() {
        const msg = document.getElementById('passMsg');
        const current = document.getElementById('currentPass').value;
        const newP = document.getElementById('newPass').value;
        const confirm = document.getElementById('confirmPass').value;
        if (newP !== confirm) {
          msg.className = 'form-msg err'; msg.textContent = 'Parollar mos kelmaydi'; return;
        }
        try {
          const res = await fetch('/api/stats', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'change_password', current: current, newPass: newP }),
          });
          const data = await res.json();
          if (data.ok) {
            msg.className = 'form-msg ok'; msg.textContent = 'Parol o\'zgartirildi';
            document.getElementById('currentPass').value = '';
            document.getElementById('newPass').value = '';
            document.getElementById('confirmPass').value = '';
          } else {
            msg.className = 'form-msg err'; msg.textContent = data.error || 'Xatolik';
          }
        } catch {
          msg.className = 'form-msg err'; msg.textContent = 'Server xatoligi';
        }
      }

      // Detect horizontal scroll on panel-body elements for fade hint
      function checkScrollHints() {
        document.querySelectorAll('.panel-body').forEach(el => {
          el.classList.toggle('has-scroll', el.scrollWidth > el.clientWidth + 4);
          el.addEventListener('scroll', function() {
            this.classList.toggle('has-scroll', this.scrollLeft < this.scrollWidth - this.clientWidth - 4);
          }, { passive: true });
        });
      }

      var _origRenderAll = renderAll;
      renderAll = function() { _origRenderAll(); setTimeout(checkScrollHints, 50); };

      // ───── MOBILE QUICK STATS (mobile-only hero) ─────
      function isMobileView() { return window.innerWidth <= 640; }

      var mqsPeriodLabels = {
        yesterday: 'Kechagi', today: 'Bugungi', week: 'Haftalik', month: 'Oylik',
        '3months': '3 oylik', '6months': '6 oylik', '12months': 'Yillik'
      };

      function mqsCalcProfit(ov) {
        if (!ov) return 0;
        var starsProfit = Math.round((ov.starsRevenue || 0) * 0.12);
        var giftProfit = Math.round((ov.giftRevenue || 0) * 0.12);
        var premiumProfit = Math.round((ov.premiumRevenue || 0) * 0.10);
        var psProfit = Math.round((ov.psRevenue || 0) * 0.10);
        var p112Profit = ((ov.p112OneCount || 0) * 18000) + ((ov.p112TwelveCount || 0) * 48000);
        return starsProfit + giftProfit + premiumProfit + psProfit + p112Profit;
      }

      function renderMobileQuickStats() {
        var box = document.getElementById('mobileQuickStats');
        if (!box) return;
        var allowed = (currentSection === 'overview' || currentSection === 'profit');
        if (!isMobileView() || !allowed) {
          box.hidden = true;
          box.style.display = 'none';
          return;
        }
        box.hidden = false;
        box.style.display = '';

        var label = mqsPeriodLabels[currentPeriod] || (currentMonth ? 'Oylik' : 'Bugungi');
        var ov = statsData && statsData.orders && statsData.orders.overview;
        var profit = mqsCalcProfit(ov);
        var orders = ov ? (ov.totalOrders || 0) : 0;

        var todayLabel = document.getElementById('mqsTodayLabel');
        var ordersLabel = document.getElementById('mqsOrdersLabel');
        if (todayLabel) todayLabel.textContent = label + ' foyda';
        if (ordersLabel) ordersLabel.textContent = label + ' buyurtmalar';
        document.getElementById('mqsTodayProfit').textContent = fmtMoney(profit) + " so'm";
        document.getElementById('mqsTodayOrders').textContent = orders + ' ta';
      }

      async function fetchMqsYesterday() {
        if (!isMobileView()) return;
        var now = new Date();
        var tz = new Date(now.getTime() + 5 * 60 * 60 * 1000);
        var yest = new Date(Date.UTC(tz.getUTCFullYear(), tz.getUTCMonth(), tz.getUTCDate() - 1));
        var ys = yest.getUTCFullYear() + '-' + String(yest.getUTCMonth() + 1).padStart(2, '0') + '-' + String(yest.getUTCDate()).padStart(2, '0');
        try {
          var res = await fetch('/api/stats?salesFrom=' + ys + '&salesTo=' + ys + '&source=all');
          if (res.status === 401) { location.reload(); return; }
          var data = await res.json();
          var ov = data.orders && data.orders.overview;
          var el = document.getElementById('mqsYdayProfit');
          if (el) el.textContent = fmtMoney(mqsCalcProfit(ov)) + " so'm";
        } catch (e) { console.error('MQS yesterday error:', e); }
      }

      window.addEventListener('resize', function() {
        renderMobileQuickStats();
      });

      initMonthFilters();
      // Mobile default — Maosh; desktop default — Umumiy
      showSection(isMobileView() ? 'salary' : 'overview');
      fetchStats();
      fetchMqsYesterday();
      setInterval(fetchStats, 30000);
      setInterval(fetchMqsYesterday, 60000);
    </script>
  )}
</body>
</html>
