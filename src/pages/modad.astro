          </div>
          <div class="stat-card">
            <div class="sc-label">👑 Premium</div>
            <div class="sc-value">${ov.premiumTotalMonths} oy</div>
            <div class="sc-sub"><span class="sc-green">${fmtMoney(ov.premiumRevenue)} so'm</span><span class="sc-divider"></span><span>${ov.premiumCount} ta sotildi</span></div>
          </div>
        `;

        var rows = o.recent;
        if (!rows.length) {
