      function renderDailyStars() {
        var o = statsData.orders;
        // For premium_send va premium_1_12, show daily months instead of stars
        if (currentSource === 'premium_send' || currentSource === 'premium_1_12') {
          if (!o || !o.dailyMonths || !o.dailyMonths.length) {
            document.getElementById('dailyStars').innerHTML = '<div class="empty">Ma\'lumot yo\'q</div>';
            return;
          }
          var max = Math.max(...o.dailyMonths.map(d => d.totalMonths));
          document.getElementById('dailyStars').innerHTML = o.dailyMonths.map(d => {
            var pct = max > 0 ? Math.max((d.totalMonths / max) * 100, 4) : 4;
            var dateStr = new Date(d.date).toLocaleDateString('uz', { day: '2-digit', month: '2-digit' });
            return '<div class="dr-row">' +
              '<div class="dr-date">' + dateStr + '</div>' +
              '<div class="dr-bar-bg"><div class="dr-bar" style="width:' + pct + '%;background:linear-gradient(90deg,#3b82f6,#60a5fa)"></div></div>' +
              '<div class="dr-info"><span class="dr-amount">📤 ' + d.totalMonths + ' oy</span><span class="dr-orders"> (' + d.orders + ')</span></div>' +
            '</div>';
          }).join('');
          return;
        }
        if (!o || !o.dailyStars || !o.dailyStars.length) {
          document.getElementById('dailyStars').innerHTML = '<div class="empty">Ma\'lumot yo\'q</div>';
          return;
        }
        var max = Math.max(...o.dailyStars.map(d => d.totalStars));
        document.getElementById('dailyStars').innerHTML = o.dailyStars.map(d => {
          var pct = max > 0 ? Math.max((d.totalStars / max) * 100, 4) : 4;
          var dateStr = new Date(d.date).toLocaleDateString('uz', { day: '2-digit', month: '2-digit' });
          return '<div class="dr-row">' +
            '<div class="dr-date">' + dateStr + '</div>' +
            '<div class="dr-bar-bg"><div class="dr-bar" style="width:' + pct + '%;background:linear-gradient(90deg,#facc15,#f59e0b)"></div></div>' +
            '<div class="dr-info"><span class="dr-amount">⭐ ' + fmtMoney(d.totalStars) + '</span><span class="dr-orders"> (' + d.orders + ')</span></div>' +
          '</div>';
        }).join('');
      }

      function renderDailyRevenue() {
        var o = statsData.orders;
        if (!o || !o.daily.length) {
          document.getElementById('dailyRevenue').innerHTML = '<div class="empty">Ma\'lumot yo\'q</div>';
          return;
        }
        var max = Math.max(...o.daily.map(d => d.revenue));
        document.getElementById('dailyRevenue').innerHTML = o.daily.map(d => {
          var pct = max > 0 ? Math.max((d.revenue / max) * 100, 4) : 4;
          var dateStr = new Date(d.date).toLocaleDateString('uz', { day: '2-digit', month: '2-digit' });
