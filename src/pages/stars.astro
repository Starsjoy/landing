---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = "Telegram Stars Sotib Olish — Arzon Narxda | StarsJoy";
const description = "Telegram stars sotib olish eng arzon narxlarda. Telegram yulduzchalar narxlari, tez yetkazish va 100% kafolat bilan. StarsJoy orqali telegramda stars oling.";

const faqs = [
  {
    q: "Telegram Stars nima?",
    a: "Telegram Stars — bu Telegramning ichki valyutasi bo'lib, kanallar, botlar va kontentga to'lov qilish uchun ishlatiladi. Stars yordamida premium kontent sotib olish, kanallarni qo'llab-quvvatlash va botlardagi xizmatlardan foydalanish mumkin."
  },
  {
    q: "Telegram Stars sotib olish narxlari qancha?",
    a: "StarsJoy orqali Telegram Stars eng arzon narxlarda sotib olish mumkin. Narxlar 50 Stars dan boshlanadi. Ko'proq Stars xarid qilsangiz, har bir yulduz narxi arzonroq bo'ladi. Aniq narxlarni botimizda ko'rishingiz mumkin."
  },
  {
    q: "Telegram yulduzchalar qanday sotib olinadi?",
    a: "1) @starsjoybot ga kiring, 2) Stars miqdorini tanlang, 3) Click yoki karta orqali to'lang, 4) 1-5 daqiqada Stars hisobingizga tushadi. Juda oddiy va tez jarayon!"
  },
  {
    q: "Stars sotib olgandan keyin qancha vaqtda keladi?",
    a: "To'lov tasdiqlangandan so'ng 1-5 daqiqa ichida Telegram Stars hisobingizga tushadi. Agar 5 daqiqadan oshsa, 10 Stars cashback beramiz."
  },
  {
    q: "Telegramda Stars bilan nima qilish mumkin?",
    a: "Stars bilan kanallarning premium kontentiga obuna bo'lish, botlardagi pullik xizmatlardan foydalanish, kontentmeykerlarni qo'llab-quvvatlash va Telegram ichidagi turli xaridlarni amalga oshirish mumkin."
  },
  {
    q: "Telegram Stars xavfsiz sotib olish mumkinmi?",
    a: "Ha, StarsJoy orqali sotib olish 100% xavfsiz. Biz rasmiy usullardan foydalanamiz, to'liq pul qaytarish kafolatini beramiz va minglab mamnun mijozlarga xizmat ko'rsatganmiz."
  }
];
---

<Layout
  title={title}
  description={description}
  canonical="https://starsjoy.uz/stars"
  keywords="Telegram stars sotib olish, Telegram yulduzchalar sotib olish, Telegram stars narxlari, telegramda stars olish, Telegram yulduz sotib olish, StarsJoy stars, Telegram Stars arzon"
>
  <Navbar />

  <!-- SEO Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Telegram Stars",
    "description": description,
    "brand": { "@type": "Brand", "name": "StarsJoy" },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "UZS",
      "availability": "https://schema.org/InStock",
      "offerCount": "10+"
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Bosh sahifa", "item": "https://starsjoy.uz" },
      { "@type": "ListItem", "position": 2, "name": "Telegram Stars Sotib Olish", "item": "https://starsjoy.uz/stars" }
    ]
  })} />

  <!-- Hero -->
  <section class="stars-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Bosh sahifa</a>
        <span>/</span>
        <span>Telegram Stars</span>
      </nav>
      <div class="stars-hero-inner fade-in">
        <div class="stars-hero-content">
          <h1 class="stars-title">Telegram Stars Sotib Olish — Eng Arzon Narxlarda</h1>
          <p class="stars-desc">
            Telegram yulduzchalar sotib olish endi juda oson! StarsJoy orqali telegramda stars oling — tez yetkazish, arzon narxlar va 100% kafolat bilan.
          </p>
          <div class="stars-features">
            <div class="stars-feature">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2.5 5 5.5.8-4 3.9 1 5.4L10 14.4l-4.9 2.7 1-5.4-4-3.9 5.5-.8L10 2z" fill="#FBBF24" stroke="#D97706" stroke-width="1"/></svg>
              <span>1-5 daqiqada yetkazish</span>
            </div>
            <div class="stars-feature">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="5" y="9" width="10" height="9" rx="2" stroke="#7C3AED" stroke-width="1.5"/><path d="M7.5 9V7a2.5 2.5 0 1 1 5 0v2" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span>100% kafolat</span>
            </div>
            <div class="stars-feature">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="#10B981" stroke-width="1.5"/><path d="M10 7v6M7 10h6" stroke="#10B981" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span>Eng arzon narxlar</span>
            </div>
          </div>
          <a href="https://t.me/starsjoybot" class="btn-primary" target="_blank">
            &#9889; Hozir Stars Sotib Olish
          </a>
        </div>
        <div class="stars-hero-visual">
          <div class="stars-icon-big">
            <svg width="80" height="80" viewBox="0 0 52 52" fill="none">
              <defs>
                <linearGradient id="stG" x1="6" y1="6" x2="46" y2="46">
                  <stop offset="0%" stop-color="#FFD60A"/>
                  <stop offset="50%" stop-color="#FFAE00"/>
                  <stop offset="100%" stop-color="#FF9500"/>
                </linearGradient>
              </defs>
              <path d="M26 4l6.2 12.5L45 18.8l-9.5 9.3 2.2 13.1L26 34.8l-11.7 6.4 2.2-13.1L7 18.8l12.8-2.3L26 4z" fill="url(#stG)"/>
              <path d="M26 4l6.2 12.5L45 18.8l-9.5 9.3 2.2 13.1L26 34.8V4z" fill="#FFE066" opacity="0.35"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Nima uchun Stars kerak -->
  <section class="stars-why">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Telegram Stars</span>
        <h2 class="section-title">Telegram yulduzchalar nima uchun kerak?</h2>
        <p class="section-subtitle">Stars — Telegramning ichki valyutasi bo'lib, ko'plab imkoniyatlarni ochib beradi</p>
      </div>
      <div class="why-grid">
        <div class="why-card fade-in">
          <div class="why-icon wi-content">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="4" width="20" height="20" rx="4" stroke="currentColor" stroke-width="2"/><path d="M10 12h8M10 16h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3>Premium kontent</h3>
          <p>Kanallardagi maxfiy postlar va premium kontentga kirish uchun Stars ishlatiladi</p>
        </div>
        <div class="why-card fade-in">
          <div class="why-icon wi-bot">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="5" y="3" width="18" height="22" rx="4" stroke="currentColor" stroke-width="2"/><circle cx="14" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M14 9V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="20" x2="17" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3>Bot xizmatlari</h3>
          <p>Botlardagi pullik funksiyalar va xizmatlar uchun Stars bilan to'lov qiling</p>
        </div>
        <div class="why-card fade-in">
          <div class="why-icon wi-support">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 4l3 6 6.6 1-4.8 4.6 1.1 6.6L14 19l-5.9 3.2 1.1-6.6L4.4 11l6.6-1L14 4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          </div>
          <h3>Qo'llab-quvvatlash</h3>
          <p>Sevimli kontentmeykerlaringizni Stars yuborish orqali qo'llab-quvvatlang</p>
        </div>
        <div class="why-card fade-in">
          <div class="why-icon wi-gift">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="5" y="13" width="18" height="11" rx="3" stroke="currentColor" stroke-width="2"/><rect x="7" y="8" width="14" height="6" rx="2" stroke="currentColor" stroke-width="2"/><rect x="12.5" y="8" width="3" height="16" rx="1" fill="currentColor" opacity="0.2"/></svg>
          </div>
          <h3>Sovg'a sifatida</h3>
          <p>Do'stlaringizga Stars sovg'a qiling — Telegram ichida eng yaxshi hadya</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Qanday sotib olish -->
  <section class="stars-how">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Qo'llanma</span>
        <h2 class="section-title">Telegram Stars qanday sotib olinadi?</h2>
        <p class="section-subtitle">Atigi 3 qadam — 5 daqiqada Stars hisobingizda</p>
      </div>
      <div class="how-steps">
        <div class="how-step fade-in">
          <div class="how-step-num">1</div>
          <h3>Botga kiring</h3>
          <p>Telegramda <strong>@starsjoybot</strong> ga kiring va "Stars sotib olish" tugmasini bosing</p>
        </div>
        <div class="how-step fade-in">
          <div class="how-step-num">2</div>
          <h3>Miqdorni tanlang</h3>
          <p>Kerakli Stars miqdorini tanlang va Click yoki karta orqali to'lovni amalga oshiring</p>
        </div>
        <div class="how-step fade-in">
          <div class="how-step-num">3</div>
          <h3>Stars qabul qiling</h3>
          <p>1-5 daqiqa ichida Telegram Stars hisobingizga tushadi. Tayyor!</p>
        </div>
      </div>
      <div class="how-cta fade-in">
        <a href="https://t.me/starsjoybot" class="btn-primary" target="_blank">&#9889; Hozir Boshlash</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="stars-faq">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">FAQ</span>
        <h2 class="section-title">Telegram Stars haqida savollar</h2>
        <p class="section-subtitle">Stars sotib olish bo'yicha eng ko'p beriladigan savollar</p>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <div class="faq-item fade-in">
            <button class="faq-question">
              <span>{faq.q}</span>
              <span class="faq-toggle">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">{faq.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="stars-cta">
    <div class="container">
      <div class="stars-cta-box fade-in">
        <h2>Telegram Stars sotib olishga tayyormisiz?</h2>
        <p>Eng arzon narxlar, tez yetkazish va 100% kafolat bilan</p>
        <a href="https://t.me/starsjoybot" class="btn-white" target="_blank">&#9889; Stars Sotib Olish</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<!-- FAQ Script -->
<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement!;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const isActive = item.classList.contains('active');
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('active');
        (i.querySelector('.faq-answer') as HTMLElement).style.maxHeight = '';
      });
      if (!isActive) {
        item.classList.add('active');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });
</script>

<style>
  /* ===== HERO ===== */
  .stars-hero {
    padding: 120px 24px 80px;
    background: linear-gradient(180deg, #FFFBEB 0%, #FFFFFF 100%);
    position: relative;
    overflow: hidden;
  }
  .stars-hero::before {
    content: '';
    position: absolute;
    top: -150px; right: -150px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(255, 174, 0, 0.08), transparent 70%);
    pointer-events: none;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 32px;
  }
  .breadcrumb a { color: var(--primary); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .stars-hero-inner {
    display: flex;
    align-items: center;
    gap: 60px;
  }
  .stars-hero-content { flex: 1; }
  .stars-hero-visual {
    flex: 0 0 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stars-title {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 20px;
    color: var(--text);
  }
  .stars-desc {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 28px;
    max-width: 540px;
  }

  .stars-features {
    display: flex;
    gap: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .stars-feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text);
  }

  .stars-icon-big {
    width: 160px;
    height: 160px;
    background: linear-gradient(135deg, #FFF8E1, #FFE082);
    border-radius: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 16px 48px rgba(255, 174, 0, 0.2);
  }

  /* ===== WHY ===== */
  .stars-why { background: var(--bg-alt); }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .why-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 24px;
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .why-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .why-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
  }
  .why-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .why-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wi-content { background: rgba(255, 174, 0, 0.1); color: #D97706; }
  .wi-bot { background: rgba(124, 58, 237, 0.08); color: #7C3AED; }
  .wi-support { background: rgba(37, 99, 235, 0.08); color: #2563EB; }
  .wi-gift { background: rgba(16, 185, 129, 0.08); color: #10B981; }

  /* ===== HOW ===== */
  .how-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 40px;
  }
  .how-step {
    text-align: center;
    padding: 32px 24px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .how-step h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
  }
  .how-step p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .how-step-num {
    width: 48px;
    height: 48px;
    margin: 0 auto 16px;
    background: var(--gradient);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.2rem;
    color: #fff;
  }
  .how-cta { text-align: center; }

  /* ===== FAQ ===== */
  .stars-faq { background: var(--bg-alt); }
  .faq-list {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-item {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .faq-item.active {
    border-color: rgba(124, 58, 237, 0.3);
    box-shadow: 0 4px 16px rgba(124, 58, 237, 0.08);
  }
  .faq-question {
    width: 100%;
    padding: 20px 24px;
    background: none;
    border: none;
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-family: inherit;
  }
  .faq-question:hover { color: var(--primary); }
  .faq-toggle {
    width: 28px; height: 28px; min-width: 28px;
    border-radius: 8px;
    background: rgba(124, 58, 237, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--primary);
    transition: transform 0.3s;
  }
  .faq-item.active .faq-toggle { transform: rotate(45deg); }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-answer-inner {
    padding: 0 24px 20px;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* ===== CTA ===== */
  .stars-cta-box {
    background: var(--gradient);
    border-radius: 24px;
    padding: 60px 40px;
    text-align: center;
    color: #fff;
  }
  .stars-cta-box h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  .stars-cta-box p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 28px;
  }
  .btn-white {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 36px;
    background: #fff;
    color: #5B21B6;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .stars-hero-inner { flex-direction: column; text-align: center; }
    .stars-hero-visual { flex: none; }
    .stars-desc { margin: 0 auto 28px; }
    .stars-features { justify-content: center; }
    .why-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .stars-hero { padding: 100px 16px 60px; }
    .stars-title { font-size: 2rem; }
    .stars-desc { font-size: 1rem; }
    .stars-features { flex-direction: column; align-items: center; gap: 12px; }
    .stars-icon-big { width: 120px; height: 120px; border-radius: 28px; }
    .stars-icon-big svg { width: 60px; height: 60px; }
    .why-grid { grid-template-columns: 1fr; }
    .how-steps { grid-template-columns: 1fr; gap: 16px; }
    .stars-cta-box { padding: 40px 24px; }
    .stars-cta-box h2 { font-size: 1.5rem; }
  }
</style>
