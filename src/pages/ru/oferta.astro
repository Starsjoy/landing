---
import Layout from '../../layouts/Layout.astro';
import NavbarRu from '../../components/NavbarRu.astro';
import Footer from '../../components/Footer.astro';

const title = "Публичная Оферта | StarsJoy";
const description = "Публичная оферта StarsJoy — условия предоставления услуг, порядок оплаты, политика возврата и обязанности пользователей. Telegram Stars, Premium и Gifts в Узбекистане.";
---

<Layout
  title={title}
  description={description}
  canonical="https://starsjoy.uz/ru/oferta"
  keywords="StarsJoy оферта, StarsJoy договор, StarsJoy условия, StarsJoy возврат, StarsJoy refund, купить Telegram Stars"
  lang="ru"
  hreflangs={[
    { lang: "uz", href: "https://starsjoy.uz/oferta" },
    { lang: "ru", href: "https://starsjoy.uz/ru/oferta" }
  ]}
>
  <NavbarRu />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://starsjoy.uz/ru" },
      { "@type": "ListItem", "position": 2, "name": "Публичная Оферта", "item": "https://starsjoy.uz/ru/oferta" }
    ]
  })} />

  <section class="offerta-hero">
    <div class="container">
      <div class="offerta-hero-content">
        <nav class="breadcrumb">
          <a href="/ru">Главная</a>
          <span>/</span>
          <span>Публичная Оферта</span>
        </nav>
        <h1 class="offerta-title">Публичная Оферта</h1>
        <p class="offerta-meta">StarsJoy &middot; starsjoy.uz &middot; @starsjoybot</p>
        <p class="offerta-meta">Дата вступления в силу: 5 марта 2026 г.</p>
      </div>
    </div>
  </section>

  <!-- § 1 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 1. Общие положения</h2>
        <p><strong>1.1.</strong> Настоящий документ является публичной офертой StarsJoy (далее — «Исполнитель»), определяющей условия приобретения цифровых продуктов.</p>
        <p><strong>1.2.</strong> Исполнитель осуществляет деятельность через сайт starsjoy.uz и Telegram-бот @starsjoybot.</p>
        <p><strong>1.3.</strong> Оформление заказа через бот означает полное и безоговорочное принятие (акцепт) условий настоящей оферты.</p>
        <p><strong>1.4.</strong> Исполнитель действует в соответствии с законодательством Республики Узбекистан.</p>
      </div>
    </div>
  </section>

  <!-- § 2 -->
  <section class="offerta-section offerta-alt">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 2. Предоставляемые услуги</h2>
        <p><strong>2.1.</strong> Исполнитель предоставляет следующие цифровые услуги:</p>
        <ul>
          <li><strong>Telegram Stars</strong> — приобретение официальных платёжных единиц Telegram;</li>
          <li><strong>Telegram Premium</strong> — активация подписки Telegram Premium;</li>
          <li><strong>Telegram Gifts</strong> — отправка подарков через Telegram.</li>
        </ul>
        <p><strong>2.2.</strong> Все продукты доставляются в цифровом виде непосредственно на ваш Telegram-аккаунт.</p>
        <p><strong>2.3.</strong> Исполнитель работает через официальный API Telegram и Fragment. StarsJoy является независимым реселлером.</p>
      </div>
    </div>
  </section>

  <!-- § 3 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 3. Порядок заказа и оплаты</h2>
        <p><strong>3.1.</strong> Заказ оформляется через @starsjoybot в соответствии с инструкциями бота.</p>
        <p><strong>3.2.</strong> Оплата принимается следующими способами: Click, пластиковые карты Uzcard и Humo.</p>
        <p><strong>3.3.</strong> После успешной оплаты заказ выполняется в течение 5 минут.</p>
        <p><strong>3.4.</strong> Цены указаны в узбекских сумах. Стоимость определяется на основе текущего курса и тарифов на момент заказа.</p>
        <p><strong>3.5.</strong> Исполнитель оставляет за собой право изменять цены без предварительного уведомления.</p>
      </div>
    </div>
  </section>

  <!-- § 4 -->
  <section class="offerta-section offerta-alt">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 4. Условия оказания услуг</h2>
        <p><strong>4.1.</strong> Исполнитель не несёт ответственности за проблемы, вызванные неправильным указанием Telegram username или ID.</p>
        <p><strong>4.2.</strong> Исполнитель не несёт ответственности за технические сбои платформы Telegram, изменение правил Telegram или блокировку аккаунта.</p>
        <p><strong>4.3.</strong> Пользователь обязан убедиться, что на его Telegram-аккаунте включена возможность получения Stars. В противном случае заказ может быть не выполнен.</p>
      </div>
    </div>
  </section>

  <!-- § 5 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 5. Политика возврата (refund)</h2>
        <p><strong>5.1.</strong> Цифровые продукты после доставки возврату не подлежат.</p>
        <p><strong>5.2.</strong> Если оплата прошла успешно, но заказ не был выполнен по техническим причинам, пользователь имеет право на полный возврат средств.</p>
        <p><strong>5.3.</strong> Запрос на возврат должен быть направлен в течение 24 часов с момента оплаты через @starsjoy_bot (бот поддержки). Необходимо приложить скриншот или подтверждение платежа.</p>
        <p><strong>5.4.</strong> Если заказ был доставлен другому лицу из-за неправильно указанных данных Telegram, возврат не осуществляется.</p>
        <p><strong>5.5.</strong> Если пользователь добровольно отказался от услуги после её выполнения, возврат не рассматривается.</p>
      </div>
    </div>
  </section>

  <!-- § 6 -->
  <section class="offerta-section offerta-alt">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 6. Обязанности пользователя</h2>
        <p><strong>6.1.</strong> Пользователь обязан использовать сервис исключительно в законных целях.</p>
        <p><strong>6.2.</strong> Использование сервиса в целях мошенничества, спама или причинения вреда другим строго запрещено. Такие пользователи будут заблокированы.</p>
        <p><strong>6.3.</strong> Пользователь обязуется соблюдать Условия использования платформы Telegram.</p>
      </div>
    </div>
  </section>

  <!-- § 7 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 7. Служба поддержки</h2>
        <p><strong>7.1.</strong> Все обращения и вопросы принимаются исключительно через @starsjoy_bot (бот поддержки).</p>
        <p><strong>7.2.</strong> Ответ на обращения предоставляется в течение 24 часов в рабочие дни.</p>
        <p><strong>7.3.</strong> Исполнитель оставляет за собой право отказать в обслуживании пользователям, проявляющим грубость, угрозы или ненадлежащее поведение.</p>
      </div>
    </div>
  </section>

  <!-- § 8 -->
  <section class="offerta-section offerta-alt">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 8. Персональные данные и конфиденциальность</h2>
        <p><strong>8.1.</strong> Исполнитель собирает только минимально необходимые данные для оказания услуг (Telegram ID, username).</p>
        <p><strong>8.2.</strong> Персональные данные пользователей не продаются третьим лицам. Рейтинги и показатели активности могут быть публично видимы в рамках сервиса.</p>
        <p><strong>8.3.</strong> Платёжные данные обрабатываются платёжными системами. Исполнитель не хранит данные карт.</p>
      </div>
    </div>
  </section>

  <!-- § 9 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 9. Заключительные положения</h2>
        <p><strong>9.1.</strong> Исполнитель оставляет за собой право изменять условия настоящей оферты в любое время. Изменения вступают в силу с момента публикации в Telegram-канале @starsjoy.</p>
        <p><strong>9.2.</strong> Продолжение использования сервиса после изменения условий оферты считается принятием новых условий.</p>
        <p><strong>9.3.</strong> Споры разрешаются в первую очередь путём переговоров. При недостижении соглашения — в судебном порядке в соответствии с законодательством Республики Узбекистан.</p>
        <p><strong>9.4.</strong> Недействительность отдельных пунктов оферты не влияет на действительность остальных положений.</p>
      </div>
    </div>
  </section>

  <!-- Footer line -->
  <section class="offerta-footer-line">
    <div class="container">
      <div class="offerta-block">
        <p class="offerta-footer-text">StarsJoy &middot; starsjoy.uz &middot; @starsjoybot</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .offerta-hero {
    padding: 120px 24px 60px;
    background: #FFFFFF;
  }

  .breadcrumb {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.85rem; color: var(--text-muted); margin-bottom: 32px;
  }
  .breadcrumb a { color: var(--primary); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .offerta-hero-content { max-width: 760px; margin: 0 auto; }
  .offerta-title {
    font-size: 2.4rem; font-weight: 900; line-height: 1.15;
    margin-bottom: 16px; color: var(--text);
  }
  .offerta-meta {
    font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 4px;
  }

  .offerta-section { padding: 60px 24px; }
  .offerta-alt { background: #FFFFFF; }

  .offerta-block { max-width: 760px; margin: 0 auto; }
  .offerta-block h2 {
    font-size: 1.4rem; font-weight: 800; margin-bottom: 20px; color: var(--text);
  }
  .offerta-block p {
    font-size: 0.95rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 12px;
  }
  .offerta-block p:last-child { margin-bottom: 0; }
  .offerta-block ul {
    list-style: none; padding: 0; margin: 0 0 12px;
  }
  .offerta-block li {
    font-size: 0.95rem; color: var(--text-muted); line-height: 1.8;
    padding-left: 20px; position: relative; margin-bottom: 6px;
  }
  .offerta-block li::before {
    content: '—'; position: absolute; left: 0; color: var(--text-muted);
  }

  .offerta-footer-line {
    padding: 40px 24px;
    border-top: 1px solid var(--border);
  }
  .offerta-footer-text {
    text-align: center; font-size: 0.9rem; color: var(--text-muted); font-weight: 600;
  }

  @media (max-width: 640px) {
    .offerta-hero { padding: 100px 16px 40px; }
    .offerta-title { font-size: 1.6rem; }
    .offerta-meta { font-size: 0.85rem; }
    .offerta-section { padding: 40px 16px; }
    .offerta-block h2 { font-size: 1.2rem; margin-bottom: 16px; }
    .offerta-block p { font-size: 0.9rem; }
    .offerta-block li { font-size: 0.9rem; }
    .breadcrumb { margin-bottom: 20px; font-size: 0.8rem; }
  }
</style>
