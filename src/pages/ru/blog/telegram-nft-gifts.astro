    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://starsjoy.uz/ru" },
      { "@type": "ListItem", "position": 2, "name": "Блог", "item": "https://starsjoy.uz/ru/blog" },
      { "@type": "ListItem", "position": 3, "name": "Telegram NFT Gifts", "item": "https://starsjoy.uz/ru/blog/telegram-nft-gifts" }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Что такое Telegram NFT Gifts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Telegram NFT Gifts — это подарки внутри Telegram, которые хранятся в блокчейне TON и могут быть проданы как NFT."
        }
      },
      {
        "@type": "Question",
        "name": "Чем NFT-подарки отличаются от обычных?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "NFT-подарки уникальны, их владение подтверждено блокчейном, их можно продать, и их стоимость может расти. Обычные подарки предназначены только для использования."
        }
      },
      {
        "@type": "Question",
        "name": "Можно ли продать NFT-подарки?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Да, их можно продать через маркетплейс. Пользователь может отправить подарок, сохранить в профиле или продать."
        }
      },
      {
        "@type": "Question",
        "name": "Как формируются цены на NFT-подарки Telegram?",
