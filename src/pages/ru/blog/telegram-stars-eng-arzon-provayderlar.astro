                    <td>Средняя–высокая</td>
                    <td>Visa / Mastercard</td>
                    <td>Сразу</td>
                  </tr>
                  <tr>
                    <td>4</td>
                    <td>App Store / Google Play</td>
                    <td>Дороже всего (+30% комиссия)</td>
                    <td>Международная карта</td>
                    <td>Сразу</td>
                  </tr>
                </tbody>
