              <tr><td>Продажа Premium (3, 6, 12 мес.)</td><td>—</td><td>✅</td></tr>
              <tr><td>Профессиональный SEO-сайт</td><td>—</td><td>✅</td></tr>
              <tr><td>Click + Payme + Uzcard + Humo</td><td>✅</td><td>✅</td></tr>
              <tr><td>Сервер и хостинг (12 мес.)</td><td>✅</td><td>✅</td></tr>
