  ogType="article"
  lang="ru"
  hreflangs={[
    { lang: "uz", href: "https://starsjoy.uz/blog/telegram-premium-vizasiz" },
    { lang: "ru", href: "https://starsjoy.uz/ru/blog/telegram-premium-vizasiz" }
  ]}
>
  <NavbarRu />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Купить Telegram Premium без Visa (2026): через Uzcard, Humo и бот",
    "description": description,
    "datePublished": publishDate,
    "dateModified": publishDate,
    "author": {
      "@type": "Organization",
