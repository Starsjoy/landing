---
import Layout from '../../layouts/Layout.astro';
import NavbarRu from '../../components/NavbarRu.astro';
import Footer from '../../components/Footer.astro';

const title = "Купить Telegram Stars — Дёшево и Быстро | StarsJoy";
const description = "Купить Telegram Stars по самым низким ценам. Доставка за 1-5 минут, оплата через Click и карту. 100% гарантия. StarsJoy — надёжный сервис покупки звёзд Телеграм.";

const faqs = [
  {
    q: "Что такое Telegram Stars?",
    a: "Telegram Stars — это внутренняя валюта Телеграма, с помощью которой можно оплачивать контент каналов, услуги ботов и поддерживать авторов. Stars открывают доступ к премиум-контенту и различным сервисам внутри мессенджера."
  },
  {
    q: "Сколько стоят Telegram Stars?",
    a: "В StarsJoy вы можете купить Telegram Stars по самым низким ценам в Узбекистане. Стоимость начинается от 50 Stars. Чем больше звёзд вы покупаете, тем дешевле выходит каждая единица. Актуальные цены — в нашем боте."
  },
  {
    q: "Как купить Telegram Stars через StarsJoy?",
    a: "Всё очень просто: 1) Откройте @starsjoybot в Телеграме, 2) Выберите нужное количество Stars, 3) Оплатите через Click или банковскую карту, 4) Получите звёзды на свой аккаунт за 1-5 минут."
  },
  {
    q: "Как быстро приходят Stars после оплаты?",
    a: "После подтверждения оплаты Telegram Stars поступают на ваш аккаунт в течение 1-5 минут. Если доставка займёт больше 5 минут, мы начислим 10 Stars в качестве компенсации."
  },
  {
    q: "Что можно делать с Telegram Stars?",
    a: "С помощью Stars можно подписываться на премиум-контент каналов, оплачивать платные функции ботов, отправлять поддержку любимым авторам и совершать покупки внутри Telegram. Это универсальная валюта мессенджера."
  },
  {
    q: "Безопасно ли покупать Telegram Stars через StarsJoy?",
    a: "Да, покупка Stars через StarsJoy полностью безопасна. Мы используем только официальные методы, предоставляем полную гарантию возврата средств и обслужили тысячи довольных клиентов."
  }
];
---

<Layout
  title={title}
  description={description}
  canonical="https://starsjoy.uz/ru/stars"
  keywords="купить Telegram Stars, Telegram Stars цена, купить звёзды Телеграм, Telegram Stars дёшево, звёзды Телеграм купить Узбекистан, StarsJoy Stars"
  lang="ru"
  hreflangs={[
    { lang: "uz", href: "https://starsjoy.uz/stars" },
    { lang: "ru", href: "https://starsjoy.uz/ru/stars" }
  ]}
>
  <NavbarRu />

  <!-- SEO Schema Markup: Product -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Telegram Stars",
    "description": description,
    "brand": { "@type": "Brand", "name": "StarsJoy" },
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "UZS",
      "availability": "https://schema.org/InStock",
      "offerCount": "10+"
    }
  })} />

  <!-- SEO Schema Markup: FAQ -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": { "@type": "Answer", "text": faq.a }
    }))
  })} />

  <!-- SEO Schema Markup: Breadcrumb -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://starsjoy.uz/ru" },
      { "@type": "ListItem", "position": 2, "name": "Купить Telegram Stars", "item": "https://starsjoy.uz/ru/stars" }
    ]
  })} />

  <!-- Hero -->
  <section class="stars-hero">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/ru">Главная</a>
        <span>/</span>
        <span>Telegram Stars</span>
      </nav>
      <div class="stars-hero-inner fade-in">
        <div class="stars-hero-content">
          <h1 class="stars-title">Купить Telegram Stars — По Лучшим Ценам</h1>
          <p class="stars-desc">
            Купить звёзды Телеграм стало проще простого! С StarsJoy вы получите Telegram Stars быстро, недорого и с полной гарантией. Оплата через Click и банковскую карту.
          </p>
          <div class="stars-features">
            <div class="stars-feature">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2l2.5 5 5.5.8-4 3.9 1 5.4L10 14.4l-4.9 2.7 1-5.4-4-3.9 5.5-.8L10 2z" fill="#FBBF24" stroke="#D97706" stroke-width="1"/></svg>
              <span>Доставка 1-5 мин</span>
            </div>
            <div class="stars-feature">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="5" y="9" width="10" height="9" rx="2" stroke="#7C3AED" stroke-width="1.5"/><path d="M7.5 9V7a2.5 2.5 0 1 1 5 0v2" stroke="#7C3AED" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span>100% гарантия</span>
            </div>
            <div class="stars-feature">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="7" stroke="#10B981" stroke-width="1.5"/><path d="M10 7v6M7 10h6" stroke="#10B981" stroke-width="1.5" stroke-linecap="round"/></svg>
              <span>Лучшие цены</span>
            </div>
          </div>
          <a href="https://t.me/starsjoybot" class="btn-primary" target="_blank">
            &#9889; Купить Stars Сейчас
          </a>
        </div>
        <div class="stars-hero-visual">
          <div class="stars-icon-big">
            <svg width="80" height="80" viewBox="0 0 52 52" fill="none">
              <defs>
                <linearGradient id="stG" x1="6" y1="6" x2="46" y2="46">
                  <stop offset="0%" stop-color="#FFD60A"/>
                  <stop offset="50%" stop-color="#FFAE00"/>
                  <stop offset="100%" stop-color="#FF9500"/>
                </linearGradient>
              </defs>
              <path d="M26 4l6.2 12.5L45 18.8l-9.5 9.3 2.2 13.1L26 34.8l-11.7 6.4 2.2-13.1L7 18.8l12.8-2.3L26 4z" fill="url(#stG)"/>
              <path d="M26 4l6.2 12.5L45 18.8l-9.5 9.3 2.2 13.1L26 34.8V4z" fill="#FFE066" opacity="0.35"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Зачем нужны Stars -->
  <section class="stars-why">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Telegram Stars</span>
        <h2 class="section-title">Зачем нужны Telegram Stars?</h2>
        <p class="section-subtitle">Stars — внутренняя валюта Телеграма, которая открывает множество возможностей</p>
      </div>
      <div class="why-grid">
        <div class="why-card fade-in">
          <div class="why-icon wi-content">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="4" width="20" height="20" rx="4" stroke="currentColor" stroke-width="2"/><path d="M10 12h8M10 16h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3>Премиум контент</h3>
          <p>Получите доступ к закрытым постам и эксклюзивному контенту каналов с помощью Telegram Stars</p>
        </div>
        <div class="why-card fade-in">
          <div class="why-icon wi-bot">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="5" y="3" width="18" height="22" rx="4" stroke="currentColor" stroke-width="2"/><circle cx="14" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M14 9V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="11" y1="20" x2="17" y2="20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3>Сервисы ботов</h3>
          <p>Оплачивайте платные функции и услуги Telegram-ботов звёздами — удобно и быстро</p>
        </div>
        <div class="why-card fade-in">
          <div class="why-icon wi-support">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 4l3 6 6.6 1-4.8 4.6 1.1 6.6L14 19l-5.9 3.2 1.1-6.6L4.4 11l6.6-1L14 4z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
          </div>
          <h3>Поддержка авторов</h3>
          <p>Отправляйте Stars любимым контент-мейкерам в знак благодарности и поддержки</p>
        </div>
        <div class="why-card fade-in">
          <div class="why-icon wi-gift">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="5" y="13" width="18" height="11" rx="3" stroke="currentColor" stroke-width="2"/><rect x="7" y="8" width="14" height="6" rx="2" stroke="currentColor" stroke-width="2"/><rect x="12.5" y="8" width="3" height="16" rx="1" fill="currentColor" opacity="0.2"/></svg>
          </div>
          <h3>В подарок</h3>
          <p>Подарите Stars друзьям — лучший цифровой подарок внутри Телеграма</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Как купить -->
  <section class="stars-how">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">Инструкция</span>
        <h2 class="section-title">Как купить Telegram Stars?</h2>
        <p class="section-subtitle">Всего 3 шага — и Stars у вас на аккаунте за 5 минут</p>
      </div>
      <div class="how-steps">
        <div class="how-step fade-in">
          <div class="how-step-num">1</div>
          <h3>Откройте бот</h3>
          <p>Перейдите в <strong>@starsjoybot</strong> в Телеграме и нажмите кнопку «Купить Stars»</p>
        </div>
        <div class="how-step fade-in">
          <div class="how-step-num">2</div>
          <h3>Выберите количество</h3>
          <p>Укажите нужное количество Stars и оплатите через Click или банковскую карту</p>
        </div>
        <div class="how-step fade-in">
          <div class="how-step-num">3</div>
          <h3>Получите Stars</h3>
          <p>В течение 1-5 минут Telegram Stars поступят на ваш аккаунт. Готово!</p>
        </div>
      </div>
      <div class="how-cta fade-in">
        <a href="https://t.me/starsjoybot" class="btn-primary" target="_blank">&#9889; Начать Покупку</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="stars-faq">
    <div class="container">
      <div class="section-header fade-in">
        <span class="section-label">FAQ</span>
        <h2 class="section-title">Вопросы о Telegram Stars</h2>
        <p class="section-subtitle">Ответы на самые частые вопросы о покупке звёзд Телеграм</p>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <div class="faq-item fade-in">
            <button class="faq-question">
              <span>{faq.q}</span>
              <span class="faq-toggle">+</span>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-inner">{faq.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="stars-cta">
    <div class="container">
      <div class="stars-cta-box fade-in">
        <h2>Готовы купить Telegram Stars?</h2>
        <p>Лучшие цены, мгновенная доставка и 100% гарантия безопасности</p>
        <a href="https://t.me/starsjoybot" class="btn-white" target="_blank">&#9889; Купить Stars</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<!-- FAQ Script -->
<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement!;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const isActive = item.classList.contains('active');
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('active');
        (i.querySelector('.faq-answer') as HTMLElement).style.maxHeight = '';
      });
      if (!isActive) {
        item.classList.add('active');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });
</script>

<style>
  /* ===== HERO ===== */
  .stars-hero {
    padding: 120px 24px 80px;
    background: linear-gradient(180deg, #FFFBEB 0%, #FFFFFF 100%);
    position: relative;
    overflow: hidden;
  }
  .stars-hero::before {
    content: '';
    position: absolute;
    top: -150px; right: -150px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(255, 174, 0, 0.08), transparent 70%);
    pointer-events: none;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 32px;
  }
  .breadcrumb a { color: var(--primary); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .stars-hero-inner {
    display: flex;
    align-items: center;
    gap: 60px;
  }
  .stars-hero-content { flex: 1; }
  .stars-hero-visual {
    flex: 0 0 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stars-title {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: 20px;
    color: var(--text);
  }
  .stars-desc {
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 28px;
    max-width: 540px;
  }

  .stars-features {
    display: flex;
    gap: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .stars-feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text);
  }

  .stars-icon-big {
    width: 160px;
    height: 160px;
    background: linear-gradient(135deg, #FFF8E1, #FFE082);
    border-radius: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 16px 48px rgba(255, 174, 0, 0.2);
  }

  /* ===== WHY ===== */
  .stars-why { background: var(--bg-alt); }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .why-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 24px;
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .why-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }
  .why-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
  }
  .why-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .why-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .wi-content { background: rgba(255, 174, 0, 0.1); color: #D97706; }
  .wi-bot { background: rgba(124, 58, 237, 0.08); color: #7C3AED; }
  .wi-support { background: rgba(37, 99, 235, 0.08); color: #2563EB; }
  .wi-gift { background: rgba(16, 185, 129, 0.08); color: #10B981; }

  /* ===== HOW ===== */
  .how-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 40px;
  }
  .how-step {
    text-align: center;
    padding: 32px 24px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .how-step h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--text);
  }
  .how-step p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .how-step-num {
    width: 48px;
    height: 48px;
    margin: 0 auto 16px;
    background: var(--gradient);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.2rem;
    color: #fff;
  }
  .how-cta { text-align: center; }

  /* ===== FAQ ===== */
  .stars-faq { background: var(--bg-alt); }
  .faq-list {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .faq-item {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .faq-item.active {
    border-color: rgba(124, 58, 237, 0.3);
    box-shadow: 0 4px 16px rgba(124, 58, 237, 0.08);
  }
  .faq-question {
    width: 100%;
    padding: 20px 24px;
    background: none;
    border: none;
    color: var(--text);
    font-size: 1rem;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-family: inherit;
  }
  .faq-question:hover { color: var(--primary); }
  .faq-toggle {
    width: 28px; height: 28px; min-width: 28px;
    border-radius: 8px;
    background: rgba(124, 58, 237, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--primary);
    transition: transform 0.3s;
  }
  .faq-item.active .faq-toggle { transform: rotate(45deg); }
  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-answer-inner {
    padding: 0 24px 20px;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* ===== CTA ===== */
  .stars-cta-box {
    background: var(--gradient);
    border-radius: 24px;
    padding: 60px 40px;
    text-align: center;
    color: #fff;
  }
  .stars-cta-box h2 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 12px;
  }
  .stars-cta-box p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 28px;
  }
  .btn-white {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 36px;
    background: #fff;
    color: #5B21B6;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-white:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .stars-hero-inner { flex-direction: column; text-align: center; }
    .stars-hero-visual { flex: none; }
    .stars-desc { margin: 0 auto 28px; }
    .stars-features { justify-content: center; }
    .why-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .stars-hero { padding: 100px 16px 40px; }
    .stars-hero-inner { gap: 28px; text-align: left; }
    .stars-title { font-size: 1.75rem; line-height: 1.2; }
    .stars-desc { font-size: 0.95rem; margin: 0 0 20px; line-height: 1.6; }
    .stars-features { flex-direction: column; align-items: flex-start; gap: 10px; margin-bottom: 24px; }
    .stars-feature { font-size: 0.85rem; }
    .breadcrumb { margin-bottom: 20px; font-size: 0.8rem; }
    .stars-hero-visual { display: none; }
    .stars-hero-inner :global(.btn-primary) { width: 100%; justify-content: center; padding: 14px 24px; font-size: 0.95rem; }

    .why-grid { grid-template-columns: 1fr; gap: 12px; }
    .why-card {
      padding: 24px 20px;
      text-align: center;
    }
    .why-card:hover { transform: none; }
    .why-icon { width: 48px; height: 48px; min-width: 48px; margin: 0 auto 12px; border-radius: 14px; }
    .why-card h3 { font-size: 0.95rem; margin-bottom: 4px; }
    .why-card p { font-size: 0.82rem; line-height: 1.5; }

    .how-steps { grid-template-columns: 1fr; gap: 12px; }
    .how-step {
      padding: 20px;
      display: flex;
      flex-direction: row;
      align-items: center;
      text-align: left;
