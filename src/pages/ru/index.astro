<!-- 3D Cube & Animation Scripts -->
<script>
  // 3D Cube rotation
  const cube = document.getElementById('cube3d');
  if (cube) {
    let angle = 0;
    function rotateCube() {
      angle += 0.3;
      const tiltX = Math.sin(angle * 0.01) * 6;
      cube!.style.transform = `rotateY(${angle}deg) rotateX(${tiltX}deg)`;
      requestAnimationFrame(rotateCube);
    }
    rotateCube();
  }

  // Logo float
  const logoEl = document.getElementById('logoFloat');
  if (logoEl) {
    let t = 0;
    function floatLogo() {
      t += 0.025;
      const y = Math.sin(t) * 8;
      logoEl!.style.transform = `translateY(${y}px)`;
      requestAnimationFrame(floatLogo);
    }
    floatLogo();
  }

  // Shadow pulse
  const shadow = document.getElementById('cubeShadow');
  if (shadow) {
    let st = 0;
    function pulseShadow() {
      st += 0.02;
      const s = 0.85 + Math.sin(st) * 0.15;
      const o = 0.4 + Math.sin(st) * 0.2;
      shadow!.style.transform = `scaleX(${s})`;
      shadow!.style.opacity = `${o}`;
      requestAnimationFrame(pulseShadow);
    }
    pulseShadow();
  }

  // Sparkle dots
  document.querySelectorAll('.dot').forEach((dot, i) => {
    const el = dot as HTMLElement;
    let dt = i * 1.2;
    function animDot() {
      dt += 0.025;
      const val = (Math.sin(dt) + 1) / 2;
      const opacity = val * 0.9;
      const scale = 0.5 + val * 0.8;
      const moveY = val * -10;
      el.style.opacity = `${opacity}`;
      el.style.transform = `scale(${scale}) translateY(${moveY}px)`;
      requestAnimationFrame(animDot);
    }
    animDot();
  });

  // FAQ accordion
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement!;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const isActive = item.classList.contains('active');

      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('active');
        (i.querySelector('.faq-answer') as HTMLElement).style.maxHeight = '';
      });

      if (!isActive) {
        item.classList.add('active');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });
</script>

