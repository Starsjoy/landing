---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const title = "Ommaviy Oferta Shartnomasi | StarsJoy";
const description = "StarsJoy ommaviy oferta shartnomasi — xizmat ko'rsatish shartlari, to'lov tartibi, qaytarim siyosati va foydalanuvchi majburiyatlari haqida to'liq ma'lumot.";
---

<Layout
  title={title}
  description={description}
  canonical="https://starsjoy.uz/oferta"
  keywords="StarsJoy oferta, StarsJoy shartnoma, StarsJoy shartlar, StarsJoy qaytarim, StarsJoy refund"
>
  <Navbar />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Bosh sahifa", "item": "https://starsjoy.uz" },
      { "@type": "ListItem", "position": 2, "name": "Ommaviy Oferta", "item": "https://starsjoy.uz/oferta" }
    ]
  })} />

  <section class="offerta-hero">
    <div class="container">
      <div class="offerta-hero-content">
        <nav class="breadcrumb">
          <a href="/">Bosh sahifa</a>
          <span>/</span>
          <span>Ommaviy Oferta</span>
        </nav>
        <h1 class="offerta-title">Ommaviy Oferta Shartnomasi</h1>
        <p class="offerta-meta">StarsJoy &middot; starsjoy.uz &middot; @starsjoybot</p>
        <p class="offerta-meta">Kuchga kirgan sana: 2026-yil 5-mart</p>
      </div>
    </div>
  </section>

  <!-- § 1 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 1. Umumiy qoidalar</h2>
        <p><strong>1.1.</strong> Ushbu hujjat StarsJoy (bundan keyin — «Ijrochi») tomonidan taqdim etiladigan raqamli mahsulotlarni sotib olish shartlarini belgilovchi ommaviy oferta shartnomasi hisoblanadi.</p>
        <p><strong>1.2.</strong> Ijrochi starsjoy.uz sayti va @starsjoybot Telegram-bot orqali faoliyat yuritadi.</p>
        <p><strong>1.3.</strong> Foydalanuvchi botda buyurtma berish orqali ushbu oferta shartlarini to'liq va so'zsiz qabul qilgan hisoblanadi (aksept).</p>
        <p><strong>1.4.</strong> Ijrochi O'zbekiston Respublikasi qonunchiligiga muvofiq faoliyat yuritadi.</p>
      </div>
    </div>
  </section>

  <!-- § 2 -->
  <section class="offerta-section offerta-alt">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 2. Taqdim etiladigan xizmatlar</h2>
        <p><strong>2.1.</strong> Ijrochi quyidagi raqamli xizmatlarni taqdim etadi:</p>
        <ul>
          <li><strong>Telegram Stars</strong> — Telegram ichidagi rasmiy to'lov birliklarini sotib olish;</li>
          <li><strong>Telegram Premium</strong> — Telegram Premium obunasini faollashtirish;</li>
          <li><strong>Telegram Gifts</strong> — Telegram orqali sovg'a yuborish.</li>
        </ul>
        <p><strong>2.2.</strong> Barcha mahsulotlar raqamli tarzda, to'g'ridan-to'g'ri Telegram akkauntingizga yetkaziladi.</p>
        <p><strong>2.3.</strong> Ijrochi Telegram platformasining rasmiy API va Fragment orqali xizmat ko'rsatadi. StarsJoy mustaqil reseller sifatida faoliyat yuritadi.</p>
      </div>
    </div>
  </section>

  <!-- § 3 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 3. Buyurtma berish va to'lov tartibi</h2>
        <p><strong>3.1.</strong> Buyurtma @starsjoybot orqali bot ko'rsatmalariga amal qilingan holda beriladi.</p>
        <p><strong>3.2.</strong> To'lov quyidagi usullar orqali qabul qilinadi: Click, Uzcard va Humo plastik kartalari.</p>
        <p><strong>3.3.</strong> To'lov muvaffaqiyatli o'tkazilgandan so'ng buyurtma 5 daqiqa ichida bajariladi.</p>
        <p><strong>3.4.</strong> Narxlar O'zbek so'mida belgilanadi. Narx buyurtma berish paytidagi kurs va tarifga asoslanadi.</p>
        <p><strong>3.5.</strong> Ijrochi narxlarni oldindan xabardor qilmagan holda o'zgartirish huquqini saqlab qoladi.</p>
      </div>
    </div>
  </section>

  <!-- § 4 -->
  <section class="offerta-section offerta-alt">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 4. Xizmat ko'rsatish shartlari</h2>
        <p><strong>4.1.</strong> Foydalanuvchi noto'g'ri Telegram username yoki ID kiritmagan holda yuzaga kelgan muammolar uchun Ijrochi javobgar emas.</p>
        <p><strong>4.2.</strong> Telegram platformasi tomonidan yuzaga keladigan texnik uzilishlar, Telegram qoidalari o'zgarishi yoki Telegram akkauntining bloklanishi uchun Ijrochi mas'uliyat olmaydi.</p>
        <p><strong>4.3.</strong> Foydalanuvchi Telegram akkauntida Stars qabul qilish imkoniyati yoqilgan bo'lishi shart. Aks holda buyurtma bajarilmasligi mumkin.</p>
      </div>
    </div>
  </section>

  <!-- § 5 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 5. To'lovni qaytarish (refund) siyosati</h2>
        <p><strong>5.1.</strong> Raqamli mahsulotlar yetkazib berilgandan keyin qaytarilmaydi.</p>
        <p><strong>5.2.</strong> To'lov muvaffaqiyatli o'tgan, lekin buyurtma texnik nosozlik sababli bajarilmagan taqdirda foydalanuvchi to'liq qaytarim talab qilish huquqiga ega.</p>
        <p><strong>5.3.</strong> Qaytarim talabi to'lov o'tkazilgan kundan 24 soat ichida @starsjoy_bot (support bot) orqali yuborilishi kerak. To'lov screenshoti yoki tasdig'i ilova qilinishi shart.</p>
        <p><strong>5.4.</strong> Foydalanuvchi noto'g'ri Telegram ma'lumotlari kiritganligi sababli buyurtma boshqa shaxsga yetkazilgan bo'lsa, qaytarim amalga oshirilmaydi.</p>
        <p><strong>5.5.</strong> Buyurtma bajarilgandan keyin foydalanuvchi o'z irodasi bilan voz kechgan holda qaytarim ko'rib chiqilmaydi.</p>
      </div>
    </div>
  </section>

  <!-- § 6 -->
  <section class="offerta-section offerta-alt">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 6. Foydalanuvchi majburiyatlari</h2>
        <p><strong>6.1.</strong> Foydalanuvchi xizmatdan faqat qonuniy maqsadlarda foydalanishi shart.</p>
        <p><strong>6.2.</strong> Xizmatni firibgarlik, spam yoki boshqalarga zarar yetkazish maqsadida ishlatish qat'iyan taqiqlanadi. Bunday foydalanuvchilar bloklanadi.</p>
        <p><strong>6.3.</strong> Foydalanuvchi Telegram platformasining Foydalanish shartlariga rioya qilish majburiyatini o'z zimmasiga oladi.</p>
      </div>
    </div>
  </section>

  <!-- § 7 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 7. Qo'llab-quvvatlash xizmati</h2>
        <p><strong>7.1.</strong> Barcha murojaat va savollar faqat @starsjoy_bot (support bot) orqali qabul qilinadi.</p>
        <p><strong>7.2.</strong> Murojaatlarga ish kunlari 24 soat ichida javob beriladi.</p>
        <p><strong>7.3.</strong> Qo'pol munosabat, tahdid yoki noto'g'ri xatti-harakat ko'rsatgan foydalanuvchilarga xizmat ko'rsatishdan bosh tortish huquqi Ijrochida saqlanadi.</p>
      </div>
    </div>
  </section>

  <!-- § 8 -->
  <section class="offerta-section offerta-alt">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 8. Shaxsiy ma'lumotlar va maxfiylik</h2>
        <p><strong>8.1.</strong> Ijrochi faqat xizmat ko'rsatish uchun zarur bo'lgan minimal ma'lumotlarni (Telegram ID, username) jamlaydi.</p>
        <p><strong>8.2.</strong> Foydalanuvchi shaxsiy ma'lumotlari uchinchi shaxslarga sotilmaydi. Reyting va faollik ko'rsatkichlari xizmat doirasida ommaviy ko'rinishi mumkin.</p>
        <p><strong>8.3.</strong> To'lov ma'lumotlari to'lov tizimlari tomonidan boshqariladi. Ijrochi karta ma'lumotlarini saqlamaydi.</p>
      </div>
    </div>
  </section>

  <!-- § 9 -->
  <section class="offerta-section">
    <div class="container">
      <div class="offerta-block">
        <h2>§ 9. Yakuniy qoidalar</h2>
        <p><strong>9.1.</strong> Ijrochi ushbu oferta shartlarini istalgan vaqtda o'zgartirish huquqini saqlab qoladi. O'zgarishlar @starsjoy telegram kanalida e'lon qilingan paytdan kuchga kiradi.</p>
        <p><strong>9.2.</strong> Oferta shartlari o'zgargandan so'ng xizmatdan foydalanishni davom ettirish — yangi shartlarni qabul qilish sifatida talqin etiladi.</p>
        <p><strong>9.3.</strong> Nizolar birinchi navbatda muzokaralar yo'li bilan hal etiladi. Kelishuv bo'lmasa, O'zbekiston Respublikasi qonunchiligiga muvofiq sudga murojaat qilinadi.</p>
        <p><strong>9.4.</strong> Ushbu ofertaning alohida bandlari haqiqiy bo'lmasa, qolgan bandlar o'z kuchini saqlab qoladi.</p>
      </div>
    </div>
  </section>

  <!-- Footer line -->
  <section class="offerta-footer-line">
    <div class="container">
      <div class="offerta-block">
        <p class="offerta-footer-text">StarsJoy &middot; starsjoy.uz &middot; @starsjoybot</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .offerta-hero {
    padding: 120px 24px 60px;
    background: #FFFFFF;
  }

  .breadcrumb {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.85rem; color: var(--text-muted); margin-bottom: 32px;
  }
  .breadcrumb a { color: var(--primary); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .offerta-hero-content { max-width: 760px; margin: 0 auto; }
  .offerta-title {
    font-size: 2.4rem; font-weight: 900; line-height: 1.15;
    margin-bottom: 16px; color: var(--text);
  }
  .offerta-meta {
    font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 4px;
  }

  .offerta-section { padding: 60px 24px; }
  .offerta-alt { background: #FFFFFF; }

  .offerta-block { max-width: 760px; margin: 0 auto; }
  .offerta-block h2 {
    font-size: 1.4rem; font-weight: 800; margin-bottom: 20px; color: var(--text);
  }
  .offerta-block p {
    font-size: 0.95rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 12px;
  }
  .offerta-block p:last-child { margin-bottom: 0; }
  .offerta-block ul {
    list-style: none; padding: 0; margin: 0 0 12px;
  }
  .offerta-block li {
    font-size: 0.95rem; color: var(--text-muted); line-height: 1.8;
    padding-left: 20px; position: relative; margin-bottom: 6px;
  }
  .offerta-block li::before {
    content: '—'; position: absolute; left: 0; color: var(--text-muted);
  }

  .offerta-footer-line {
    padding: 40px 24px;
    border-top: 1px solid var(--border);
  }
  .offerta-footer-text {
    text-align: center; font-size: 0.9rem; color: var(--text-muted); font-weight: 600;
  }

  @media (max-width: 640px) {
    .offerta-hero { padding: 100px 16px 40px; }
    .offerta-title { font-size: 1.6rem; }
    .offerta-meta { font-size: 0.85rem; }
    .offerta-section { padding: 40px 16px; }
    .offerta-block h2 { font-size: 1.2rem; margin-bottom: 16px; }
    .offerta-block p { font-size: 0.9rem; }
    .offerta-block li { font-size: 0.9rem; }
    .breadcrumb { margin-bottom: 20px; font-size: 0.8rem; }
  }
</style>
