                    <th>Muddat</th>
                    <th>Rasmiy narx (USD)</th>
                    <th>Vositachi orqali (UZS)</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>1 oy</td>
                    <td>~$3.99</td>
                    <td>50,000 – 80,000</td>
                  </tr>
                  <tr>
                    <td>3 oy</td>
                    <td>~$10.99</td>
