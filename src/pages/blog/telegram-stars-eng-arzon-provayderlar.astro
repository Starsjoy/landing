      { "@type": "ListItem", "position": 1, "name": "Bosh sahifa", "item": "https://starsjoy.uz" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://starsjoy.uz/blog" },
      { "@type": "ListItem", "position": 3, "name": "Eng arzon Telegram Stars provayderlari", "item": "https://starsjoy.uz/blog/telegram-stars-eng-arzon-provayderlar" }
