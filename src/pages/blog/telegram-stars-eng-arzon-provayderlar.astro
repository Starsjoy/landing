      },
      {
        "@type": "Question",
        "name": "Nega App Store orqali Stars qimmat?",
        "acceptedAnswer": { "@type": "Answer", "text": "Apple va Google ilova ichidagi xaridlardan 30% gacha komissiya oladi. Shu sabab iOS yoki Android ilovasi orqali olingan Stars boshqa usullarga nisbatan ancha qimmat bo'ladi." }
      },
      {
        "@type": "Question",
        "name": "Fragment'da Stars arzonmi?",
        "acceptedAnswer": { "@type": "Answer", "text": "Fragment narxi TON kursiga bog'liq va o'zgarib turadi. Asosiy kamchilik — to'lov uchun TON kripto hamyoni kerak, Uzcard yoki Humo to'g'ridan-to'g'ri ishlamaydi, shuning uchun O'zbekiston foydalanuvchilari uchun noqulay." }
      },
      {
        "@type": "Question",
        "name": "Mahalliy bot orqali Stars sotib olish xavfsizmi?",
