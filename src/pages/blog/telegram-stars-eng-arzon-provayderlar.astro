      { "@type": "ListItem", "position": 1, "name": "Mahalliy botlar (StarsJoy, Uzcard/Humo)" },
      { "@type": "ListItem", "position": 2, "name": "Fragment (TON hamyon orqali)" },
      { "@type": "ListItem", "position": 3, "name": "Rasmiy Telegram bot (@PremiumBot)" },
      { "@type": "ListItem", "position": 4, "name": "App Store / Google Play" }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Telegram Stars'ni eng arzon qayerdan olish mumkin?",
