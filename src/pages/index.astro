---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Guarantees from '../components/Guarantees.astro';
import Referral from '../components/Referral.astro';
import Reviews from '../components/Reviews.astro';
import BlogHighlights from '../components/BlogHighlights.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Telegram Stars, Premium va Gifts - StarsJoy"
  canonical="https://starsjoy.uz"
  hreflangs={[
    { lang: "uz", href: "https://starsjoy.uz" },
    { lang: "ru", href: "https://starsjoy.uz/ru" }
  ]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "StarsJoy",
    "url": "https://starsjoy.uz",
    "description": "StarsJoy — O'zbekistonda Telegram Stars, Premium va Gifts xizmatlarini taqdim etuvchi platforma. Tez, ishonchli va arzon narxlarda.",
    "publisher": {
      "@type": "Organization",
      "name": "StarsJoy",
      "url": "https://starsjoy.uz",
      "logo": "https://starsjoy.uz/logo.png"
    }
  })} />
  <Navbar />
  <Hero />
  <Services />
  <HowItWorks />
  <Guarantees />
  <Reviews lang="uz" />
  <Referral />
  <BlogHighlights lang="uz" />
  <FAQ />
  <CTA />
  <Footer />
</Layout>
